# SPDX-License-Identifier: Apache-2.0
# clang-format style for the Alp SDK.
# Conservative LLVM/Zephyr-leaning baseline; refine in follow-ups.
---
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100
AlignConsecutiveAssignments: AcrossEmptyLines
AlignConsecutiveDeclarations: AcrossEmptyLines
AlignTrailingComments: true
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: WithoutElse
BreakBeforeBraces: Linux
KeepEmptyLinesAtTheStartOfBlocks: false
PointerAlignment: Right
SortIncludes: Never
SpaceAfterCStyleCast: false
SpacesInParentheses: false
SpacesInSquareBrackets: false
IncludeBlocks: Preserve
ReflowComments: false

# Pin behaviour across clang-format versions.  The LLVM default for
# Cpp11BracedListStyle flipped between clang-format 14 (Ubuntu apt
# default on the CI runner) and clang-format 18+, which makes the
# `(alp_i2c_config_t){ .foo = ... }` designated-initialiser idiom
# format differently on developer machines vs CI.  Locking it
# explicitly keeps the formatter idempotent across the version skew.
Cpp11BracedListStyle: false
