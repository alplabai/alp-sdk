# --- core: m33_sm (zephyr) ---
# Auto-generated by scripts/alp_orchestrate.py -- do not edit.
# Per-core Kconfig fragment for slice `m33_sm` (zephyr).

CONFIG_ALP_SDK=y
CONFIG_LOG=y
CONFIG_PRINTK=y
CONFIG_THREAD_LOCAL_STORAGE=y
CONFIG_LOG_DEFAULT_LEVEL=3

# On-module HW manifest EEPROM -> portable bus 0 (alp-i2c0);
# enables alp_hw_info_read() + the console banner manifest line.
CONFIG_ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID=0

# SoM silicon (renesas:rzv2n:n44 via E1M-V2N101)
CONFIG_ALP_SOC_RENESAS_RZV2N_N44=y

# Cross-EVK board facade selector (<alp/board.h>); CONFIG_COMPILER_OPT is single-value (do not also set in prj.conf).
CONFIG_COMPILER_OPT="-DALP_BOARD_E1M_X_EVK"

# SoM-intrinsic chip drivers (from `E1M-V2N101` on_module + helper_firmware)
CONFIG_ALP_SDK_CHIP_ACT8760=y
CONFIG_ALP_SDK_CHIP_CLK_5L35023B=y
CONFIG_ALP_SDK_CHIP_DA9292=y
CONFIG_ALP_SDK_CHIP_EEPROM_24C128=y
CONFIG_ALP_SDK_CHIP_GD32G553=y
CONFIG_ALP_SDK_CHIP_MURATA_LBEE5HY2FY=y
CONFIG_ALP_SDK_CHIP_OPTIGA_TRUST_M=y
CONFIG_ALP_SDK_CHIP_RTL8211FDI=y
CONFIG_ALP_SDK_CHIP_RV3028C7=y
CONFIG_ALP_SDK_CHIP_TMP112=y

# Board-populated chip drivers (from the resolved board definition)
CONFIG_ALP_SDK_CHIP_BME280=n
CONFIG_ALP_SDK_CHIP_BMI323=y
CONFIG_ALP_SDK_CHIP_BMP581=y
CONFIG_ALP_SDK_BLOCK_BUTTON_LED=y
CONFIG_ALP_SDK_CHIP_CAM_MUX_PI3WVR626=n
CONFIG_ALP_SDK_CHIP_ICM42670=y
CONFIG_ALP_SDK_CHIP_INA236=y
CONFIG_ALP_SDK_CHIP_LIS2DW12=n
CONFIG_ALP_SDK_CHIP_LSM6DSO=n
CONFIG_ALP_SDK_CHIP_OV5640=n
CONFIG_ALP_SDK_BLOCK_PDM_MIC=y
CONFIG_ALP_SDK_CHIP_SSD1306=n
CONFIG_ALP_SDK_CHIP_SSD1331=n
CONFIG_ALP_SDK_CHIP_TAS2563=y
CONFIG_ALP_SDK_CHIP_TCAL9538=y

# Zephyr subsystems required on core `m33_sm` (chip drivers + peripherals)
CONFIG_GPIO=y
CONFIG_I2C=y

