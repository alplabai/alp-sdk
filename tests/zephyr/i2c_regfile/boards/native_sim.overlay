/*
 * Copyright 2026 Alp Lab AB
 * SPDX-License-Identifier: Apache-2.0
 *
 * One emulated I2C bus exposed via the alp-i2c0 alias.  Unlike an
 * external-controller bench setup, the emul controller forwards
 * same-bus i2c_transfer calls addressed to a registered target to
 * that target's callbacks -- so the suite's controller-side
 * alp_i2c_write / alp_i2c_write_read calls drive the register-file
 * helper end to end on native_sim.
 */

#include <zephyr/dt-bindings/i2c/i2c.h>

/ {
    aliases {
        alp-i2c0 = &i2c0_emul;
    };

    /* native_sim's /soc has #address-cells=2, #size-cells=1, so
     * `reg` needs three cells: <addr_hi addr_lo size>. */
    soc {
        i2c0_emul: i2c@100 {
            compatible = "zephyr,i2c-emul-controller";
            status = "okay";
            reg = <0 0x100 4>;
            #address-cells = <1>;
            #size-cells = <0>;
            clock-frequency = <I2C_BITRATE_STANDARD>;
        };
    };
};
