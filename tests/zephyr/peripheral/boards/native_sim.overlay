/*
 * Copyright 2026 Alp Lab AB
 * SPDX-License-Identifier: Apache-2.0
 *
 * Devicetree overlay for the alp-sdk peripheral ztest under
 * native_sim.  Wires three emulated GPIOs, one emulated I2C bus,
 * one emulated SPI bus, the existing native_sim UART (uart0), and
 * one emulated UART (uart-emul) to the alias names alp_sdk's Zephyr
 * backend looks up.
 */

#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
    aliases {
        alp-i2c0  = &i2c0_emul;
        alp-spi0  = &spi0_emul;
        alp-uart0 = &uart0;
        alp-uart1 = &uart1_emul;
    };

    /* #626: alp_uart_read()'s timeout_ms == 0 / finite / partial-fill
     * contract needs bytes we control injecting into RX -- uart0 is
     * native_sim's real backing UART with no test-side RX hook, so a
     * second, purely emulated UART (uart_emul_put_rx_data()) backs
     * the timeout tests in src/uart.c instead of port 0. */
    uart1_emul: uart-emul-alp-uart1 {
        compatible = "zephyr,uart-emul";
        status = "okay";
        current-speed = <115200>;
        rx-fifo-size = <256>;
        tx-fifo-size = <256>;
    };

    soc {
        i2c0_emul: i2c@100 {
            compatible = "zephyr,i2c-emul-controller";
            status = "okay";
            reg = <0x100 4>;
            #address-cells = <1>;
            #size-cells = <0>;
            clock-frequency = <I2C_BITRATE_STANDARD>;
        };

        spi0_emul: spi@200 {
            compatible = "zephyr,spi-emul-controller";
            status = "okay";
            reg = <0x200 4>;
            #address-cells = <1>;
            #size-cells = <0>;
        };
    };

    gpio_emul0: gpio_emul0 {
        compatible = "zephyr,gpio-emul";
        status = "okay";
        gpio-controller;
        rising-edge;
        falling-edge;
        #gpio-cells = <2>;
        ngpios = <8>;
    };

    alp_pins: alp-pins {
        compatible = "alp,pin-array";
        gpios = <&gpio_emul0 0 GPIO_ACTIVE_HIGH>,
                <&gpio_emul0 1 GPIO_ACTIVE_HIGH>,
                <&gpio_emul0 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
    };
};
