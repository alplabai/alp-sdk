 *
 * ITCM link retarget so the SES loads each core's image to its ITCM global
 * alias (HE 0x58000000 / HP 0x50000000, set by the dual ATOC loadAddress).
 * app.overlay is auto-applied to BOTH the rtss_he and rtss_hp board builds.
 */
/ {
	chosen {
		zephyr,flash = &itcm;
		/delete-property/ zephyr,code-partition;
	};
};
