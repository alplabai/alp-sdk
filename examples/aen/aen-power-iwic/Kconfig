# Stage-B PM bring-up over the pinned Zephyr 4.4.0 tree.
#
# `config PM` (subsys/pm/Kconfig) `depends on SYS_CLOCK_EXISTS && HAS_PM`, and
# `config HAS_PM` is a prompt-less bool that can ONLY be `select`ed by a SoC/board
# (it has no menuconfig prompt, so it cannot be set from prj.conf).  Pinned
# upstream Zephyr's Alif Ensemble SoC layer does NOT select it (only the
# alifsemi/zephyr_alif fork does).  This app-level Kconfig selects it so the
# CONFIG_PM=y in prj.conf becomes reachable -- the Tier-1.5 plumbing that, with
# src/alif_pm_iwic.c (pm_state_set) and the board overlay (suspend_idle
# power-state), brings a minimal Alif PM up with no edit to upstream zephyr/.
#
# Gated on the AEN801 M55-HE board: HAS_PM is only honoured (and pm_state_set is
# only correct) on the M55 core where this app's WICCONTROL(HE)=0x1A604010 hook
# applies.

if BOARD_ALP_E1M_AEN801_M55_HE

config HAS_PM
	default y

endif # BOARD_ALP_E1M_AEN801_M55_HE

source "Kconfig.zephyr"
