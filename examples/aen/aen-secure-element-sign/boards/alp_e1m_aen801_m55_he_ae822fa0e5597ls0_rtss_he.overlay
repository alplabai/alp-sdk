 *
 * aen-secure-element-sign overlay for the E1M-AEN801 (Ensemble E8,
 * M55-HE) RAM-run.  Retarget ROM to ITCM so Flow C can load and run
 * this image without writing MRAM.
 */

/ {
	chosen {
		zephyr,flash = &itcm;
		/delete-property/ zephyr,code-partition;
	};
};
