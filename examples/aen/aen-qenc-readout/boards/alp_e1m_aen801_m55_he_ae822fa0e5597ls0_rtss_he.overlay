/*
 * Copyright (c) 2026 Alp Lab AB
 * SPDX-License-Identifier: Apache-2.0
 *
 * Quadrature-decoder overlay for the E1M-AEN801 (E8, M55-HE).
 *
 * Adds an "alif,utimer-qdec" CHILD under a UTIMER channel-12 parent
 * (utimer@4800d000, timer-id 12) -- channel 12 IS the QEC0 quadrature block.
 * Confirmed against the Alif DFP AE822FA0E5597 (Device/soc/AE822FA0E5597/
 * include/rtss_he/soc.h): QEC0_CMPA_IRQ_IRQn = 369 "Channel 12 interrupt
 * request at driver A".  So the QEC0 X/Y pads muxed below (P3_0/P3_1) are
 * decoded by UTIMER channel 12, NOT channel 0 -- binding the qdec under
 * utimer0/timer-id 0 reads a counter that never sees the encoder edges.
 *
 * Channel base 0x4800d000 = UTIMER_BASE 0x48000000 + (12 + 1) * 0x1000 (each
 * channel config block is 0x1000, DFP UTIMER_UTIMER_CHANNEL_CFG_Type "Size =
 * 4096 (0x1000)"; the dtsi utimer11/timer-id 11 = 0x4800c000 confirms the
 * stride).  The global common region stays 0x48000000 + 0x24, as on every
 * other utimer node.  Channel 12 is NOT defined in
 * zephyr/dts/alif/ensemble_e8_peripherals.dtsi (only 0/3/6/10/11 are), so the
 * full parent node is declared here.
 *
 * The parent carries a `clocks` phandle: the qdec driver reaches clk_dev/clkid
 * via DT_CLOCKS_CTLR/CELL(DT_INST_PARENT), and reads the "global"/"timer" reg
 * regions and timer-id from the parent too.
 *
 * PADS / TIMER MAPPING: the SoC exposes four dedicated quadrature blocks
 * QEC0..QEC3 (header ensemble-e4-e6-e8-pinctrl.h), which are UTIMER channels
 * 12..15 (DFP QEC{0..3}_CMPA_IRQn = 369/371/373/375):
 *   QEC0 X=P3_0 (chan A) / Y=P3_1 (chan B) / Z=P3_2 (index)   <- used here
 *   QEC1 P3_3/P3_4/P3_5 ; QEC2 P3_6/P3_7/P4_0 ; QEC3 P4_1/P4_2/P4_3
 * The encoder's wiring to the QEC0 pads is a schematic detail -- CONFIRM the
 * board harness before trusting the count.
 *
 * The QEC0 X/Y channel inputs carry `input-enable` (= the upstream pad REN bit
 * 16, set by soc/alif/ensemble/pinctrl_soc.h) so their input buffers actually
 * sense the encoder edges -- without it the count stays static regardless of
 * motion.
 */
#include <zephyr/dt-bindings/pinctrl/alif-ensemble-pinctrl.h>
#include <zephyr/dt-bindings/clock/alif-ensemble-clocks-ext.h>
#include <zephyr/dt-bindings/timer/alif_utimer.h>

/ {
	chosen {
		zephyr,flash = &itcm; /* bench RAM/SES-load; path-ref form */
		/delete-property/ zephyr,code-partition;
	};
	aliases {
		alp-qenc0 = &utimer12_qdec;
	};
};

&pinctrl {
	pinctrl_qec0: pinctrl_qec0 {
		/* QEC0 X/Y = encoder channel A/B INPUTS -> input-enable (pad REN). */
		group0 {
			pinmux = <PIN_P3_0__QEC0_X_A>, <PIN_P3_1__QEC0_Y_A>;
			input-enable;
		};
	};
};

&soc {
	/* QEC0 = UTIMER channel 12 (DFP: QEC0_CMPA_IRQn 369 = "Channel 12"). */
	utimer12: utimer@4800d000 {
		compatible = "alif,utimer";
		reg = <0x4800D000 0x1000 0x48000000 0x24>;
		reg-names = "timer", "global";
		timer-id = <12>;
		counter-direction = <ALIF_UTIMER_COUNTER_DIRECTION_UP>;
		clocks = <&clockctrl ALIF_UTIMER_CLK>;
		status = "okay";

		utimer12_qdec: qdec {
			compatible = "alif,utimer-qdec";
			counts-per-revolution = <1000>;
			input-filter-enable;
			filter-prescaler = <16>;
			filter-taps = <1>;
			pinctrl-0 = <&pinctrl_qec0>;
			pinctrl-names = "default";
			status = "okay";
		};
	};
};
