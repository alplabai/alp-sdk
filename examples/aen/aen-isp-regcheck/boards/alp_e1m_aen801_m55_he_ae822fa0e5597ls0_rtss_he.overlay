 * SPDX-License-Identifier: Apache-2.0
 *
 * aen-isp-regcheck overlay for the E1M-AEN801 (Ensemble E8, M55-HE) RAM-run.
 *
 * Enables the Alif ISP-Pico node so it BINDS on silicon:
 *   - isp (vsi,isp-pico @ 0x49046000, IRQs 367 "isp" / 368 "mi-isp")
 *
 * SCOPE: this proves the ISP node BINDS (DT_HAS_VSI_ISP_PICO_ENABLED + the reg/
 * irq match) AND builds+links the isp_pico.c driver TU (CONFIG_VIDEO_ISP_VSI=y,
 * see prj.conf) against hal_alif v2.3.0 + the vendored isp-vsi.h /
 * isp_ctrl_params.h headers (zephyr/include/zephyr/drivers/video/).  This is a
 * BUILD-ONLY proof: LIVE ISP processing stays BENCH-BLOCKED on this batch (no
 * camera sensor wired): the ISP only does useful work inside a
 * camera->csi->isp->memory media-controller graph, which this regcheck
 * deliberately does not stand up.
 */

/*
 * RAM-run: retarget ROM to ITCM (path-reference form &itcm; the phandle-array
 * form makes FLASH_SIZE=0 and overflows the link).
 */
/ {
	chosen {
		zephyr,flash = &itcm;
		/delete-property/ zephyr,code-partition;
	};
};

&isp {
	status = "okay";
};
