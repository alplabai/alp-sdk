 * SPDX-License-Identifier: Apache-2.0
 *
 * Wire native_sim's host-stdin/stdout UART to alp-uart0 so the
 * example exercises a real (host-mediated) byte path with the
 * interrupt-driven RX hook in place.  On real silicon the alias
 * points at a SoC USART node and the IRQ wakes on every byte
 * received.
 */

/ {
    aliases {
        alp-uart0 = &uart0;
    };
};
