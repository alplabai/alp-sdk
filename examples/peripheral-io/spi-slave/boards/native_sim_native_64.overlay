/*
 * Copyright 2026 Alp Lab AB
 * SPDX-License-Identifier: Apache-2.0
 *
 * One emulated SPI bus exposed via the alp-spi0 alias.  The
 * example targets BOARD_SPI_ARDUINO (alp-spi1), which native_sim
 * does not provide, so alp_spi_target_open degrades cleanly
 * (NOT_READY diagnostic) -- the alp-spi0 alias exists only for
 * the loader's DT-resolution pass to succeed.
 */

/ {
    aliases {
        alp-spi0 = &spi0_emul;
    };

    soc {
        spi0_emul: spi@200 {
            compatible = "zephyr,spi-emul-controller";
            status = "okay";
            reg = <0 0x200 4>;
            #address-cells = <1>;
            #size-cells = <0>;
        };
    };
};
