 * SPDX-License-Identifier: Apache-2.0
 *
 * Host overlay for the vendor-ext composability demo.
 *
 * The alp,pin-array is POSITIONAL: alp_z_gpio_resolve(pin_id) indexes
 * it by the E1M GPIO index, so entry N must be E1M pad N in the
 * e1m_pinout.h canonical order (IO0..25 = 0..25, PWM0..7 = 26..33,
 * ENC0_X..ENC3_Y = 34..41, ADC0..7 = 42..49, DAC0..1 = 50..51).
 *
 * Way 1 of the demo drives ADC1's pad as a plain GPIO, i.e.
 * E1M_GPIO_ADC1 = index 43.  A gpio-emul controller maxes out at 32
 * pins, so reaching index 43 needs TWO controllers -- this overlay
 * shows the canonical split a full 52-slot board file would use:
 *   indices  0..31 -> gpio_emul0 pins 0..31
 *   indices 32..43 -> gpio_emul1 pins 0..11   (index 43 = pin 11)
 * The array stops at 43, the highest index this demo touches.
 *
 * No ADC controller is wired, so the alp-adc1 alias resolves to a
 * NULL spec and Ways 2/3 take the graceful "skip" path -- the same
 * native_sim contract examples/peripheral-io/adc-voltmeter relies on.
 */

#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
    gpio_emul0: gpio_emul0 {
        compatible = "zephyr,gpio-emul";
        status = "okay";
        gpio-controller;
        rising-edge;
        falling-edge;
        #gpio-cells = <2>;
        ngpios = <32>;
    };

    gpio_emul1: gpio_emul1 {
        compatible = "zephyr,gpio-emul";
        status = "okay";
        gpio-controller;
        rising-edge;
        falling-edge;
        #gpio-cells = <2>;
        ngpios = <32>;
    };

    alp_pins: alp-pins {
        compatible = "alp,pin-array";
        gpios = <&gpio_emul0  0 GPIO_ACTIVE_HIGH>,   /* [ 0] E1M_GPIO_IO0  */
                <&gpio_emul0  1 GPIO_ACTIVE_HIGH>,   /* [ 1] E1M_GPIO_IO1  */
                <&gpio_emul0  2 GPIO_ACTIVE_HIGH>,   /* [ 2] E1M_GPIO_IO2  */
                <&gpio_emul0  3 GPIO_ACTIVE_HIGH>,   /* [ 3] E1M_GPIO_IO3  */
                <&gpio_emul0  4 GPIO_ACTIVE_HIGH>,   /* [ 4] E1M_GPIO_IO4  */
                <&gpio_emul0  5 GPIO_ACTIVE_HIGH>,   /* [ 5] E1M_GPIO_IO5  */
                <&gpio_emul0  6 GPIO_ACTIVE_HIGH>,   /* [ 6] E1M_GPIO_IO6  */
                <&gpio_emul0  7 GPIO_ACTIVE_HIGH>,   /* [ 7] E1M_GPIO_IO7  */
                <&gpio_emul0  8 GPIO_ACTIVE_HIGH>,   /* [ 8] E1M_GPIO_IO8  */
                <&gpio_emul0  9 GPIO_ACTIVE_HIGH>,   /* [ 9] E1M_GPIO_IO9  */
                <&gpio_emul0 10 GPIO_ACTIVE_HIGH>,   /* [10] E1M_GPIO_IO10 */
                <&gpio_emul0 11 GPIO_ACTIVE_HIGH>,   /* [11] E1M_GPIO_IO11 */
                <&gpio_emul0 12 GPIO_ACTIVE_HIGH>,   /* [12] E1M_GPIO_IO12 */
                <&gpio_emul0 13 GPIO_ACTIVE_HIGH>,   /* [13] E1M_GPIO_IO13 */
                <&gpio_emul0 14 GPIO_ACTIVE_HIGH>,   /* [14] E1M_GPIO_IO14 */
                <&gpio_emul0 15 GPIO_ACTIVE_HIGH>,   /* [15] E1M_GPIO_IO15 */
                <&gpio_emul0 16 GPIO_ACTIVE_HIGH>,   /* [16] E1M_GPIO_IO16 */
                <&gpio_emul0 17 GPIO_ACTIVE_HIGH>,   /* [17] E1M_GPIO_IO17 */
                <&gpio_emul0 18 GPIO_ACTIVE_HIGH>,   /* [18] E1M_GPIO_IO18 */
                <&gpio_emul0 19 GPIO_ACTIVE_HIGH>,   /* [19] E1M_GPIO_IO19 */
                <&gpio_emul0 20 GPIO_ACTIVE_HIGH>,   /* [20] E1M_GPIO_IO20 */
                <&gpio_emul0 21 GPIO_ACTIVE_HIGH>,   /* [21] E1M_GPIO_IO21 */
                <&gpio_emul0 22 GPIO_ACTIVE_HIGH>,   /* [22] E1M_GPIO_IO22 */
                <&gpio_emul0 23 GPIO_ACTIVE_HIGH>,   /* [23] E1M_GPIO_IO23 */
                <&gpio_emul0 24 GPIO_ACTIVE_HIGH>,   /* [24] E1M_GPIO_IO24 */
                <&gpio_emul0 25 GPIO_ACTIVE_HIGH>,   /* [25] E1M_GPIO_IO25 */
                <&gpio_emul0 26 GPIO_ACTIVE_HIGH>,   /* [26] E1M_GPIO_PWM0 */
                <&gpio_emul0 27 GPIO_ACTIVE_HIGH>,   /* [27] E1M_GPIO_PWM1 */
                <&gpio_emul0 28 GPIO_ACTIVE_HIGH>,   /* [28] E1M_GPIO_PWM2 */
                <&gpio_emul0 29 GPIO_ACTIVE_HIGH>,   /* [29] E1M_GPIO_PWM3 */
                <&gpio_emul0 30 GPIO_ACTIVE_HIGH>,   /* [30] E1M_GPIO_PWM4 */
                <&gpio_emul0 31 GPIO_ACTIVE_HIGH>,   /* [31] E1M_GPIO_PWM5 */
                <&gpio_emul1  0 GPIO_ACTIVE_HIGH>,   /* [32] E1M_GPIO_PWM6 */
                <&gpio_emul1  1 GPIO_ACTIVE_HIGH>,   /* [33] E1M_GPIO_PWM7 */
                <&gpio_emul1  2 GPIO_ACTIVE_HIGH>,   /* [34] E1M_GPIO_ENC0_X */
                <&gpio_emul1  3 GPIO_ACTIVE_HIGH>,   /* [35] E1M_GPIO_ENC0_Y */
                <&gpio_emul1  4 GPIO_ACTIVE_HIGH>,   /* [36] E1M_GPIO_ENC1_X */
                <&gpio_emul1  5 GPIO_ACTIVE_HIGH>,   /* [37] E1M_GPIO_ENC1_Y */
                <&gpio_emul1  6 GPIO_ACTIVE_HIGH>,   /* [38] E1M_GPIO_ENC2_X */
                <&gpio_emul1  7 GPIO_ACTIVE_HIGH>,   /* [39] E1M_GPIO_ENC2_Y */
                <&gpio_emul1  8 GPIO_ACTIVE_HIGH>,   /* [40] E1M_GPIO_ENC3_X */
                <&gpio_emul1  9 GPIO_ACTIVE_HIGH>,   /* [41] E1M_GPIO_ENC3_Y */
                <&gpio_emul1 10 GPIO_ACTIVE_HIGH>,   /* [42] E1M_GPIO_ADC0 */
                <&gpio_emul1 11 GPIO_ACTIVE_HIGH>;   /* [43] E1M_GPIO_ADC1 -- Way 1 drives this pad */
    };
};
