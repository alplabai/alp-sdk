# Build directories
build/
build_*/
out/
cmake-build-*/
bwdt/

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/c_cpp_properties.json
.vs/
.idea/
*.code-workspace

# Vendor SDKs are pulled by west / cpackget — not stored in git.
# Keep vendor README files; ignore everything else inside each wrapper.
vendors/*/sdk/
vendors/*/fsp/
vendors/*/cube/
!vendors/*/README.md
!vendors/*/CMakeLists.txt
!vendors/*/*.c
!vendors/*/*.h

# CC3501E SimpleLink CC33xx SDK -- license-gated, multi-GB, NOT redistributed
# by alp-sdk.  Keep the committed wrapper (CMakeLists.txt + README.md); ignore
# the extracted SDK if it is dropped in-tree under sdk/.  (The `vendors/`
# plural rule above does not match this firmware-local singular `vendor/` path.)
firmware/cc3501e/vendor/simplelink-cc33xx/sdk/

# Zephyr / west workspace artefacts when this repo is the topdir.
.west/
twister-out/
twister-out.*/
modules/
zephyr/.cache/

# Compiled binaries
*.exe
*.out
*.app
*.elf
*.bin
*.hex

# Libraries
*.a
*.lib
*.so
*.dylib
*.dll

# Object files
*.o
*.obj
*.lo

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Makefile
*.cmake
!CMakeLists.txt
# Hand-written tooling Makefile (NOT a CMake build artifact) -- the
# native_sim container's convenience targets.  Keep it tracked.
!tools/native-sim-container/Makefile
# Toolchain files MUST stay tracked -- the bridge builds invoke
# them via -DCMAKE_TOOLCHAIN_FILE in CI + locally.
!firmware/gd32-bridge/toolchain/*.cmake
!firmware/cc3501e/toolchain/*.cmake
# ... as is the build-id baker the gd32-bridge CMakeLists runs every build.
!firmware/gd32-bridge/cmake/*.cmake
!cmake/**/*.cmake
!toolchain/**/*.cmake
# Checked-in Zephyr board flash/debug runner files (board.cmake) -- these
# are source, not generated, and `west flash` needs them tracked.
!zephyr/boards/**/board.cmake

# Test results
Testing/
test_results/

# Temporary files
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Python (if using test scripts)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
# any virtualenv flavour, incl. the NPU-branch scratch envs (.venv-vela/,
# .venv/, etc.) -- keeps account-gated Vela/CMSIS/TVM wheels out of the
# public repo (the ~/npu-sdks-outside-the-tree convention).
.venv*/
*venv/
.claude/

# MCUboot signing keys -- per-directory .gitignore at keys/.gitignore
# keeps the development key file out of git; production public keys
# (*.pub.pem) are explicitly allowed back in.

# Maintainer-local notes (morning handoffs, scratch capture).
# These are deliberately uncommitted -- they capture run state for
# the next day, not durable documentation.
notes/

# Python packaging artefacts
*.egg-info/
dist/
*.dist-info/

# meta-alp-sdk: the private LPDDR4X DDR param is OVERLAID into this public layer
# tree at build time from alp-sdk-internal (see that repo's conf/bblayers-overlay.md).
# It is Renesas-gen_tool-derived, SoM-hardware-specific config and MUST NOT be
# committed to the public repo.
meta-alp-sdk/recipes-bsp/trusted-firmware-a/trusted-firmware-a/ddr_param_def_lpddr4-alp.c

# Local ARM Vela / NPU toolchain virtualenv (not redistributed)
.venv-vela/

# Alif-proprietary Vela system-config -- the NPU examples inject it at build
# time via -DAEN_NPU_VELA_CONFIG=<path>/ensemble_vela.ini (the .ini ships in
# alp-sdk-internal, NOT here).  This guard keeps a stray copy that an operator
# drops next to an example from ever being committed to the public repo.
ensemble_vela.ini
**/ensemble_vela.ini
firmware/cc3501e/hal/ti/cc3501e_ota_candidate.c
