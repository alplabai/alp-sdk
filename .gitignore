# Build directories
build/
build_*/
out/
cmake-build-*/

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/c_cpp_properties.json
.vs/
.idea/
*.code-workspace

# Vendor SDKs are pulled by west / cpackget — not stored in git.
# Keep vendor README files; ignore everything else inside each wrapper.
vendors/*/sdk/
vendors/*/fsp/
vendors/*/cube/
!vendors/*/README.md
!vendors/*/CMakeLists.txt
!vendors/*/*.c
!vendors/*/*.h

# Zephyr / west workspace artefacts when this repo is the topdir.
.west/
twister-out/
twister-out.*/
modules/
zephyr/.cache/

# Compiled binaries
*.exe
*.out
*.app
*.elf
*.bin
*.hex

# Libraries
*.a
*.lib
*.so
*.dylib
*.dll

# Object files
*.o
*.obj
*.lo

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Makefile
*.cmake
!CMakeLists.txt

# Test results
Testing/
test_results/

# Temporary files
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Python (if using test scripts)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.claude/
