{
  "schemaVersion": 1,
  "description": "Single source of truth for every `--emit` mode the SDK exposes across scripts/alp_project.py and scripts/alp_orchestrate/ (and re-exposed by scripts/alp_cli/emit.py's `alp emit` front door / `west alp-emit`). Frontends (alp-sdk-vscode, Alp Studio, IDE tooling) read THIS instead of hand-mirroring the argparse `choices=` lists in each CLI. A drift gate (scripts/check_emit_registry.py) asserts this file's mode set exactly matches the real `--emit` choices parsed out of alp_project.py and alp_orchestrate/cli.py, so a mode added to the code with no registry entry (or a phantom registry entry with no code) fails CI. Stability: additive-only per mode; a breaking change to an existing mode's shape ships as a new schemaVersion.",
  "modes": [
    {
      "mode": "zephyr-conf",
      "owner": {
        "cli": "alp_project",
        "module": "scripts/alp_orchestrate/kconfig.py",
        "function": "_slice_alp_conf"
      },
      "scope": "core",
      "options": {
        "input": "optional",
        "output": "optional",
        "core": "optional",
        "build_root": false
      },
      "compatible": { "os": ["zephyr"] },
      "output": {
        "media": "kconfig-conf",
        "schema_id": null,
        "path": "build/<core_id>-zephyr/alp.conf",
        "consumer_hint": "zephyr build -- Kconfig fragment appended to prj.conf"
      }
    },
    {
