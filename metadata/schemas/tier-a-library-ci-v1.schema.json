{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alplab.example/schemas/tier-a-library-ci-v1.schema.json",
  "title": "ADR 0018 Tier-A library CI registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "hostBuild", "familyMatrix"],
  "properties": {
    "schemaVersion": {
      "const": "tier-a-library-ci-v1"
    },
    "_comment": {
      "type": "string"
    },
    "hostBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "libraries", "excludedLibraries"],
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "libraries": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "excludedLibraries": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "familyMatrix": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family", "som", "core"],
        "properties": {
          "family": {
            "type": "string",
            "minLength": 1
          },
          "som": {
            "type": "string",
            "pattern": "^E1M-[A-Z0-9]+$"
          },
          "core": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
