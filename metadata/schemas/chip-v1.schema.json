{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alplabai/alp-sdk/metadata/schemas/chip-v1.schema.json",
  "title": "alp-sdk chip manifest (v1)",
  "description": "Per-chip manifest under metadata/chips/<part>.yaml. Physical block optional; when present it feeds the carrier netlist + BOM (alp-studio#65).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "chip_id", "display_name", "vendor", "mpn_population", "datasheet", "bus", "kconfig", "families", "verification"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "chip_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "display_name": { "type": "string" },
    "driver_status": { "type": "string" },
    "vendor": { "type": "string" },
    "mpn_population": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "datasheet": { "type": "object" },
    "bus": { "type": "string" },
    "i2c": { "type": "object" },
    "spi": { "type": "object" },
    "uart": { "type": "object" },
    "kconfig": { "type": "object" },
    "families": { "type": "array" },
    "verification": { "type": "object" },
    "resolutions": { "type": "object" },
    "peripherals": { "type": "object" },
    "sensor": { "type": "object" },
    "mipi": { "type": "object" },
    "precision": { "type": "object" },
    "notes": { "type": "string" },
    "audio": { "type": "object" },
    "motor": { "type": "object" },
    "ranging": { "type": "object" },
    "gnss": { "type": "object" },
    "formats": { "type": "array" },
    "cellular": { "type": "object" },
    "encoder": { "type": "object" },
    "protocol": { "type": "object" },
    "register_table": { "type": "array" },
    "interconnect": { "type": "object" },
    "rails": { "type": "array" },
    "crypto": { "type": "object" },
    "operation_mode": { "type": "string" },
    "channels": { "type": "array" },
    "control_lines": { "type": "array" },
    "upstream": { "type": "object" },
    "dependencies": { "type": "array" },
    "capacity": { "type": "object" },
    "target_expected_idcode": { "type": "string" },
    "pwm_routing": { "type": "object" },
    "pcie": { "type": "object" },
    "adc": { "type": "object" },
    "monitoring": { "type": "object" },
    "silicon_under_lid": { "type": "array" },
    "side_channel_lines": { "type": "array" },
    "bulk_traffic_lines": { "type": "array" },
    "capabilities": { "type": "object" },
    "gpios": { "type": "object" },
    "instances_per_lane": { "type": "integer" },
    "v2n_m1_path_mapping": { "type": "object" },
    "features": { "type": "array" },
    "mdio": { "type": "object" },
    "oui": { "type": "integer" },
    "phy_id_pattern": { "type": "integer" },
    "instances_per_v2n": { "type": "integer" },
    "instances": { "type": "array" },
    "power": { "type": "object" },
    "slave_address_range": { "type": "string" },
    "radio": { "type": "object" },
    "host_interfaces": { "type": "object" },
    "signals": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["input", "output", "bidir", "power", "ground", "analog", "open_drain", "open_drain_output"] },
          "scope": { "type": "string" },
          "v2n_route": { "type": "string" },
          "notes": { "type": "string" },
          "direction": { "type": "string" },
          "role": { "type": "string" },
          "route": { "type": "string" },
          "aen_route": { "type": "string" }
        }
      }
    },
    "physical": {
      "type": "object", "additionalProperties": false,
      "if": { "required": ["pins"] },
      "then": { "required": ["refdes_prefix", "package", "footprint", "pins", "visibility", "provenance"] },
      "properties": {
        "refdes_prefix": { "type": "string", "pattern": "^[A-Z]+$" },
        "package": { "type": "string" },
        "footprint": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "visibility": { "type": "string", "enum": ["public", "internal"] },
        "provenance": { "type": "string", "enum": ["datasheet_confirmed", "web_provisional", "internal_netlist"], "description": "Trust level of the pad/footprint data. web_provisional = transcribed from a public datasheet found online, pending maintainer confirmation." },
        "dimension_mm": { "type": "string" },
        "antenna": { "type": "string" },
        "operating_temp_deg_c": { "type": "string" },
        "pins": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["pad", "signal"],
            "properties": { "pad": { "type": "string" }, "signal": { "type": "string" } }
          }
        },
        "passives": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["role", "value", "net", "refdes_prefix"],
            "properties": {
              "role": { "type": "string", "enum": ["decouple", "pullup", "pulldown", "series", "bulk", "level_shift"] },
              "value": { "type": "string" }, "net": { "type": "string" },
              "refdes_prefix": { "type": "string", "pattern": "^[A-Z]+$" }
            }
          }
        }
      }
    }
  }
}
