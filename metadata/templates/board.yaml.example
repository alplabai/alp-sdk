# Minimal board.yaml example for testing scripts/alp_project.py
# and scripts/alp_orchestrate.py.  The richly-commented template at
# board.yaml is what consumers fork; this file is the smallest
# valid document the loader can exercise end-to-end.

som:
  sku: E1M-AEN801

preset: e1m-evk

# Per-core runtime mapping.  The E8 silicon exposes the A32 cluster
# plus the M55-HP + M55-HE pair; this minimal Zephyr example runs
# only M55-HP and leaves the other topology defaults alone.
# This example runs Zephyr on M55-HP only; M55-HE inherits the SoM
# topology's default Zephyr shim (so the build covers both halves
# by default).
cores:
  m55_hp:
    app: ./src
    inference:
      default_arena_kib: 128
    libraries:
      - lvgl              # exercise the LVGL CONFIG_* path
      - mbedtls           # exercise the MbedTLS CONFIG_* path
      - cmsis_dsp         # exercise the CMSIS-DSP CONFIG_* path
      - etl               # exercise the user-facing C++ lib path
    iot:
      wifi: true
      mqtt: true
      ble: false
      tls: true

diagnostics:
  last_error: true
  log_level: info
