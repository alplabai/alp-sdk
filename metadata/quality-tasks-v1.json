      "description": "Fail if any repo board.yaml has an outstanding schema migration.",
      "runner": "check-script",
      "script": "scripts/check_board_schema_version.py",
      "gate": true,
      "profiles": [
        "pr",
        "full",
        "release"
      ],
      "output": "none",
      "ci": null
    },
    {
      "id": "build-plan",
