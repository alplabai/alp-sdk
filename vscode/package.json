{
  "name": "alp-sdk",
  "displayName": "ALP SDK",
  "description": "First-class IDE support for ALP SDK projects: board.yaml schema-aware editing, alp_project.py loader commands, per-OS dependency bootstrap, and west build/flash/run wrappers.",
  "version": "0.3.0",
  "publisher": "alplabai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alplabai/alp-sdk.git",
    "directory": "vscode"
  },
  "homepage": "https://github.com/alplabai/alp-sdk/tree/main/vscode",
  "bugs": {
    "url": "https://github.com/alplabai/alp-sdk/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "alp-sdk",
    "embedded",
    "zephyr",
    "yocto",
    "alif",
    "renesas",
    "nxp"
  ],
  "activationEvents": [
    "onLanguage:yaml",
    "workspaceContains:**/board.yaml"
  ],
  "main": "./out/extension.js",
  "extensionDependencies": [
    "redhat.vscode-yaml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "alp.generateZephyrConf",
        "title": "Alp: Generate alp.conf (zephyr-conf)",
        "category": "Alp"
      },
      {
        "command": "alp.generateDtsOverlay",
        "title": "Alp: Generate alp.overlay (dts-overlay)",
        "category": "Alp"
      },
      {
        "command": "alp.generateCmakeArgs",
        "title": "Alp: Generate CMake -D args",
        "category": "Alp"
      },
      {
        "command": "alp.generateYoctoConf",
        "title": "Alp: Generate Yocto local.conf snippet",
        "category": "Alp"
      },
      {
        "command": "alp.generateAll",
        "title": "Alp: Generate all (zephyr-conf + dts-overlay + cmake-args + yocto-conf)",
        "category": "Alp"
      },
      {
        "command": "alp.validateBoardYaml",
        "title": "Alp: Validate board.yaml",
        "category": "Alp"
      },
      {
        "command": "alp.installDependencies",
        "title": "Alp: Install dependencies (per-OS)",
        "category": "Alp"
      },
      {
        "command": "alp.westBuild",
        "title": "Alp: West build",
        "category": "Alp"
      },
      {
        "command": "alp.westFlash",
        "title": "Alp: West flash",
        "category": "Alp"
      },
      {
        "command": "alp.westRunNativeSim",
        "title": "Alp: Run under native_sim",
        "category": "Alp"
      },
      {
        "command": "alp.openConfigurator",
        "title": "Alp: Open board configurator (GUI)",
        "category": "Alp"
      }
    ],
    "yamlValidation": [
      {
        "fileMatch": "board.yaml",
        "url": "./schemas/board-config-v1.schema.json"
      }
    ],
    "snippets": [
      {
        "language": "yaml",
        "path": "./snippets/board-yaml.json"
      }
    ],
    "configuration": {
      "title": "ALP SDK",
      "properties": {
        "alpSdk.path": {
          "type": "string",
          "default": "",
          "description": "Path to the alp-sdk repository checkout.  When empty, the extension searches the workspace for the SDK root (a directory containing scripts/alp_project.py)."
        },
        "alpSdk.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python interpreter to use for the loader + validator.  Defaults to `python3` (POSIX) / `python` (Windows)."
        },
        "alpSdk.boardYamlPath": {
          "type": "string",
          "default": "board.yaml",
          "description": "Path (relative to the workspace root) of the board.yaml the loader operates on."
        },
        "alpSdk.westCwd": {
          "type": "string",
          "default": "",
          "description": "Working directory for `west build/flash/run`.  When empty, defaults to the workspace root."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0"
  }
}
