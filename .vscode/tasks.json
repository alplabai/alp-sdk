{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure CMake (Mock Driver)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "build",
                "-DBUILD_MOCK=ON",
                "-DBUILD_EXAMPLES=ON"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Configure CMake (Alif Driver)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "build",
                "-DBUILD_ALIF=ON",
                "-DBUILD_EXAMPLES=ON"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build (CMake)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "dependsOn": []
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build",
                "--target",
                "clean"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Run Getting Started Example",
            "type": "shell",
            "command": "${workspaceFolder}/build/bin/getting_started",
            "windows": {
                "command": "${workspaceFolder}\\build\\bin\\getting_started.exe"
            },
            "group": "test",
            "problemMatcher": [],
            "dependsOn": [
                "Build (CMake)"
            ]
        },
        {
            "label": "Download Alif SDK",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/download_alif_sdk.ps1"
            ],
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Full Build and Run (Mock)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure CMake (Mock Driver)",
                "Build (CMake)",
                "Run Getting Started Example"
            ],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "CMSIS Erase",
            "type": "shell",
            "command": "pyocd",
            "options": {
                "cwd": "${workspaceFolder}/examples",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "args": [
                "erase",
                "--probe",
                "cmsisdap:",
                "--chip",
                "--cbuild-run",
                "${command:cmsis-csolution.getCbuildRunFile}"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load",
            "type": "shell",
            "command": "pyocd",
            "options": {
                "cwd": "${workspaceFolder}/examples",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "args": [
                "load",
                "--probe",
                "cmsisdap:",
                "--cbuild-run",
                "${command:cmsis-csolution.getCbuildRunFile}"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Run",
            "type": "shell",
            "command": "pyocd",
            "options": {
                "cwd": "${workspaceFolder}/examples",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "args": [
                "gdbserver",
                "--probe",
                "cmsisdap:",
                "--connect",
                "attach",
                "--persist",
                "--reset-run",
                "--cbuild-run",
                "${command:cmsis-csolution.getCbuildRunFile}",
                "--quiet",
                "--log",
                "*.cbuild_run,*server=info"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load+Run",
            "dependsOn": [
                "CMSIS Load",
                "CMSIS Run"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "CMSIS TargetInfo",
            "type": "shell",
            "command": "pyocd",
            "options": {
                "cwd": "${workspaceFolder}/examples",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "args": [
                "list",
                "--cbuild-run",
                "${command:cmsis-csolution.getCbuildRunFile}"
            ],
            "problemMatcher": []
        }
    ]
}
