{
    "//": [
        "VS Code tasks for the ALP SDK.  Two flavours:",
        "  1. Zephyr-module flow (`west build`) for ztests + examples.",
        "     Requires a Zephyr workspace with this repo loaded as a",
        "     module via `EXTRA_ZEPHYR_MODULES` or west.yml.",
        "  2. Plain-CMake flow (`cmake`/`ctest`) for OS-independent",
        "     metadata + ABI tooling.",
        "Both flows assume PowerShell on Windows / bash on Linux/macOS."
    ],
    "version": "2.0.0",
    "tasks": [
        {
            "label": "validate · metadata (soc-spec v1)",
            "type": "shell",
            "command": "python3",
            "args": ["scripts/validate_metadata.py"],
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "regen · soc_caps.h",
            "type": "shell",
            "command": "python3",
            "args": ["scripts/gen_soc_caps.py"],
            "problemMatcher": []
        },
        {
            "label": "regen · ABI snapshot (v0.1)",
            "type": "shell",
            "command": "python3",
            "args": [
                "scripts/abi_snapshot.py",
                "--version", "v0.1",
                "--output", "docs/abi/v0.1-snapshot.json"
            ],
            "problemMatcher": []
        },
        {
            "label": "diff · ABI vs v0.1 snapshot",
            "type": "shell",
            "command": "python3",
            "args": [
                "scripts/abi_snapshot.py",
                "--diff", "docs/abi/v0.1-snapshot.json"
            ],
            "problemMatcher": []
        },
        {
            "label": "twister · all (native_sim/native/64)",
            "type": "shell",
            "command": "python3",
            "args": [
                "${env:ZEPHYR_BASE}/scripts/twister",
                "--testsuite-root", "${workspaceFolder}/tests/zephyr",
                "--testsuite-root", "${workspaceFolder}/examples",
                "-p", "native_sim/native/64",
                "--inline-logs"
            ],
            "options": {
                "env": {
                    "EXTRA_ZEPHYR_MODULES": "${workspaceFolder}"
                }
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "twister · peripheral suite",
            "type": "shell",
            "command": "python3",
            "args": [
                "${env:ZEPHYR_BASE}/scripts/twister",
                "--testsuite-root", "${workspaceFolder}/tests/zephyr/peripheral",
                "-p", "native_sim/native/64",
                "--inline-logs"
            ],
            "options": {
                "env": {
                    "EXTRA_ZEPHYR_MODULES": "${workspaceFolder}"
                }
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "twister · chips suite",
            "type": "shell",
            "command": "python3",
            "args": [
                "${env:ZEPHYR_BASE}/scripts/twister",
                "--testsuite-root", "${workspaceFolder}/tests/zephyr/chips",
                "-p", "native_sim/native/64",
                "--inline-logs"
            ],
            "options": {
                "env": {
                    "EXTRA_ZEPHYR_MODULES": "${workspaceFolder}"
                }
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "west build · edgeai-vision-aen (native_sim)",
            "type": "shell",
            "command": "west",
            "args": [
                "build", "-b", "native_sim/native/64",
                "${workspaceFolder}/examples/edgeai-vision-aen",
                "-d", "${workspaceFolder}/build/edgeai-vision-aen",
                "--", "-DEXTRA_ZEPHYR_MODULES=${workspaceFolder}"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "west build · iot-connected-camera (native_sim)",
            "type": "shell",
            "command": "west",
            "args": [
                "build", "-b", "native_sim/native/64",
                "${workspaceFolder}/examples/iot-connected-camera",
                "-d", "${workspaceFolder}/build/iot-connected-camera",
                "--", "-DEXTRA_ZEPHYR_MODULES=${workspaceFolder}"
            ],
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "configure · plain CMake (baremetal stubs)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build/baremetal",
                "-S", ".",
                "-DALP_OS=baremetal",
                "-DALP_BUILD_TESTS=ON"
            ],
            "problemMatcher": []
        },
        {
            "label": "GD32 SDK · update submodule",
            "type": "shell",
            "command": "git",
            "args": [
                "submodule", "update", "--init", "--recursive",
                "vendors/gd32_firmware_library/upstream"
            ],
            "problemMatcher": [],
            "detail": "Clone or refresh the alplabai/gd32g5x3-firmware-library submodule under vendors/gd32_firmware_library/upstream/.  Unblocks BRIDGE_HAL_BACKEND=gd32 in gd32-bridge/CMakeLists.txt."
        }
    ]
}
