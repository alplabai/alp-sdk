#
# Cross-platform line-ending policy.
#
# Zephyr / GCC / clang-format all treat LF as canonical -- pin it
# here so a Windows checkout (where git's autocrlf=true would
# otherwise rewrite to CRLF) doesn't break clang-format-diff CI
# on the next push.  Developers on macOS / Windows / Linux all
# see and commit identical bytes.

* text=auto eol=lf

# Source -- always LF.  Pin explicitly so editor / git config can't override.
*.c       text eol=lf
*.h       text eol=lf
*.cpp     text eol=lf
*.hpp     text eol=lf
*.py      text eol=lf
*.cmake   text eol=lf
*.txt     text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.conf    text eol=lf
*.overlay text eol=lf
*.dts     text eol=lf
*.dtsi    text eol=lf
*.kconfig text eol=lf
Kconfig*  text eol=lf
CMakeLists.txt text eol=lf

# Patch files preserve upstream diff context; context markers followed by tabs
# are valid patch syntax, not source indentation damage.
*.patch text eol=lf -whitespace

# Shell / Python helpers must stay LF so they remain executable
# under WSL and macOS.
*.sh      text eol=lf

# Windows .bat / .ps1 stay CRLF (cmd.exe / PowerShell expect it).
*.bat     text eol=crlf
*.ps1     text eol=crlf

# Binary blobs -- never touch.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.zip     binary
*.tar.gz  binary
*.tflite  binary
*.onnx    binary
*.dxnn    binary
*.alpmodel binary
*.bin     binary
*.elf     binary
