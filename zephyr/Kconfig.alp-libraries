#
# Per-library + per-backend Kconfig symbols emitted by the
# §D.lib.loader cross-library HW-backend loader hook in
# scripts/alp_project.py.  Each enabled library's
# metadata/library-profiles/<name>/hw-backends.yaml names accelerator
# *classes* (not vendor parts) -- the loader cross-references those
# against the active SoM family and emits the highest-priority
# matching `CONFIG_ALP_<LIB>_<BACKEND>=y` knob.  Every library has a
# pure-SW fallback that is always available.
#
# Sourced under `if ALP_SDK` from zephyr/Kconfig once the loader hook
# is consumed downstream.  This file just declares the symbols.

# v0.5 §D.lib.loader -- per-library HW-accelerator Kconfig knobs.

menu "ALP SDK per-library HW-accelerator wiring"

# ----------------------------------------------------------------------
# tflite_micro
# ----------------------------------------------------------------------

config ALP_TFLM_ETHOS_U85
	bool "TFLite-Micro on Alif Ethos-U85 NPU (E4 / E6 / E8 only)"
	depends on ALP_SOC_ALIF_ENSEMBLE_E4 || ALP_SOC_ALIF_ENSEMBLE_E6 || \
	           ALP_SOC_ALIF_ENSEMBLE_E8
	help
	  Compile TFLite-Micro kernels against the Alif Ethos-U85 NPU
	  back-end (delegated execution).  Only E4 / E6 / E8 populate a
	  U85 alongside the family-standard pair of U55s.  U85 supports
	  Transformers and is the strategic forward path for Generative
	  AI workloads on the Ensemble family.

config ALP_TFLM_ETHOS_U55
	bool "TFLite-Micro on Alif Ethos-U55 NPU"
	depends on ALP_SOC_ALIF_ENSEMBLE_E3 || ALP_SOC_ALIF_ENSEMBLE_E4 || \
	           ALP_SOC_ALIF_ENSEMBLE_E5 || ALP_SOC_ALIF_ENSEMBLE_E6 || \
	           ALP_SOC_ALIF_ENSEMBLE_E7 || ALP_SOC_ALIF_ENSEMBLE_E8
	help
	  Compile TFLite-Micro kernels against an Alif Ethos-U55 NPU
	  back-end (delegated execution).  Every Ensemble SKU carries
	  two U55s (NPU-HE paired with M55-HE, NPU-HP paired with
	  M55-HP); the driver shim is the same for both instances and
	  selects at runtime via base-address + IRQ.  Enabled on every
	  E* SoC -- it's the family-wide primary on E3 / E5 / E7 (no
	  U85) and the secondary on E4 / E6 / E8 (alongside the U85).

config ALP_TFLM_ETHOS_U65
	bool "TFLite-Micro on NXP i.MX 93 Ethos-U65 NPU"
	depends on ALP_SOC_NXP_IMX9_IMX93
	help
	  Compile TFLite-Micro kernels against the Ethos-U65 NPU
	  embedded in i.MX 93.  Same TFLM op-resolver as U55 / U85;
	  Vela's `--accelerator-config ethos-u65-256` target.  The
	  legacy `CONFIG_ALP_SDK_INFERENCE_ETHOS_U_N93=y` knob is the
	  N93-specific driver shim that complements this kernel-level
	  knob.

config ALP_TFLM_DRP_AI
	bool "TFLite-Micro on Renesas DRP-AI NPU"
	depends on ALP_SOC_RENESAS_RZV2N_N44
	help
	  Compile TFLite-Micro kernels against the Renesas DRP-AI3 NPU.

