# ----------------------------------------------------------------------
# .alpmodel package reader (<alp/model.h>)
# ----------------------------------------------------------------------

config ALP_SDK_MODEL_READER
	bool "Read-side .alpmodel package parser (<alp/model.h>)"
	default n
	select ZCBOR
	help
	  Compile src/common/alp_model.c, the OS-agnostic read-side parser
	  for the .alpmodel package (24-byte header + CBOR manifest + blob
	  table).  alp_model_parse() decodes an in-memory package into a
	  bounded, stack-friendly alp_model_t view (model identity, the
	  per-backend target table, and blob slices) with no heap.

	  Selects ZCBOR for the manifest-map decode.  Off by default; the
	  runtime model loader (and any hand-written firmware that consumes
	  .alpmodel packages directly) opts in.
