/*
 * Copyright (c) 2026 Alp Lab AB
 * SPDX-License-Identifier: Apache-2.0
 *
 * alp-sdk SoC-overlay for the Alif Ensemble E8 (AE822FA0E5597xx0).
 *
 * Upstream Zephyr v4.4's Alif SoC layer (dts/arm/alif/ensemble/) models only
 * UART + clocks + pinctrl + memory; the GPIO / I2C / SPI / Ethernet peripheral
 * nodes are absent.  Alif's peripherals are DesignWare (Synopsys) IP, for which
 * Zephyr already ships generic drivers (gpio_dw / i2c_dw / spi_dw / eth_dwmac),
 * so this overlay just *declares the nodes* with the `snps,designware-*`
 * compatibles + the SoC's reg / IRQ / clock; a board enables (status="okay")
 * the instances its carrier uses.
 *
 * reg/IRQ values are transcribed from Alif's Apache-2.0 zephyr_alif fork
 * (dts/arm/alif/ensemble/common/e1.dtsi) -- the same SoC, identical addresses.
 * The fork's ALIF_DEFAULT_IRQ_PRIORITY (not in upstream) is rendered here as a
 * literal priority 3 (the repo's default IRQ priority, matching the MHU nodes).
 *
 * Included by the alp_e1m_aen801_m55_{he,hp} boards via the alp-sdk dts_root
 * (`#include <alif/ensemble_e8_peripherals.dtsi>`).  vendor-ext, BENCH-UNVERIFIED.
 *
 * Populated: GPIO (snps,designware-gpio), LPI2C (alif,lpi2c), Ethernet
 * (alif,ethernet over the upstream eth_dwmac core), SPI0 (snps,designware-spi).
 * The non-UART peripheral clock IDs upstream's alif-ensemble-clocks.h omits are
 * supplied, re-encoded for the upstream clockctrl, by the alp-sdk -ext header
 * included below.
 */

#include <zephyr/dt-bindings/clock/alif-ensemble-clocks-ext.h>

&soc {
	/*
	 * DesignWare GPIO -- 10 general ports (gpio0..gpio9) + the LP-island
	 * port (lpgpio).  Each port is an independent 0x1000 register block with
	 * 8 pins and 8 per-pin interrupt lines.  gpio_dw needs no clocks and no
	 * pinctrl on the controller; the pad->GPIO mux is applied per-pin via the
	 * Alif pinctrl group on whichever node consumes the pin.
	 */
	gpio0: gpio@49000000 {
		compatible = "snps,designware-gpio";
		reg = <0x49000000 0x1000>;
		ngpios = <8>;
		interrupts = <179 3>, <180 3>, <181 3>, <182 3>,
			     <183 3>, <184 3>, <185 3>, <186 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio1: gpio@49001000 {
		compatible = "snps,designware-gpio";
		reg = <0x49001000 0x1000>;
		ngpios = <8>;
		interrupts = <187 3>, <188 3>, <189 3>, <190 3>,
			     <191 3>, <192 3>, <193 3>, <194 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio2: gpio@49002000 {
		compatible = "snps,designware-gpio";
		reg = <0x49002000 0x1000>;
		ngpios = <8>;
		interrupts = <195 3>, <196 3>, <197 3>, <198 3>,
			     <199 3>, <200 3>, <201 3>, <202 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio3: gpio@49003000 {
		compatible = "snps,designware-gpio";
		reg = <0x49003000 0x1000>;
		ngpios = <8>;
		interrupts = <203 3>, <204 3>, <205 3>, <206 3>,
			     <207 3>, <208 3>, <209 3>, <210 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio4: gpio@49004000 {
		compatible = "snps,designware-gpio";
		reg = <0x49004000 0x1000>;
		ngpios = <8>;
		interrupts = <211 3>, <212 3>, <213 3>, <214 3>,
			     <215 3>, <216 3>, <217 3>, <218 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio5: gpio@49005000 {
		compatible = "snps,designware-gpio";
		reg = <0x49005000 0x1000>;
		ngpios = <8>;
		interrupts = <219 3>, <220 3>, <221 3>, <222 3>,
			     <223 3>, <224 3>, <225 3>, <226 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio6: gpio@49006000 {
		compatible = "snps,designware-gpio";
		reg = <0x49006000 0x1000>;
		ngpios = <8>;
		interrupts = <227 3>, <228 3>, <229 3>, <230 3>,
			     <231 3>, <232 3>, <233 3>, <234 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio7: gpio@49007000 {
		compatible = "snps,designware-gpio";
		reg = <0x49007000 0x1000>;
		ngpios = <8>;
		interrupts = <235 3>, <236 3>, <237 3>, <238 3>,
			     <239 3>, <240 3>, <241 3>, <242 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio8: gpio@49008000 {
		compatible = "snps,designware-gpio";
		reg = <0x49008000 0x1000>;
		ngpios = <8>;
		interrupts = <243 3>, <244 3>, <245 3>, <246 3>,
			     <247 3>, <248 3>, <249 3>, <250 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	gpio9: gpio@49009000 {
		compatible = "snps,designware-gpio";
		reg = <0x49009000 0x1000>;
		ngpios = <8>;
		interrupts = <251 3>, <252 3>, <253 3>, <254 3>,
			     <255 3>, <256 3>, <257 3>, <258 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	lpgpio: gpio@42002000 {
		compatible = "snps,designware-gpio";
		reg = <0x42002000 0x1000>;
		ngpios = <8>;
		interrupts = <171 3>, <172 3>, <173 3>, <174 3>,
			     <175 3>, <176 3>, <177 3>, <178 3>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};

	/*
	 * LPI2C0 -- the on-module "BRD_I2C" housekeeping bus (P7_4 SCL_A /
	 * P7_5 SDA_A), carrying OPTIGA (0x30) / RV-3028 (0x52) / TMP112 (0x48) /
	 * EEPROM (0x50).  Minimal Alif LPI2C IP (compatible "alif,lpi2c", driver
	 * zephyr/drivers/i2c/i2c_alif_lpi2c.c, ported from the Apache-2.0 fork;
	 * reg/IRQ from the fork's e1.dtsi -- no clock prop).  A board enables it
	 * (status="okay") and supplies pinctrl_lpi2c0.  vendor-ext, BENCH-UNVERIFIED.
	 */
	lpi2c0: i2c@43009000 {
		compatible = "alif,lpi2c";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0x43009000 0x100>;
		interrupts = <47 3>;
		status = "disabled";
	};

	/*
	 * Synopsys DesignWare MAC (GMAC) -- the Ensemble RMII Ethernet MAC,
	 * backing the UPSTREAM eth_dwmac core via the alp-sdk Alif glue
	 * (drivers/ethernet/eth_dwmac_alif_ensemble.c, compatible "alif,ethernet").
	 * reg/IRQ transcribed from the fork's e1.dtsi (ethernet@48100000, IRQ 148);
	 * the ALIF_ETHERNET_CLK id is synthesized in the UPSTREAM clock encoding
	 * (see alif-ensemble-clocks-ext.h -- the fork's packed value would target
	 * the wrong clock block).
	 *
	 * First bring-up uses a FIXED-LINK PHY: upstream Zephyr v4.4 ships no
	 * snps,designware-mdio driver, so the on-SoM TI DP83825I (RMII, 100/full)
	 * runs unmanaged.  A board enables this node (status="okay") + supplies
	 * pinctrl_eth (the RMII pin group) + a real local-mac-address.
	 *
	 * BENCH-UNVERIFIED + bench follow-up: the RMII 50 MHz ref-clock on the
	 * E1M-AEN801 comes from an on-module oscillator into P11_0 (clock-in mode);
	 * the upstream alif clock driver has NO path to program ETH_CTRL_REG's
	 * ref-clk-source select, so whether silicon needs that bit set before the
	 * MAC sees a clock is unconfirmed (do NOT invent it).
	 */
	ethernet: ethernet@48100000 {
		compatible = "alif,ethernet", "snps,designware-ethernet";
		reg = <0x48100000 0x1000>;
		interrupts = <148 3>;
		clocks = <&clockctrl ALIF_ETHERNET_CLK>;
		local-mac-address = [02 01 56 78 43 21];
		phy-connection-type = "rmii";
		phy-handle = <&eth_phy>;
		/* pinctrl-0 + pinctrl-names supplied by the enabling board overlay
		 * (RMII pin group); omitted here so the disabled node validates. */
		status = "disabled";

		eth_phy: ethernet-phy {
			compatible = "ethernet-phy-fixed-link";
			status = "okay";
			default-speeds = "100BASE Full-Duplex";
		};
	};

	/*
	 * DesignWare DWC_ssi SPI0 (AHB, always-on domain).  Driven by the alp-sdk
	 * vendored DWC-SSI driver (drivers/spi/spi_dw_alif.c, compatible
	 * "alif,dwc-ssi-spi") -- NOT upstream's "snps,designware-spi" spi_dw, which
	 * drives the DW-apb-SSI register layout (wrong CTRLR0 bit positions for this
	 * IP).  The `dwc-ssi` flag selects the DWC_ssi layout.  reg/IRQ from the
	 * fork's e1.dtsi; ALIF_SPI_CLK is a frequency-only dummy (no gate reg).
	 *
	 * BENCH-UNVERIFIED.  Netlist-grounded as the customer-facing edge SPI master
	 * (SoC P5_x); a board enables it (status="okay") + supplies pinctrl + the CS
	 * scheme (HW-SS vs cs-gpios is a bench unknown -- do not hard-code).  spi1
	 * (0x48104000) is the on-SoM CC3501E Wi-Fi link (GPIO-CS), not a free edge
	 * bus -- not declared here.  fifo-depth/max-xfer-size/rx-delay carry safe
	 * overridable binding defaults; override per the Alif TRM.
	 */
	spi0: spi@48103000 {
		compatible = "alif,dwc-ssi-spi";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0x48103000 0x1000>;
		interrupts = <137 3>;
		clocks = <&clockctrl ALIF_SPI_CLK>;
		dwc-ssi;
		fifo-depth = <16>;
		status = "disabled";
	};
};
