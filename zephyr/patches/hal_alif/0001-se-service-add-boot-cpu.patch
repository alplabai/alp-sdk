+/**
+ * @brief Request SE to boot (release) a specific CPU at an address.
+ *
+ * Starts a CPU whose image the SES already loaded (e.g. a TOC entry flagged
+ * "load" without "boot"). The booted core uses this to release the other M55.
+ *
+ * @param cpu_id  Identifier of the CPU to boot (EXTSYS_0 = M55-HP, EXTSYS_1 = M55-HE).
+ * @param address Boot/VTOR address of the target image (0 = the SES-loaded address).
+ * @retval 0 Success.
+ * @retval -EAGAIN Operation timed out. Retry after a delay.
+ * @retval -EBUSY SE is busy. Retry after a delay.
+ * @return Positive error code returned by SE for a failed service request.
+ */
+int se_service_boot_cpu(uint32_t cpu_id, uint32_t address);
