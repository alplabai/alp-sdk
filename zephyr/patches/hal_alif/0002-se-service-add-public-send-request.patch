 /**
+ * @brief Send a fully populated SE service request packet and block for
+ *        the response.
+ *
+ * Generic transport for callers that build their own SE service request
+ * packet (e.g. the CryptoCell AES / SHA / AEAD services in
+ * services_lib_protocol.h) rather than going through a per-service wrapper.
+ * The packet's header.hdr_service_id must be set and every send_*_addr
+ * already run through local_to_global(); on return the packet's resp_*
+ * fields carry the SE response.
+ *
+ * @param packet Pointer to the populated *_svc_t request packet.
+ * @param size   sizeof the concrete *_svc_t.
+ * @retval 0 Success (read the packet's resp_error_code for the SE verdict).
+ * @retval -EINVAL packet is NULL or size is 0.
+ * @retval -EAGAIN Operation timed out. Retry after a delay.
+ * @retval -EBUSY SE communication channel is busy.
+ */
+int se_service_send_request(uint32_t *packet, uint32_t size);
+
+/**
