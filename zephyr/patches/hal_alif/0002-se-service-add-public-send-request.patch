  *
  * @param img_addr Pointer to the image data.
diff --git a/se_services/zephyr/src/se_service.c b/se_services/zephyr/src/se_service.c
--- a/se_services/zephyr/src/se_service.c
+++ b/se_services/zephyr/src/se_service.c
@@ -1388,6 +1388,37 @@
 	return 0;
 }
 
+int se_service_send_request(uint32_t *packet, uint32_t size)
+{
+	int err;
+
+	if (packet == NULL || size == 0u) {
+		return -EINVAL;
+	}
+
+	/* Ensure SE is ready to receive service calls */
+	err = se_service_ensure_ready();
+	if (err) {
+		return err;
+	}
+
+	err = k_mutex_lock(&svc_mutex, K_MSEC(MUTEX_TIMEOUT));
+	if (err) {
+		LOG_ERR("Unable to lock mutex (error = %d)\n", err);
+		return err;
+	}
+
+	/* The caller has fully populated the request packet (header service
+	 * id set + every send_*_addr already run through local_to_global()).
+	 * send_msg_to_se() flushes it to SE-visible memory, sends its global
+	 * address over the MHUv2 pair, blocks for the SE response, and
+	 * invalidates the cache so the packet's resp_* fields are visible.
+	 */
+	err = send_msg_to_se(packet, size, SERVICE_TIMEOUT);
+	k_mutex_unlock(&svc_mutex);
+	return err;
+}
