+def collect_missing_deps(kconf):
+    # Collects, for every symbol whose assigned value did not take effect,
+    # the unsatisfied direct dependencies that blocked it -- the same list
+    # check_assigned_sym_values() renders into its stderr warning, keyed by
+    # prefixed symbol name and returned as data. Written next to the trace
+    # so a consumer can name the blocking dependency.
+    #
+    # Only symbols with a non-empty missing-deps list appear: a promptless
+    # symbol whose deps are all satisfied (assignment still ignored) is
+    # absent, matching the 'no prompt' half already carried by the trace's
+    # visibility field.
+    #
+    # The per-symbol 'did it take' test mirrors check_assigned_sym_values()
+    # exactly; the caller gates this on the same handwritten-input mode, so
+    # the two never diverge.
+
+    result = {}
+    for sym in kconf.unique_defined_syms:
+        if sym.choice:
+            continue
 
+        user_value = sym.user_value
+        if user_value is None:
+            continue
 
+        if sym.type in (BOOL, TRISTATE):
+            user_value = TRI_TO_STR[user_value]
+
+        if user_value == sym.str_value:
+            continue
+
+        mdeps = missing_deps(sym)
+        if not mdeps:
+            continue
+
+        expr_strs = []
+        for expr in mdeps:
+            estr = expr_str(expr)
+            if isinstance(expr, tuple):
+                estr = f"({estr})"
+            expr_strs.append(f"{estr} (={TRI_TO_STR[expr_value(expr)]})")
+
+        result[kconf.config_prefix + sym.name] = expr_strs
+
+    return result
+
+
