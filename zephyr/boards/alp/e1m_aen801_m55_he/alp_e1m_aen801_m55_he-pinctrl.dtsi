 *
 * E1M-AEN801 (Alif Ensemble E8) Cortex-M55-HE carrier pin control.
 *
 * Console: the E1M edge "UART0" maps to Alif UART5 (P3_4 RX_A / P3_5 TX_A) on
 * the AEN module PCB; the Alp E1M-EVK carrier wires its USB-UART console to it.
 * Confirmed against the SoM netlist + metadata/e1m_modules/aen/from-alif.tsv
 * (rows F2 = UART0_TX = UART5_TX_A/P3_5, G2 = UART0_RX = UART5_RX_A/P3_4).
 *
 * GPIO / I2C / SPI / Ethernet pin groups are added alongside their drivers
 * (the alp-sdk Alif peripheral drivers); only the console is wired here.
 */

#include <zephyr/dt-bindings/pinctrl/alif-ensemble-pinctrl.h>

&pinctrl {
	pinctrl_uart5: pinctrl_uart5 {
		group0 {
			pinmux = <PIN_P3_4__UART5_RX_A>;
			input-enable;
		};

		group1 {
			pinmux = <PIN_P3_5__UART5_TX_A>;
		};
	};
};
