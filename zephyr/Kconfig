# ALP SDK Kconfig fragment exposed to Zephyr applications.

config ALP_SDK
	bool "ALP SDK"
	help
	  Enable the ALP SDK on Zephyr.  When set, the SDK's Zephyr
	  backend is compiled and <alp/...> headers are added to the
	  application include path.

if ALP_SDK

# Active SoC selection — drives <alp/soc_caps.h> capability checks.
# When no choice is selected the SDK's runtime validation is permissive
# (default macros = UINT16_MAX); selecting a SoC enables strict
# rejection of configs that exceed its documented hardware caps.
# See docs/adr/0002-error-mechanism.md.

choice
	prompt "Active SoC capability profile (for runtime config validation)"
	default ALP_SOC_NONE
	help
	  Select the SoM's SoC so the SDK can reject runtime configs
	  that exceed its documented caps (e.g. a 16-bit ADC config
	  on a 12-bit SoC).  alp-studio's generated build sets this
	  automatically; hand-written firmware can pick manually.

config ALP_SOC_NONE
	bool "None — capability checks pass through"

config ALP_SOC_ALIF_ENSEMBLE_E3
	bool "Alif Ensemble E3 (alif:ensemble:e3)"

config ALP_SOC_ALIF_ENSEMBLE_E4
	bool "Alif Ensemble E4 (alif:ensemble:e4 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E5
	bool "Alif Ensemble E5 (alif:ensemble:e5 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E6
	bool "Alif Ensemble E6 (alif:ensemble:e6 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E7
	bool "Alif Ensemble E7 (alif:ensemble:e7)"

config ALP_SOC_ALIF_ENSEMBLE_E8
	bool "Alif Ensemble E8 (alif:ensemble:e8 — preliminary)"

config ALP_SOC_RENESAS_RZV2N_N44
	bool "Renesas RZ/V2N R9A09G056N44 (renesas:rzv2n:n44)"

config ALP_SOC_DEEPX_DX_M1
	bool "DEEPX DX-M1 NPU (deepx:dx:m1)"

config ALP_SOC_NXP_IMX9_IMX93
	bool "NXP i.MX 93 (nxp:imx9:imx93 — preliminary)"

endchoice

config ALP_SDK_MAX_I2C_HANDLES
	int "Maximum concurrent alp_i2c_t handles"
	default 4

config ALP_SDK_I2C_SW_FALLBACK
	bool "Software I2C fallback (in-memory loopback)"
	depends on ALP_SDK
	default y if BOARD_NATIVE_SIM || ARCH_POSIX
	default n
	help
	  Compiles a deterministic in-memory I2C loopback backend that
	  registers as a wildcard at priority 0.  write() stashes the
	  last frame keyed by address; read() returns it zero-padded or
	  truncated.  For native_sim build / test only -- production
	  firmware MUST NOT rely on this since no real device is driven.

config ALP_SDK_MAX_SPI_HANDLES
	int "Maximum concurrent alp_spi_t handles"
	default 4

config ALP_SDK_MAX_UART_HANDLES
	int "Maximum concurrent alp_uart_t handles"
	default 4

config ALP_SDK_UART_RX_RINGBUF
	bool "Byte-granular RX ring buffer (LwRB) for <alp/peripheral.h> UART"
	default n
	depends on SERIAL && UART_INTERRUPT_DRIVEN
	help
	  Enable the alp_uart_rx_ringbuf_* helpers in src/zephyr/peripheral_uart.c.
	  When attached to an open alp_uart_t, the SDK registers an
	  interrupt-driven RX callback that drains the controller's FIFO
	  into a caller-supplied LwRB-backed ring; consumer code drains
	  bytes via alp_uart_rx_ringbuf_pop without polling.  Backed by
	  the SDK-internal LwRB stub (vendors/lwrb/) until the v0.4
	  extras-v04 west group flips upstream LwRB in.  When OFF the
	  helpers return NULL / ALP_ERR_NOSUPPORT so apps can link
	  cleanly.

config ALP_SDK_MAX_UART_RX_RINGBUF_HANDLES
	int "Maximum concurrent alp_uart_rx_ringbuf_t handles"
	default 4
	depends on ALP_SDK_UART_RX_RINGBUF
	help
	  Pool size for ring-buffer state structs.  One handle per
	  attached UART port; raise if more than four ports stream RX
	  through the helper concurrently.

config ALP_SDK_MAX_GPIO_HANDLES
	int "Maximum concurrent alp_gpio_t handles"
	default 16

config ALP_SDK_MAX_PWM_HANDLES
	int "Maximum concurrent alp_pwm_t handles"
	default 8

config ALP_SDK_MAX_ADC_HANDLES
	int "Maximum concurrent alp_adc_t handles"
	default 8

config ALP_SDK_MAX_COUNTER_HANDLES
	int "Maximum concurrent alp_counter_t handles"
	default 4

config ALP_SDK_MAX_QENC_HANDLES
	int "Maximum concurrent alp_qenc_t handles"
	default 4

config ALP_SDK_MAX_DAC_HANDLES
	int "Maximum concurrent alp_dac_t handles"
	default 2

config ALP_SDK_MAX_ADC_STREAM_HANDLES
	int "Maximum concurrent alp_adc_stream_t handles"
	default 2
	help
	  Pool size for DMA-backed streaming-ADC handles.  On the V2N
	  family (V2N + V2N-M1) the GD32G553 supervisor MCU exposes
	  exactly two concurrent stream slots (one per DMA controller);
	  raise only if a future backend grows additional slots.

config ALP_SDK_V2N_SUPERVISOR
	bool "V2N supervisor singleton (GD32G553 bridge auto-init)"
	default y if ALP_SOC_RENESAS_RZV2N_N44 && ALP_SDK_CHIP_GD32G553
	depends on ALP_SDK_CHIP_GD32G553
	help
	  Compile src/zephyr/v2n_supervisor.c.  On V2N, the portable
	  alp_pwm_* / alp_adc_* / alp_qenc_* / alp_counter_* / alp_dac_*
	  surfaces dispatch through a singleton GD32G553 driver context
	  instead of resolving Zephyr DT aliases directly -- per the
	  2026-05-12 hardware decision, every E1M-standard analog +
	  counter peripheral on V2N is reached via the GD32 IO MCU
	  bridge.  The singleton lazy-initialises on first peripheral
	  open() under a shared mutex and re-uses the same gd32g553_t
	  context across every backend call.

	  Set CONFIG_ALP_SDK_V2N_SUPERVISOR_SPI_BUS_ID and / or
	  CONFIG_ALP_SDK_V2N_SUPERVISOR_I2C_BUS_ID to the alp_spi /
	  alp_i2c bus ids carrying the bridge transport(s).  At least
	  one must be non-negative for the singleton to come up; when
	  both are set the GD32 driver picks the SPI fast path by
	  default.

	  Off-V2N builds (native_sim, AEN, i.MX 93) leave this off and
	  the backends route through the per-class DT aliases as usual.

if ALP_SDK_V2N_SUPERVISOR

config ALP_SDK_V2N_SUPERVISOR_SPI_BUS_ID
	int "alp_spi bus_id carrying the GD32 SPI fast path (-1 = disabled)"
	default -1
	help
	  alp_spi_open()'s bus_id field.  Resolves to the Renesas RSPI
	  controller on V2N pads P76/P77/P96/P97 -- typically E1M SPI1
	  (per the studio's gd32-io-mcu-map.tsv routing) but board
	  files may override.  Set to -1 to disable the SPI path; the
	  I2C management path alone is fast enough for low-rate
	  telemetry but loses the dedicated-link latency win.

config ALP_SDK_V2N_SUPERVISOR_I2C_BUS_ID
	int "alp_i2c bus_id carrying the GD32 I2C management path (-1 = disabled)"
	default -1
	help
	  alp_i2c_open()'s bus_id field.  Resolves to the Renesas RIIC8
	  controller on V2N pads P07/P06 (BRD_I2C).  Set to -1 to
	  disable the I2C path; the SPI fast path alone covers every
	  bridge call but loses the cold-boot / multi-master probe
	  flexibility.  At least one of SPI_BUS_ID / I2C_BUS_ID MUST
	  be non-negative.

config ALP_SDK_V2N_SUPERVISOR_I2C_ADDR
	hex "GD32G553 firmware 7-bit I2C slave address"
	default 0x70
	range 0x08 0x77
	depends on ALP_SDK_V2N_SUPERVISOR_I2C_BUS_ID >= 0
	help
	  GD32G553_BRIDGE_DEFAULT_I2C_ADDR is 0x70 and the production
	  V2N firmware will ship at that address.  Override only when
	  a specific carrier reconfigures the GD32 firmware to dodge a
	  bus-address collision (the firmware tree's
	  CONFIG_GD32G553_BRIDGE_I2C_ADDR + this Kconfig MUST match).

config ALP_SDK_V2N_SUPERVISOR_SPI_FREQ_HZ
	int "GD32 SPI clock frequency (Hz)"
	default 10000000
	range 1000000 25000000
	depends on ALP_SDK_V2N_SUPERVISOR_SPI_BUS_ID >= 0
	help
	  10 MHz is comfortably below the GD32G553 SPI slave's documented
	  ceiling and gives ~1 us per byte at the wire.  Raise toward
	  25 MHz on boards with short, well-terminated SPI traces.

config ALP_SDK_V2N_SUPERVISOR_I2C_BITRATE_HZ
	int "GD32 I2C management-path bitrate (Hz)"
	default 400000
	depends on ALP_SDK_V2N_SUPERVISOR_I2C_BUS_ID >= 0
	help
	  Standard-mode 100 kHz, fast-mode 400 kHz, or fast-mode+ 1 MHz
	  -- pick the highest the shared BRD_I2C devices all support.

config ALP_SDK_V2N_SUPERVISOR_ACQUIRE_TIMEOUT_MS
	int "Max wait for the supervisor mutex on each bridge op (ms)"
	default 100
	range 1 5000
	help
	  Bounded acquire timeout for the singleton's serialisation
	  mutex.  Each portable alp_pwm_* / alp_adc_* / alp_dac_* /
	  alp_qenc_* / alp_counter_* op on V2N takes this mutex for the
	  duration of the underlying gd32g553_* call (~1 ms typical on
	  SPI, ~5 ms typical on I2C).  When a thread is mid-init against
	  a hung GD32 the bus call inside gd32g553_init() can block much
	  longer; this timeout prevents subsequent acquirers from piling
	  up behind it -- they get ALP_ERR_BUSY back at the portable
	  surface and can retry.  Default 100 ms is well above any
	  steady-state op; raise for builds where the GD32 firmware
	  uses long clock-stretching cycles on I2C.

config ALP_SDK_V2N_POWER_MGMT
	bool "V2N DEEPX rail-management auxiliary"
	default y if ALP_SOC_RENESAS_RZV2N_N44 && ALP_SDK_CHIP_DA9292
	depends on ALP_SDK_CHIP_DA9292
	help
	  Compile src/zephyr/v2n_power_mgmt.c.  Listens on
	  v2n-deepx-pwr-en-req-gpios (Renesas P65) for a rising edge,
	  then brings up the DEEPX 0.75 V rail by programming the
	  DA9292 PMIC CH2 over BRD_I2C (via the supervisor
	  singleton's borrowed I2C handle) + drives
	  v2n-deepx-core-0p75-en-gpios (P64) high once CH2 reaches
	  power-good.

	  Carrier boards that don't have the DEEPX rail (V2N base
	  SoMs without the M1 DEEPX add-on) can leave the DT aliases
	  unpopulated; the module compiles in but returns NOSUPPORT
	  from its init hook.

	  Defaults on for V2N + DA9292 builds; turn off to suppress
	  the IRQ handler if the carrier wires DEEPX from elsewhere.

endif # ALP_SDK_V2N_SUPERVISOR

config ALP_SDK_MAX_I2S_HANDLES
	int "Maximum concurrent alp_i2s_t handles"
	default 2

config ALP_SDK_MAX_CAN_HANDLES
	int "Maximum concurrent alp_can_t handles"
	default 4

config ALP_SDK_MAX_RTC_HANDLES
	int "Maximum concurrent alp_rtc_t handles"
	default 2

config ALP_SDK_MAX_WDT_HANDLES
	int "Maximum concurrent alp_wdt_t handles"
	default 2

# Per-class peripheral wrappers — opt-in so apps that don't use a
# given Zephyr subsystem don't link the wrapper.  Each defaults on
# when its underlying Zephyr driver class is enabled.

config ALP_SDK_PERIPH_PWM
	bool "Enable <alp/pwm.h> wrapper"
	default y if PWM
	depends on PWM
	help
	  Compile src/zephyr/peripheral_pwm.c.  Provides alp_pwm_*
	  on top of Zephyr's pwm_* API.  Resolves channel_id via the
	  alp-pwm0..alp-pwm7 DT aliases.  On V2N (CONFIG_ALP_SOC_RENESAS_RZV2N_N44),
	  the wrapper instead dispatches through the GD32 supervisor
	  singleton (CONFIG_ALP_SDK_V2N_SUPERVISOR) -- the Renesas
	  RZ/V2N has no PWM peripherals per soc_caps; all eight E1M
	  channels reach the GD32 IO-MCU.

config ALP_SDK_PERIPH_DAC
	bool "Enable <alp/adc.h> DAC half (alp_dac_*)"
	default y if DAC || ALP_SDK_V2N_SUPERVISOR
	help
	  Compile src/zephyr/peripheral_dac.c.  Provides alp_dac_*
	  on top of Zephyr's dac_* API (alp-dac0..alp-dac1 DT aliases).
	  On V2N (CONFIG_ALP_SOC_RENESAS_RZV2N_N44), the wrapper
	  dispatches through the GD32 supervisor singleton instead of
	  resolving DT aliases -- the Renesas RZ/V2N has no DAC
	  peripherals.

config ALP_SDK_PERIPH_ADC
	bool "Enable <alp/adc.h> wrapper"
	default y if ADC
	depends on ADC
	help
	  Compile src/zephyr/peripheral_adc.c.  Provides alp_adc_*
	  on top of Zephyr's adc_* API.  Resolves channel_id via the
	  alp-adc0..alp-adc7 DT aliases (each pointing at a node with
	  an io-channels phandle and the standard ADC channel-config
	  properties).

config ALP_SDK_PERIPH_COUNTER
	bool "Enable <alp/counter.h> free-running counter wrapper"
	default y if COUNTER
	depends on COUNTER
	help
	  Compile src/zephyr/peripheral_counter.c.  Provides
	  alp_counter_* on top of Zephyr's counter_* API.  Resolves
	  counter_id via the alp-counter0..alp-counter3 DT aliases.

config ALP_SDK_PERIPH_QENC
	bool "Enable <alp/counter.h> quadrature-decoder wrapper"
	default y if SENSOR
	depends on SENSOR
	help
	  Compile src/zephyr/peripheral_qenc.c.  Provides alp_qenc_*
	  on top of Zephyr's sensor_* API (SENSOR_CHAN_ROTATION).
	  Resolves encoder_id via alp-qenc0..alp-qenc3 DT aliases.

config ALP_SDK_PERIPH_I2S
	bool "Enable <alp/i2s.h> wrapper"
	default y if I2S
	depends on I2S
	help
	  Compile src/zephyr/peripheral_i2s.c.  Provides alp_i2s_*
	  on top of Zephyr's i2s_* API with a 2-block ping-pong
	  memory slab.

config ALP_SDK_PERIPH_CAN
	bool "Enable <alp/can.h> wrapper (classic CAN + CAN-FD)"
	default y if CAN
	depends on CAN
	help
	  Compile src/zephyr/peripheral_can.c.  Provides alp_can_*
	  on top of Zephyr's can_* API.  CAN-FD only when
	  CONFIG_CAN_FD_MODE=y.

config ALP_SDK_PERIPH_RTC
	bool "Enable <alp/rtc.h> wrapper"
	default y if RTC
	depends on RTC
	help
	  Compile src/zephyr/peripheral_rtc.c.  Provides alp_rtc_*
	  on top of Zephyr's rtc_* API.

config ALP_SDK_PERIPH_WDT
	bool "Enable <alp/wdt.h> wrapper"
	default y if WATCHDOG
	depends on WATCHDOG
	help
	  Compile src/zephyr/peripheral_wdt.c.  Provides alp_wdt_*
	  on top of Zephyr's wdt_* API.

config ALP_SDK_PERIPH_TMU
	bool "Enable <alp/tmu.h> wrapper (CORDIC math accelerator surface)"
	default y
	help
	  Compile src/zephyr/peripheral_tmu.c.  Provides alp_tmu_sin /
	  cos / tan / atan / atan2 / sqrt / log / exp / sinh / cosh /
	  tanh / hypot on top of either the V2N supervisor's GD32G5
	  TMU (CORDIC) accelerator (when CONFIG_ALP_SDK_V2N_SUPERVISOR=y)
	  or libm directly (every other SoM).  The customer-facing
	  header is SoM-agnostic; the V2N dispatch is internal.

config ALP_SDK_DSP
	bool "Enable <alp/dsp.h> standalone DSP-chain API"
	default n
	help
	  Compile src/common/dsp_chain.c.  Provides the standalone
	  alp_dsp_chain_* surface for in-RAM FIR / IIR / window /
	  FFT processing against int16 mV-scale buffers.  Uses
	  CMSIS-DSP when ALP_HAS_CMSIS_DSP=1; otherwise falls back
	  to a portable-C math kernel set (naive FIR convolution,
	  direct-form-1 biquad cascade, radix-2 Cooley-Tukey FFT).

	  Static cost: ~30 KB for the chain pool (two concurrent
	  chains sized to ALP_DSP_MAX_FIR_TAPS / IIR_SECTIONS /
	  FFT_POINTS).  Pulls in math.h transcendentals (sinf, cosf,
	  sqrtf, lrintf).  Off by default to keep tight firmware
	  images lean.  The wave-2 bridge surfaces
	  alp_adc_filter_t / alp_adc_spectrum_t (in <alp/adc.h>,
	  landing v0.5.x) reuse the same chain machinery.

config ALP_SDK_POWER
	bool "Enable <alp/power.h> system-power-mode surface"
	default y
	help
	  Compile src/zephyr/power_zephyr.c.  Provides the portable
	  alp_power_open / configure_wake_source / request_sleep /
	  close surface that backends route either through Zephyr's
	  pm_policy_* primitives (off-V2N) or through the GD32G553
	  supervisor's CMD_POWER_MODE_SET opcode (0x28) on V2N.

	  v0.5 ships the surface with NOSUPPORT-with-INVAL-pre-checks
	  stubs so customers can wire portable sleep code today; the
	  per-backend HAL bodies (Zephyr pm_state tables on AEN +
	  the GD32 firmware-side wake-handler + the supervisor
	  re-init state machine) land in follow-up commits.

config ALP_SDK_GPU2D
	bool "Enable <alp/gpu2d.h> 2D graphics accelerator surface"
	default y
	help
	  Compile src/zephyr/gpu2d_zephyr.c.  Provides the portable
	  alp_gpu2d_open / fill_rect / blit / blend / close surface
	  that maps to vendor 2D-accelerator HALs (Alif D/AVE 2D on
	  Ensemble, planned Vivante GC328 on i.MX 93).

	  v0.5 ships NOSUPPORT-with-INVAL-pre-checks stubs so
	  customers can write portable 2D-graphics code today; the
	  per-vendor HAL bodies land once their packs stabilise as
	  Zephyr modules.

	  Surfaces the headline gap the Alif Ensemble feature audit
	  (internal AEN feature audit) called out: customers
	  migrating from V2N to AEN otherwise silently lose 2D
	  acceleration because Zephyr has no portable `gpu` / `2d`
	  driver class.

# IoT (Wi-Fi station + MQTT) — v0.2 deliverable.  When OFF the
# wrapper still compiles and honours the v0.1 NULL-with-NOSUPPORT
# contract so apps can link cleanly against <alp/iot.h>.

config ALP_SDK_IOT_WIFI
	bool "Real Wi-Fi station via Zephyr wifi_mgmt"
	default y if WIFI && NET_MGMT
	depends on WIFI && NET_MGMT
	help
	  Enable the real wifi_mgmt-backed alp_wifi_* implementation.
	  Requires CONFIG_WIFI=y and a wifi-management subsystem (e.g.
	  CONFIG_WIFI_NM_WPA_SUPPLICANT=y on AEN-Zephyr).  When OFF
	  alp_wifi_open() returns NULL with alp_last_error() =
	  ALP_ERR_NOSUPPORT.

config ALP_SDK_IOT_MQTT
	bool "Real MQTT client via Zephyr mqtt_client"
	default y if MQTT_LIB
	depends on MQTT_LIB && NET_TCP
	help
	  Enable the real mqtt_client-backed alp_mqtt_* implementation.
	  Requires CONFIG_MQTT_LIB=y + CONFIG_NET_TCP=y.  When OFF
	  alp_mqtt_open() returns NULL with alp_last_error() =
	  ALP_ERR_NOSUPPORT.

config ALP_SDK_MAX_WIFI_HANDLES
	int "Maximum concurrent alp_wifi_t handles"
	default 1
	help
	  Wi-Fi station is single-instance on every E1M-conformant SoM
	  (one radio per module).  Override only if you intentionally
	  hold multiple handles in flight (e.g. open + cleanup overlap).

config ALP_SDK_MAX_MQTT_HANDLES
	int "Maximum concurrent alp_mqtt_t handles"
	default 2
	help
	  Number of concurrent MQTT clients the wrapper can keep open.
	  Each handle reserves CONFIG_ALP_SDK_MQTT_BUF_SIZE * 3 bytes
	  for its rx / tx / topic scratch.

config ALP_SDK_MQTT_BUF_SIZE
	int "Per-client MQTT rx / tx scratch buffer size"
	default 256
	help
	  Allocated three times per alp_mqtt_t (rx, tx, topic).  Sized
	  for v0.2's JSON-payload reference apps; raise for larger
	  publish bodies or longer topic strings.

# Audio (PDM input + I2S output) -- v0.2 deliverable.  When OFF the
# wrapper still compiles and honours the v0.1 NULL-with-NOSUPPORT
# contract.

config ALP_SDK_AUDIO_IN
	bool "Real PDM input via Zephyr audio_dmic"
	default y if AUDIO_DMIC
	depends on AUDIO_DMIC
	help
	  Enable the real audio_dmic-backed alp_audio_in_* implementation.
	  Resolves the studio-supplied peripheral_id via the alp-pdm0 /
	  alp-pdm1 DT aliases.  Includes the ALP DSP chain (DC-block in
	  v0.2; AGC + resample in v0.3).  When OFF alp_audio_in_open()
	  returns NULL with alp_last_error() = ALP_ERR_NOSUPPORT.

config ALP_SDK_AUDIO_OUT
	bool "Real I2S output via alp_i2s_*"
	default y if I2S
	depends on I2S
	help
	  Enable the real alp_i2s_*-backed alp_audio_out_* implementation.
	  Delegates straight to the v0.2 <alp/i2s.h> wrapper plus a
	  software volume scale.  Reuses the alp_i2s_t handle pool.
	  When OFF alp_audio_out_open() returns NULL with NOSUPPORT.

config ALP_SDK_MAX_AUDIO_IN_HANDLES
	int "Maximum concurrent alp_audio_in_t handles"
	default 1
	help
	  PDM input is single-stream on most E1M-conformant SoMs;
	  override only if the SoC genuinely exposes multiple PDM
	  controllers and the app holds them concurrently.

config ALP_SDK_MAX_AUDIO_OUT_HANDLES
	int "Maximum concurrent alp_audio_out_t handles"
	default 1

config ALP_SDK_AUDIO_BLOCK_BYTES
	int "Maximum block size for an alp_audio_in_t (bytes)"
	default 4096
	help
	  Per-handle slab buffer is sized at this * the slab block
	  count, statically, so the wrapper avoids k_malloc.  4096 B
	  fits 1024 mono S16 frames or 512 stereo S16 frames -- ~64
	  ms at 16 kHz mono, comfortably above the typical 5-10 ms
	  block latency.

config ALP_SDK_AUDIO_IN_SLAB_BLOCKS
	int "DMA blocks per audio_in slab (>= 2)"
	default 4
	help
	  Two is the minimum (one in-flight to the driver, one drained
	  by the caller).  Four is a comfortable default; raise for
	  apps that take longer than the block period to drain.

# Inference (<alp/inference.h>) -- v0.2 deliverable, the wrapper
# always compiles and falls back to ALP_ERR_NOSUPPORT when no
# backend is enabled.

config ALP_SDK_INFERENCE_TFLM
	bool "TensorFlow Lite Micro backend for <alp/inference.h>"
	default n
	depends on TENSORFLOW_LITE_MICRO && CPP
	help
	  Enable the TFLM-backed executor (src/zephyr/inference_tflm.cpp).
	  Wraps tflite::MicroInterpreter + tflite::MicroMutableOpResolver
	  for both CPU (reference kernels) and Ethos-U
	  (CONFIG_ALP_SDK_INFERENCE_ETHOS_U) backends.  Pulls in TFLM via
	  the upstream tflite-micro Zephyr module (see west.yml's
	  name-allowlist).  When OFF, alp_inference_open() returns NULL
	  with ALP_ERR_NOSUPPORT regardless of the backend selector.

config ALP_SDK_INFERENCE_DRPAI
	bool "Renesas DRP-AI3 backend for <alp/inference.h>"
	default n
	depends on SOC_SERIES_RZV2N || SOC_FAMILY_RENESAS_RZ
	help
	  Wires the alp_inference_drpai_* hooks (src/zephyr/inference_drpai.c)
	  into the dispatcher.  Real impl bridges Renesas's DRP-AI
	  translator runtime; v0.3 ships the dispatch routing only,
	  v0.4 fills the bodies once the vendor pack lands in CI.
	  When the v0.4 work completes this defaults y on V2N targets.

config ALP_SDK_INFERENCE_ETHOS_U
	bool "Wire Arm Ethos-U op resolver (Vela-compiled models)"
	default y if ALP_SDK_INFERENCE_TFLM && (SOC_SERIES_ENSEMBLE_E7 || ALP_SOC_NXP_IMX9_IMX93)
	depends on ALP_SDK_INFERENCE_TFLM
	help
	  Adds the AddEthosU() registration so Vela-compiled .tflite
	  files can dispatch their custom ETHOS-U operator to the NPU.
	  Covers Ethos-U55 on Alif Ensemble (AEN family) and Ethos-U65 on
	  NXP i.MX 93's Cortex-M33.  Variant selection happens via
	  ALP_SDK_INFERENCE_ETHOS_U_N93 (i.MX 93) -- the SDK source path
	  is identical between U55 and U65; only the Vela compilation
	  target + Arm driver build differ.  Off-target builds (CPU-only)
	  must turn this off.

config ALP_SDK_INFERENCE_ETHOS_U_N93
	bool "Target the i.MX 93 Ethos-U65 (vs the AEN family's Ethos-U55)"
	default y if ALP_SOC_NXP_IMX9_IMX93
	depends on ALP_SDK_INFERENCE_ETHOS_U
	help
	  Compile the i.MX 93 + Ethos-U65 per-variant config layer
	  (src/zephyr/inference_ethosu_n93.c).  Anchors the v0.4 NPU
	  attach hook + variant-name helper that downstream code uses
	  to keep Vela target consistency.  Models compiled for U55
	  do not run on U65 and vice versa; this flag plus the SoC
	  choice above tells the build which Vela target the app
	  expects.

# Per-variant Ethos-U silicon switches.  Emitted by the orchestrator
# (scripts/alp_orchestrate.py) from the SoM preset's
# `inference.npu_population[]` block + the SoC JSON's
# `capabilities.ethos_u{55,65,85}_count` fallback -- the customer
# never picks one in board.yaml.  On SoMs that carry more than one
# Ethos-U variant (E4 / E6 / E8 = U55 pair + one U85) both switches
# are =y so the upstream Arm Ethos-U driver compiles in the matching
# kernel sets and the runtime dispatcher logs which variant ran the
# model.  Orthogonal to ALP_SDK_INFERENCE_ETHOS_U_N93 above, which is
# the NXP-side PHY / driver-shim selector (coexists on i.MX 93).

config ALP_SDK_INFERENCE_ETHOS_U_U55
	bool "Compile against Arm Ethos-U55 NPU kernels"
	depends on ALP_SDK_INFERENCE_ETHOS_U
	help
	  Selected by the orchestrator on SoMs whose silicon carries one
	  or more Ethos-U55 instances (AEN family E3 / E4 / E5 / E6 / E7 /
	  E8 all carry a pair; i.MX 93 does not).  The upstream Arm Ethos-U
	  driver library is compiled with the U55-256 accelerator config so
	  Vela-compiled U55 models dispatch.  Vela target on the build host
	  must match: `--accelerator-config ethos-u55-256`.

config ALP_SDK_INFERENCE_ETHOS_U_U65
	bool "Compile against Arm Ethos-U65 NPU kernels"
	depends on ALP_SDK_INFERENCE_ETHOS_U
	help
	  Selected by the orchestrator on SoMs whose silicon carries one
	  or more Ethos-U65 instances (NXP i.MX 93 today).  The upstream
	  Arm Ethos-U driver library is compiled with the U65-256
	  accelerator config.  Vela target: `--accelerator-config
	  ethos-u65-256`.  Coexists with ALP_SDK_INFERENCE_ETHOS_U_N93 (the
	  NXP-side PHY / driver-shim wiring).

config ALP_SDK_INFERENCE_ETHOS_U_U85
	bool "Compile against Arm Ethos-U85 NPU kernels (Generative AI)"
	depends on ALP_SDK_INFERENCE_ETHOS_U
	help
	  Selected by the orchestrator on SoMs whose silicon carries one
	  or more Ethos-U85 instances (Alif AEN E4 / E6 / E8; the U85 is
	  paired with a Hyper-Generative subsystem and adds Transformer
	  support on top of CNN / RNN).  The upstream Arm Ethos-U driver
	  library is compiled with U85's TensorOptimized kernels + larger
	  MAC array.  On U85-carrying SoMs both this AND
	  ALP_SDK_INFERENCE_ETHOS_U_U55 are =y -- the two U55s alongside
	  the U85 still need to run U55-compiled models.  Vela target:
	  `--accelerator-config ethos-u85-256`.

# Per-CPU-class TFLM kernel selectors.  Emitted by the orchestrator
# (scripts/alp_orchestrate.py) from the SoC JSON's
# `cores[<core_id>].vector_extension` for the slice being built --
# the customer never picks one in board.yaml.  TFLM upstream ships
# three kernel implementations (NEON / Helium MVE / scalar reference)
# and the build picks the one matching the target CPU so we don't
# pay the cost of compiling the wrong one.  Exactly one of these is
# expected to be =y on any given slice.

config ALP_SDK_INFERENCE_TFLM_NEON
	bool "TFLM NEON-accelerated kernels (Cortex-A cluster)"
	depends on ALP_SDK_INFERENCE_TFLM
	help
	  Emitted by the orchestrator for cortex-a* slices (A32 / A55).
	  Selects upstream TFLM's NEON kernel implementation -- 64/128-bit
	  vector intrinsics tuned for ARMv8-A.  Applies to the AEN family's
	  A32 cluster (E5 / E6 / E7 / E8), the V2N family's A55 cluster, and
	  the i.MX 93's A55 cluster.

config ALP_SDK_INFERENCE_TFLM_HELIUM
	bool "TFLM Helium MVE-I kernels (Cortex-M55)"
	depends on ALP_SDK_INFERENCE_TFLM
	help
	  Emitted by the orchestrator for cortex-m55 slices (ARMv8.1-M
	  Helium vector extension).  Selects upstream TFLM's Helium kernel
	  implementation -- the M55's MVE-I lane operations are roughly
	  2-4x faster on int8 convolutions than the reference kernels.
	  Applies to every M55_HP / M55_HE slice across the AEN family.

config ALP_SDK_INFERENCE_TFLM_REF
	bool "TFLM scalar reference kernels (baseline Cortex-M)"
	depends on ALP_SDK_INFERENCE_TFLM
	help
	  Emitted by the orchestrator for baseline Cortex-M slices without
	  Helium / DSP extensions (the V2N's m33_sm system-manager core,
	  the i.MX 93's m33 real-time core).  Selects upstream TFLM's
	  scalar reference kernel implementation -- the floor that always
	  works.  Slower than NEON / Helium, but the right answer when the
	  target core has neither.

# BLE (<alp/ble.h>) -- v0.3 deliverable.  Same NOSUPPORT contract
# when CONFIG_BT is off so apps can link cleanly under native_sim.

config ALP_SDK_BLE
	bool "Real Bluetooth host stack via Zephyr bt"
	default y if BT
	depends on BT
	help
	  Enables the wifi_mgmt + GATT-server peripheral path and the
	  scan + connect central path on top of Zephyr's `bt` host
	  stack.  Requires CONFIG_BT=y plus CONFIG_BT_PERIPHERAL=y
	  and/or CONFIG_BT_CENTRAL=y for the matching role.  When OFF
	  alp_ble_open() returns NULL with ALP_ERR_NOSUPPORT.

config ALP_SDK_SECURITY
	bool "Real MbedTLS PSA Crypto for <alp/security.h>"
	default y if MBEDTLS_PSA_CRYPTO_C
	depends on MBEDTLS && MBEDTLS_PSA_CRYPTO_C
	help
	  Wires the alp_hash_* / alp_aead_* / alp_random_bytes
	  surface onto MbedTLS's PSA Crypto API.  PSA picks the
	  active SoC's hardware accelerator transparently when the
	  vendor's driver layer registers it (Alif Ensemble crypto
	  subsystem, Renesas RZ/V2N RSIP).  When OFF the wrapper
	  falls back to NULL / NOSUPPORT.

config ALP_SDK_SECURITY_V2N_TRNG_ENTROPY
	bool "Feed the GD32 supervisor's TRNG into MbedTLS entropy on V2N"
	default y if ALP_SDK_V2N_SUPERVISOR && ALP_SDK_SECURITY
	depends on ALP_SDK_V2N_SUPERVISOR && ALP_SDK_SECURITY
	help
	  Compile the mbedtls_hardware_poll() implementation in
	  src/zephyr/security_zephyr.c that drains true-random bytes
	  from the GD32G553 supervisor's NIST SP800-90B pre-certified
	  TRNG.  The mbedtls profile (metadata/library-profiles/mbedtls/
	  mbedtls_config.h) sets MBEDTLS_NO_PLATFORM_ENTROPY, so
	  mbedtls's entropy module asks the SDK to supply the platform
	  entropy poll callback; this option provides that symbol on
	  V2N.  The portable alp_random_bytes() transparently benefits
	  -- PSA Crypto's DRBG seeds from this source the first time
	  it's drawn from.  No effect on alp_random_bytes's public
	  contract (still ALP_OK / ALP_ERR_NOT_READY / ALP_ERR_IO /
	  ALP_ERR_INVAL); the GD32 dependency is invisible to apps.
	  Off-V2N builds leave this OFF -- mbedtls picks whatever
	  hardware_poll the active vendor's HAL registered, or falls
	  back to ALP_ERR_IO on alp_random_bytes if nothing is wired.

config ALP_SDK_MPROC
	bool "Real multi-processor IPC for <alp/mproc.h>"
	default y if MBOX
	depends on MBOX
	help
	  Wires the alp_mbox_* / alp_shmem_* / alp_hwsem_*
	  primitives onto the Zephyr backend.  Per-surface state:

	    - mbox: Zephyr MBOX driver class (v0.4).  Alif's MHU is
	      registered as a Zephyr mbox device on AEN; the wrapper
	      resolves alp_mbox_config.channel through the alp-mboxN
	      DT aliases.
	    - shmem: DT-anchored carve-outs (v0.7, commit 2e9deec).
	      alp_shmem_open(name) resolves "alp_shmem0".."alp_shmemN"
	      strictly against the alp-shmemN aliases; boards that
	      don't declare the aliases get NOT_READY at open.
	    - hwsem: intra-core k_sem fallback (v0.7, commit 877fa29)
	      indexed by integer hwsem_id, sized by
	      ALP_SDK_MPROC_HWSEM_COUNT.  Cross-core / per-SoC
	      HWSEM-block wiring (AEN HWSEM, ST HSEM, etc.) is
	      tracked separately.

	  Yocto + GD32 backends still return NULL / NOSUPPORT for
	  shmem + hwsem; Yocto carries the mbox shim only.

config ALP_SDK_MPROC_NANOPB_FRAMING
	bool "Frame alp_mbox_send payloads through the IPC envelope"
	default n
	help
	  Wraps every alp_mbox_send payload in the IPC envelope
	  declared in src/common/proto/alp_mproc_frame.h before
	  handing it to the Zephyr mbox driver, and unwraps inbound
	  frames before dispatching alp_mbox_msg_cb_t.  The placeholder
	  binary format is intentionally NOT compatible with the v0.4-
	  final protobuf wire generated by nanopb against
	  metadata/protos/alp_mproc.proto -- this option exists so the
	  framing code path is exercised before the nanopb generator
	  pack lands.  Both ends of an IPC channel must agree on the
	  flag value; mixing framed + raw firmwares is a wire-protocol
	  break.

	  Has runtime effect only when ALP_SDK_MPROC is also on (the
	  framing code in mproc_zephyr.c is gated on both flags).
	  Compile-tested standalone so the encode/decode helpers can
	  be exercised under native_sim without a real mbox device.

config ALP_SDK_MPROC_FRAME_MAX_BYTES
	int "Maximum framed envelope size (bytes)"
	default 512
	depends on ALP_SDK_MPROC_NANOPB_FRAMING
	help
	  Static scratch buffer reserved per alp_mbox_t for the framed
	  payload.  Header overhead is ALP_MPROC_FRAME_HEADER_BYTES (12)
	  so the usable payload ceiling is this value minus 12 bytes.
	  Raise for larger RPC requests / responses.

config ALP_SDK_RPC
	bool "Framed RPC over OpenAMP / RPMsg for <alp/rpc.h>"
	default y if IPC_SERVICE_BACKEND_RPMSG
	depends on IPC_SERVICE_BACKEND_RPMSG && OPENAMP
	help
	  Wires the alp_rpc_open / alp_rpc_subscribe / alp_rpc_send /
	  alp_rpc_call surface onto Zephyr's subsys/ipc/ipc_service
	  with the rpmsg backend.  The orchestrator (scripts/alp_orchestrate.py)
	  generates <alp/system_ipc.h> + a per-board DT overlay under
	  zephyr/boards/<sku>_<core>.overlay that wires up the carve-out,
	  mailbox channel, and chosen { zephyr,ipc } node so customer
	  code calls alp_rpc_open(&(alp_rpc_config_t){...}) without
	  knowing the address layout.

	  Off-builds compile rpc_zephyr.c to NOSUPPORT stubs so apps
	  that don't opt in still link cleanly.  Heterogeneous projects
	  (board.yaml v2 with an ipc[] block) flip this on automatically
	  via the orchestrator-emitted per-core alp.conf.

config ALP_SDK_RPC_MAX_CHANNELS
	int "Maximum concurrent alp_rpc_channel_t handles"
	default 4
	depends on ALP_SDK_RPC
	help
	  Each handle reserves one ipc_service endpoint + a method-
	  subscribe table.  4 is plenty for the typical "control +
	  telemetry" channel pair an M-class slice opens; raise for
	  apps that segment more aggressively.

config ALP_SDK_RPC_SUBS_PER_CHANNEL
	int "Maximum alp_rpc_subscribe registrations per channel"
	default 8
	depends on ALP_SDK_RPC
	help
	  v0.6 dispatch table cap.  Subscribe attempts beyond this
	  return ALP_ERR_NOMEM with a clear log line so the customer
	  knows to raise the cap.  8 is sized for typical sensor /
	  command / event topic counts in a single channel; bigger
	  apps should split across more channels.

config ALP_SDK_RPC_TX_FRAME_MAX
	int "Max alp_rpc_send / alp_rpc_call frame size (bytes)"
	default 1024
	depends on ALP_SDK_RPC
	help
	  Per-channel TX scratch buffer.  Frame = method header (<=32 B
	  with NUL) + opaque payload.  1024 fits short sensor records,
	  small JSON snippets, and the v0.7 protobuf-framing upgrade
	  comfortably.  Sends that don't fit return ALP_ERR_NOMEM.

config ALP_SDK_USB
	bool "Real USB device stack for <alp/usb.h>"
	default y if USB_DEVICE_STACK
	depends on USB_DEVICE_STACK
	help
	  Wires alp_usb_device_open / enable / disable on top of
	  Zephyr's USB device stack.  Per-class endpoint
	  read/write (CDC-ACM, MSC, HID) lands in v0.3.x once
	  the per-class wrappers are wired.  Host role lands
	  alongside the SoC's USB-host controller driver.

config ALP_SDK_MAX_USB_DEV_HANDLES
	int "Maximum concurrent alp_usb_dev_t handles"
	default 1
	help
	  USB device role is single-instance on every E1M-conformant
	  SoM (one USB controller per module).

config ALP_SDK_MAX_SHMEM_HANDLES
	int "Maximum concurrent alp_shmem_t handles"
	default 2

config ALP_SDK_MAX_MBOX_HANDLES
	int "Maximum concurrent alp_mbox_t handles"
	default 4

config ALP_SDK_MAX_HWSEM_HANDLES
	int "Maximum concurrent alp_hwsem_t handles"
	default 4

config ALP_SDK_MPROC_HWSEM_COUNT
	int "Number of k_sem slots backing alp_hwsem_open (intra-core fallback)"
	default 16
	depends on ALP_SDK_MPROC
	help
	  Pool size for the k_sem-backed intra-core hwsem fallback in the
	  Zephyr mproc backend.  Each alp_hwsem_open(id) maps id -> one of
	  these k_sems (count=1, mutex semantics).  Bump if a SoM needs
	  more than 16 hwsem IDs intra-core.  Has no effect on real-HWSEM
	  paths (AEN HWSEM block, ST HSEM, etc.) which are per-SoC.

config ALP_SDK_MAX_HASH_HANDLES
	int "Maximum concurrent alp_hash_t handles"
	default 4

config ALP_SDK_MAX_AEAD_HANDLES
	int "Maximum concurrent alp_aead_t handles"
	default 4

config ALP_SDK_BLE_MAX_CONNS
	int "Maximum concurrent alp_ble_conn_t handles"
	default 2
	help
	  Mirrors CONFIG_BT_MAX_CONN; raise both together if your app
	  holds more than two simultaneous connections.

config ALP_SDK_MAX_INFERENCE_HANDLES
	int "Maximum concurrent alp_inference_t handles"
	default 2
	help
	  Each handle reserves one tensor arena (default 128 KiB
	  static; caller-supplied via cfg.arena overrides) so the
	  default 2 is intentionally low.  Raise only if the app
	  genuinely runs multiple models at once.

config ALP_SDK_HAS_LVGL
	bool "Build <alp/gui.h> against LVGL"
	default y if LVGL
	default n
	help
	  Pulls upstream LVGL into the alp_gui_lvgl_attach() path.
	  Requires CONFIG_LVGL=y.

# Note: LwRB + nanopb were previously gated by CONFIG_ALP_SDK_USE_*
# flags here.  Removed in the v0.3 cleanup -- both are SDK-internal
# libraries (LwRB for audio DMA staging, nanopb for mproc IPC frame
# serialisation) and consumers don't need to enable them.  When the
# v0.4 audio + mproc paths land, the SDK code uses them
# unconditionally; the west.yml pins go in alongside.  See
# vendors/lwrb/ and vendors/nanopb/ for the runtime contract.

config ALP_SDK_HW_INFO
	bool "Runtime hardware-info reader (EEPROM + BOARD_ID ADC)"
	default y
	help
	  Compile src/zephyr/hw_info_zephyr.c.  Provides the
	  alp_hw_info_read() + alp_hw_info_assert_matches_build()
	  surface backed by the SoM on-module 24C128 EEPROM and the
	  per-board BOARD_ID ADC + resistor divider.  The EEPROM-side
	  half is wired when CONFIG_ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID
	  is set to a non-negative bus id; the BOARD_ID ADC cross-check
	  remains TODO pending the per-family generated header.

config ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID
	int "I2C bus id for the on-module EEPROM (< 0 = disabled)"
	default -1
	depends on ALP_SDK_HW_INFO && I2C && ALP_SDK_CHIP_EEPROM_24C128
	help
	  Per-board: the bus id (matches alp_i2c_open's bus_id field)
	  carrying the SoM's on-module 24C128 EEPROM.  On V2N this is
	  the E1M I2C0 bus (Renesas RIIC0 on P31/P30); on AEN it's the
	  Alif LPI2C bus.  Set to -1 to disable the EEPROM read path --
	  alp_hw_info_read() returns ALP_ERR_NOSUPPORT.

config ALP_SDK_HW_INFO_EEPROM_ADDR_7BIT
	hex "7-bit I2C address of the on-module EEPROM"
	default 0x50
	range 0x50 0x57
	depends on ALP_SDK_HW_INFO && ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID >= 0
	help
	  EEPROM I2C address strap (24C128 family supports 0x50..0x57).

config ALP_SDK_HW_INFO_EEPROM_OFFSET
	int "Manifest offset within the EEPROM (bytes)"
	default 0
	depends on ALP_SDK_HW_INFO && ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID >= 0
	help
	  Byte offset of the alp_hw_info_eeprom_t struct in EEPROM
	  storage.  Default 0 -- production-test flow places the
	  manifest at offset 0 per the design note in
	  metadata/e1m_modules/<family>/hw-revisions.yaml.

config ALP_SDK_HW_INFO_EEPROM_I2C_BITRATE_HZ
	int "I2C bitrate for the EEPROM read (Hz)"
	default 400000
	depends on ALP_SDK_HW_INFO && ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID >= 0
	help
	  Standard-mode 100 kHz, fast-mode 400 kHz, or fast-mode+ 1 MHz
	  -- choose the highest the on-bus devices all support.

# Chip drivers.  Each is opt-in so projects only pay for the
# silicon they actually use.  Symbols use the chip's natural prefix
# (lsm6dso_*, ssd1306_*, bme280_*, …) — no alp_ prefix on chip
# drivers.  The button_led / pdm_mic helpers are the exception
# (generic block utilities, alp_-prefixed).

menu "ALP SDK chip drivers"

