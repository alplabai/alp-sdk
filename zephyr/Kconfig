config ALP_SDK_CHIP_UBLOX_MAX_M10S
	bool "u-blox MAX-M10S small-footprint multi-GNSS receiver"
	depends on SERIAL
	help
	  Compile chips/ublox_max_m10s/ublox_max_m10s.c.  Same NMEA
	  shape as NEO-M9N; smaller power envelope.

config ALP_SDK_CHIP_ATGM336H
	bool "AllyStar ATGM336H GPS / BeiDou receiver"
	depends on SERIAL
	help
	  Compile chips/atgm336h/atgm336h.c.  Cost-optimised GNSS
	  module; same NMEA shape as the u-blox drivers.

config ALP_SDK_CHIP_ATECC608B
	bool "Microchip ATECC608B EC P-256 + AES secure element"
	depends on I2C
	help
	  Compile chips/atecc608b/atecc608b.c.  Wake / idle / sleep
	  command shell.  Full ATCA crypto via the CryptoAuthLib
	  import (TBD).

