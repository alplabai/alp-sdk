# hal_alif (drivers/CMakeLists.txt) gates its analog VREF library
# (drivers/analog -> analog_ctrl.c) on CONFIG_USE_ALIF_HAL_ANALOG via
# add_subdirectory_ifdef, but -- exactly like USE_ALIF_HAL_UTIMER above --
# hal_alif never DEFINES the symbol.  On upstream Zephyr v4.4 + hal_alif (no
# fork) nothing defines it, so drivers/analog never builds and the ADC driver's
# enable_adc_ref_voltage() / adc_vref_cnt extern would not link.  alp-sdk, as the
# integration layer, defines it here so ADC_ALIF can select it to pull in
# modules/hal/alif drivers/analog (publishes analog_ctrl.h on the include path +
# compiles analog_ctrl.c with the adc_vref_cnt/dac*_vref_cnt counters).
config USE_ALIF_HAL_ANALOG
	bool
	help
	  Pull in the hal_alif analog VREF library (drivers/analog).  Selected by
	  ADC_ALIF (and any future DAC/comparator driver); not user-facing.

config ADC_ALIF
	bool "Alif Ensemble ADC (ADR 0017 Tier-2 INTERIM -> retire onto fork, BENCH-UNVERIFIED)"
	default y
	depends on ADC
	depends on DT_HAS_ALIF_ADC_ENABLED
	select PINCTRL
	select USE_ALIF_HAL_ANALOG
	help
	  Alif Ensemble ADC class driver (12-bit x3 + 24-bit x1), vendored VERBATIM
	  from the Apache-2.0 zephyr_alif fork (drivers/adc/adc_alif.c).  Binds the
	  fork-native compatible "alif,adc" (no upstream Zephyr Alif ADC exists, so
	  no collision).  Built over the hal_alif analog_ctrl VREF helper library
	  (USE_ALIF_HAL_ANALOG pulls in modules/hal/alif drivers/analog).  Single-shot
	  + continuous conversion, single/multi-channel scan, comparator, and PGA in
	  differential mode.  Not silicon-validated.

	  ADR 0017 Tier-2 (a genuine fork-driver copy -- hal_alif ships no ADC class
