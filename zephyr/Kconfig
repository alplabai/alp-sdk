config ALP_SDK_CHIP_CC3501E
	bool "TI CC3501E Wi-Fi 6 + BLE 5.4 coprocessor (E1M-AEN family)"
	depends on SPI && GPIO
	help
	  Compile chips/cc3501e/cc3501e.c.  Alif-side host driver
	  that talks to the on-module CC3501E firmware over the
	  inter-chip SPI1 bus.  The firmware itself is a separate
	  project at alplabai/cc3501e-firmware (per ADR 0005);
	  this driver only knows the wire protocol declared in
	  <alp/protocol/cc3501e.h>.  Pull this in on E1M-AEN
	  builds; <alp/iot.h> and <alp/ble.h> dispatchers will
	  route through it once their CC3501E branches land
	  (v0.3.x follow-up).

config ALP_SDK_CHIP_TMP112
	bool "TI TMP112 digital temperature sensor"
	depends on I2C
	help
	  Compile chips/tmp112/tmp112.c.  On the E1M-AEN module
	  the TMP112DIDPWR sits on Alif's LPI2C bus alongside the
	  RV-3028-C7 RTC and OPTIGA Trust M secure element.
	  +/-0.5 C accuracy, 12/13-bit resolution, 0.0625 C/LSB.

config ALP_SDK_CHIP_RV3028C7
	bool "Micro Crystal RV-3028-C7 ultra-low-power RTC"
	depends on I2C
	help
	  Compile chips/rv3028c7/rv3028c7.c.  32.768 kHz TCXO with
	  1 PPM accuracy, programmable alarm + INT pin.  Used as
	  the wake-from-sleep RTC alarm source on E1M-AEN
	  (RTC_ALARM -> Alif P15_0_FLEX).

config ALP_SDK_CHIP_OPTIGA_TRUST_M
	bool "Infineon OPTIGA Trust M secure element (SLS32AIA010)"
	depends on I2C
	help
	  Compile chips/optiga_trust_m/optiga_trust_m.c.  Hardware
	  security IC with ECC / RSA / AES / SHA-256 / TRNG and
	  10 KB secure NVM.  v0.3 ships a thin driver covering
	  init + I2C connectivity-probe; full APDU command set
	  lands in v0.3.x via Infineon's host library, registered
	  with MbedTLS PSA so <alp/security.h> picks up HW
	  acceleration transparently.

config ALP_SDK_CHIP_EEPROM_24C128
	bool "Generic 24Cxx-class 128-Kbit I2C EEPROM"
	depends on I2C
	help
	  Compile chips/eeprom_24c128/eeprom_24c128.c.  Covers
	  Onsemi N24S128C4DYT3G (E1M-AEN default) + STMicro
	  M24128-BFMH6TG (footprint-compatible alternate).  16 KB,
	  64-byte page write, 5 ms typical write cycle.

config ALP_SDK_CHIP_CAM_MUX_PI3WVR626
	bool "Diodes/Pericom PI3WVR626 MIPI CSI 2:1 mux helper"
	depends on GPIO
	help
	  Compile chips/cam_mux_pi3wvr626/cam_mux_pi3wvr626.c.
	  Thin GPIO wrapper around the PI3WVR626 SEL pin -- routes
	  one of two MIPI CSI camera inputs to the SoM's MIPI CSI
	  port.  On the E1M EVK the SEL line is driven by E1M IO2
	  (Alif P12.5) per the carrier's CAM_MUX.SEL net.

config ALP_SDK_CHIP_TCAL9538
	bool "TI TCA9538 / TCAL9538 8-channel I2C I/O expander"
	depends on I2C
	help
	  Compile chips/tcal9538/tcal9538.c.  On the E1M EVK the
	  TCAL9538 sits on E1M_I2C0 at 0x72 (A1=1, A0=0); its eight
	  GPIOs fan out LCD / camera / capacitive-touch control
	  lines plus four sensor interrupt inputs (see
	  evk_ioexp_pin_t in <alp/boards/alp_e1m_evk.h>).

config ALP_SDK_CHIP_TAS2563
	bool "TI TAS2563 smart Class-D speaker amplifier"
	depends on I2C && GPIO
	help
	  Compile chips/tas2563/tas2563.c.  v0.3 driver scope:
	  init / probe / mode / hw_enable.  Tuning-blob loader +
	  I2S binding land in v0.3.x.  The E1M EVK populates two
	  TAS2563RPP amps on I2C0 + I2S0 (0x4D and 0x4E); see
	  <alp/boards/alp_e1m_evk.h>.

config ALP_SDK_CHIP_INA236
	bool "TI INA236 16-bit current / bus voltage / power monitor"
	depends on I2C
	help
	  Compile chips/ina236/ina236.c.  Per-rail current and
	  power monitoring for instrumented PCBs; the E1M EVK
	  populates six instances at 0x40..0x46 covering +3V3,
	  +1V8, +VIO, +V_CAM0, +V_CAM1, and +5V (see
	  EVK_I2C_ADDR_INA236_* in <alp/boards/alp_e1m_evk.h>).
	  The driver verifies the manufacturer + device ID at
	  init, programs the calibration register from a
	  caller-supplied shunt resistance and max-current pair,
	  and reports bus voltage in mV, shunt voltage in uV,
	  current in uA, and power in uW.

config ALP_SDK_CHIP_ACT8760
	bool "Qorvo / Active-Semi ACT88760 primary PMIC (CMI 120.E1)"
	depends on I2C
	help
	  Compile chips/act8760/act8760.c.  The V2N / V2N-M1 SoMs
	  populate the ACT88760-120.E1 variant: 7x bucks, 6x LDOs,
	  11x GPIOs, dual-page I2C interface at 0x25 + 0x26 on
	  BRD_I2C (Renesas RIIC8).  Power-tree config is burned in
	  the chip's CMI via Qorvo's ActiveCiPS dongle; runtime I2C
	  is volatile-only and used here for telemetry + DVS.
	  Provides act8760_init, act8760_get_status, raw register
	  R/W on either page, and rail-by-rail VSET access (the
	  VSET register offsets are still TODO; see act8760.c).

config ALP_SDK_CHIP_TPS628640
	bool "TI TPS628640 single-channel buck (multi-instance, stub)"
	depends on I2C
	help
	  Compile chips/tps628640/tps628640.c.  Stub-status driver
	  for the TI TPS628640 / TPS628641 / TPS628642 family of
	  single-channel I2C-controlled bucks; V2N-M1 populates four
	  instances at 0x44 (1.05 V DDR5_VDD), 0x48 (0.85 V LPDDR),
	  0x4D (0.6 V LPDDR4X, optional V2N-common), 0x4F (0.5 V
	  DDR5_VDDQ).  The driver currently exposes only probe + raw
	  register R/W -- VSET decode awaits the TI datasheet being
	  added to the vendor datasheet.
	  Until then carriers rely on the chip's factory OTP voltage
	  and don't write to it from firmware.

config ALP_SDK_CHIP_PI3DBS12212
	bool "Diodes PI3DBS12212A 2:1 differential mux (GPIO-only)"
	depends on GPIO
	help
	  Compile chips/pi3dbs12212/pi3dbs12212.c.  Drives the
	  passive 12 Gbps differential mux on V2N-M1 that switches
	  PCIe routing between DEEPX (on-module) and the E1M edge
	  connector.  GPIO-only -- no I2C surface.  Driver takes
	  two alp_gpio_t handles (PD on Renesas P80, SEL on P95
	  per V2N-M1 wiring) and exposes a 3-state model:
	  OFF / PATH_0 / PATH_1, with glitch-free PD pulse on
	  path-to-path transitions.

config ALP_SDK_CHIP_DA9292
	bool "Renesas DA9292 multi-phase buck PMIC (secondary on V2N)"
	depends on I2C
	help
	  Compile chips/da9292/da9292.c.  DA9292 is the secondary
	  PMIC on V2N + V2N-M1, populated at 7-bit I2C address 0x1C
	  on BRD_I2C in 2-channel dual-phase mode.  CH1 (phases 1+2)
	  drives the 0.8 V Renesas rail and is enabled by hardware
	  strap at boot; CH2 (phases 3+4) drives the 0.75 V DEEPX
	  rail and starts disabled.  V2N-M1 firmware brings CH2 up
	  with da9292_v2n_m1_enable_deepx_rail before deasserting
	  M1_RESET; V2N base firmware leaves CH2 alone.  Surfaces
	  status (PG / UV / OV / OC / TEMP / VIN-UVLO), event read-
	  and-clear, voltage set / get (5 mV step, 0.3..1.275 V),
	  per-channel enable, and raw register R/W.

config ALP_SDK_CHIP_GD32G553
	bool "GigaDevice GD32G553 supervisor MCU host-side bridge driver"
	depends on (SPI || I2C)
	help
	  Compile chips/gd32g553/gd32g553.c.  Host-side (Renesas RZ/V2N)
	  driver that talks to the GD32G553MEY7TR companion supervisor
	  over the hybrid SPI + I2C bridge documented in
	  docs/gd32-bridge-protocol.md.  Exposes PING, GET_VERSION,
	  GET_BUILD_ID, RESET_REASON, GPIO_READ/WRITE, PWM_SET/GET,
	  ADC_READ, and DA9292_STATUS_FORWARD on top of either bus
	  (or both at once with per-call routing).  The firmware
	  counterpart lives in gd32-bridge/ as a separate compile
	  artifact.

config ALP_SDK_CHIP_RTL8211FDI
	bool "Realtek RTL8211FDI-VD-CG 10/100/1000BASE-T Ethernet PHY"
	help
	  Compile chips/rtl8211fdi/rtl8211fdi.c.  Callback-driven MDIO
	  driver for the two RTL8211FDI-VD-CG PHYs on the V2N module
	  (ET0 + ET1 behind the Renesas RGMII MACs).  The chip driver
	  itself does not pull in a vendor MDIO header -- the caller
	  supplies mdio_read / mdio_write function pointers, which on
	  Zephyr typically wrap the Renesas-side MDIO controller's
	  zephyr,mdio device.  Surface covers probe (Realtek OUI verify),
	  soft reset, autoneg restart, link / speed / duplex via the
	  Realtek-extended page 0xA43 register 0x1A, and Wake-on-LAN
	  magic-packet detection via the page 0xD8A register block.

config ALP_SDK_CHIP_CLK_5L35023B
	bool "Renesas / IDT 5L35023B audio clock generator (stub)"
	depends on I2C
	help
	  Compile chips/clk_5l35023b/clk_5l35023b.c.  Stub-status driver
	  for the 5L35023B clock generator that sources Audio_CLKB on
	  the V2N module (output to Renesas P10; OE on P67).  Provides
	  init / probe + raw register R/W + a register-dump path for
	  production test.  No frequency-config helpers until the
	  maintainer adds the chip datasheet to the internal design
	  archive and mirrors the Renesas RZ/V2N EVK BSP init sequence
	  into the driver.

config ALP_SDK_CHIP_MURATA_LBEE5HY2FY
	bool "Murata LBEE5HY2FY-922 Wi-Fi 6 + BLE 5.4 module GPIO surface"
	depends on GPIO
	help
	  Compile chips/murata_lbee5hy2fy/murata_lbee5hy2fy.c.  Manages
	  the five side-channel GPIO lines (BT_REG_ON, WL_REG_ON,
	  BT_HOST_WAKE, WL_HOST_WAKE, BT_DEV_WAKE) of the Murata
	  LBEE5HY2FY-922 module on the V2N SoM.  Air-side traffic
	  (Wi-Fi SDIO, BT UART, BT I2S) lives in the host OS stack
	  (brcmfmac + BlueZ + ALSA on Linux); this driver is the thin
	  power-and-wake glue around it.  On V2N the REG_ON lines are
	  GD32-side; the driver takes callbacks for them so the caller
	  can route via gd32g553_gpio_write or a direct local-GPIO
	  shim on carriers that wire REG_ON to the host.

config ALP_SDK_CHIP_DEEPX_DXM1
	bool "DEEPX DX-M1 NPU host-side bring-up sequencer (V2N-M1)"
	depends on GPIO
	select ALP_SDK_CHIP_PI3DBS12212
	help
	  Compile chips/deepx_dxm1/deepx_dxm1.c.  Host-side glue that
	  sequences M1_RESET (Renesas PA6) + the passive PCIe muxes
	  (chips/pi3dbs12212/) before the Linux DEEPX kernel driver
	  (dx_rt_npu_linux_driver) takes over.  Only meaningful on
	  V2N-M1; the underlying DEEPX silicon is NOT populated on
	  V2N base.

config ALP_SDK_CHIP_GD32_SWD
	bool "GD32G553 host-driven SWD bit-bang controller (V2N flash + recovery)"
	depends on GPIO
	help
	  Compile chips/gd32_swd/gd32_swd.c.  Bit-banged SWD controller
	  that lets the Renesas RZ/V2N host reflash the on-module
	  GD32G553MEY7TR companion MCU using three GPIO lines
	  (SWDIO + SWCLK + optional NRST) routed back to the V2N pads
	  per the 2026-05-12 hardware decision.  Reference algorithm
	  follows Arm DDI 0316C (ADIv5) + GD32G553 User Manual Rev 1.2
	  §3 (FMC).  Pulls in no vendor SDK.  The driver exposes the
	  SWD packet layer + DPIDR read + Cortex-M33 halt + FMC erase/
	  write/verify + reset_and_run; pad assignments and silicon
	  exercise still TBD on V2N (see metadata/chips/gd32_swd.yaml).

endmenu # "ALP SDK chip drivers"

endif # ALP_SDK
