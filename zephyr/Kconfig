config ALP_SDK_SECURITY
	bool "Real MbedTLS PSA Crypto for <alp/security.h>"
	default y if MBEDTLS_PSA_CRYPTO_C
	depends on MBEDTLS && MBEDTLS_PSA_CRYPTO_C
	help
	  Gates the real body inside src/backends/security/zephyr_drv.c.
	  When OFF, the registry backend still links (so the dispatcher
	  resolves) but every primitive's I/O op returns
	  ALP_ERR_NOSUPPORT.

	  Wires the alp_hash_* / alp_aead_* / alp_random_bytes
	  surface onto MbedTLS's PSA Crypto API.  PSA picks the
	  active SoC's hardware accelerator transparently when the
	  vendor's driver layer registers it (Alif Ensemble crypto
	  subsystem, Renesas RZ/V2N RSIP).

	  After Slice 4d the dispatcher (src/security_dispatch.c) owns
	  two handle pools (hash + AEAD) and caches the selected
	  backend's ops vtable for the stateless alp_random_bytes fast
	  path; the Zephyr backend (src/backends/security/zephyr_drv.c)
	  is compiled unconditionally so the registry resolves on every
	  build.  See ALP_SDK_SECURITY_SW_FALLBACK for the software-
	  backend opt-in.

config ALP_SDK_SECURITY_SW_FALLBACK
	bool "Software security fallback (no-op / deterministic random)"
	depends on ALP_SDK
	default y if BOARD_NATIVE_SIM || ARCH_POSIX
	default n
	help
	  Compiles a stub security backend that registers as a wildcard
	  at priority 0.  For native_sim build / test and for any build
	  where MbedTLS / PSA Crypto is absent -- hash_open / aead_open
	  succeed (the dispatcher hands out a handle) but hash_update /
	  hash_finish / aead_encrypt / aead_decrypt all return
	  ALP_ERR_NOT_IMPLEMENTED; random_bytes returns ALP_OK and fills
	  the buffer with a deterministic counter+0xAA pattern.  NOT
	  cryptographically random -- the wildcard exists for native_sim
	  portability, not security.  Production builds always link the
	  priority-100 zephyr_drv backend which routes through PSA
	  Crypto's DRBG.

config ALP_SDK_SECURITY_V2N_TRNG_ENTROPY
	bool "Feed the GD32 supervisor's TRNG into MbedTLS entropy on V2N"
	default y if ALP_SDK_V2N_SUPERVISOR && ALP_SDK_SECURITY
	depends on ALP_SDK_V2N_SUPERVISOR && ALP_SDK_SECURITY
	help
	  Compile the mbedtls_hardware_poll() implementation in
	  src/backends/security/zephyr_drv.c that drains true-random bytes
	  from the GD32G553 supervisor's NIST SP800-90B pre-certified
	  TRNG.  The mbedtls profile (metadata/library-profiles/mbedtls/
	  mbedtls_config.h) sets MBEDTLS_NO_PLATFORM_ENTROPY, so
	  mbedtls's entropy module asks the SDK to supply the platform
	  entropy poll callback; this option provides that symbol on
	  V2N.  The portable alp_random_bytes() transparently benefits
	  -- PSA Crypto's DRBG seeds from this source the first time
	  it's drawn from.  No effect on alp_random_bytes's public
	  contract (still ALP_OK / ALP_ERR_NOT_READY / ALP_ERR_IO /
	  ALP_ERR_INVAL); the GD32 dependency is invisible to apps.
	  Off-V2N builds leave this OFF -- mbedtls picks whatever
	  hardware_poll the active vendor's HAL registered, or falls
	  back to ALP_ERR_IO on alp_random_bytes if nothing is wired.

config ALP_SDK_SECURITY_SE_CRYPTOCELL
	bool "Route <alp/security.h> to the Alif SE CryptoCell (hardware crypto)"
	depends on ALP_SDK && HAS_ALIF_SE_SERVICES
	default y if HAS_ALIF_SE_SERVICES
	help
	  Compiles the SE-CryptoCell hardware-crypto backend
	  (src/backends/security/se_cryptocell.c).  It registers at
	  silicon_ref="alif:ensemble:e8" priority 110 -- ahead of the
	  silicon_ref="*" priority-100 MbedTLS-PSA zephyr_drv backend --
	  so on the E8 the portable alp_hash_* / alp_aead_* /
	  alp_random_bytes surface runs INSIDE the Secure Enclave's
	  CryptoCell (CC-3xx) instead of on the M55 core, riding the same
	  MHUv2 -> SE mailbox the read-only se_service client already
	  drives live on the bench.

	  Requires the hal_alif SE-service client (HAS_ALIF_SE_SERVICES,
	  which compiles se_services/zephyr/src/se_service.c) plus its
	  MHUv2 transport (ARM_MHUV2).  The E8 itcm/dtcm DT nodes must
	  carry the `global_base` property the hal_alif local_to_global()
	  helper reads (soc_memory_map.h) -- the board overlay supplies it
	  (alif,itcm/alif,dtcm).

	  RNG/TRNG runs end-to-end today through the public hal_alif
	  se_service_get_rnd_num().  The AES / SHA / CMAC / CCM / GCM /
	  ChaCha20 / Poly1305 compute requests are authored at the wire
	  level (request structs from hal_alif services_lib_protocol.h,
	  IDs 400-422 from services_lib_ids.h) and reach the SE through the
	  public se_service_send_request() transport (added by
	  zephyr/patches/hal_alif/0002-se-service-add-public-send-request.patch).
	  They are gated by ALP_SDK_SECURITY_SE_CRYPTOCELL_SEND_SEAM, which
	  defaults ON (bench-validated on E8: SHA-256 + AES-128-GCM computed in
	  the SE); with it OFF they return ALP_ERR_NOSUPPORT and the dispatcher
	  falls through to the PSA backend.

config ALP_SDK_SECURITY_SE_CRYPTOCELL_SEND_SEAM
	bool "SE CryptoCell generic send-request transport seam is available"
	depends on ALP_SDK_SECURITY_SE_CRYPTOCELL
	default y
	help
	  Enables the AES / SHA / CMAC / CCM / GCM / ChaCha20 / Poly1305
	  compute paths in the SE-CryptoCell backend.  These build a fully
	  populated CryptoCell request packet (transcribed wire structs +
	  local_to_global() address translation) and hand it to
	  alp_se_crypto_send_request().

	  The seam's transport is the public se_service_send_request(), which
	  sends an arbitrary caller-populated SE service packet over the
	  RTSS-HE <-> SE MHUv2 pair and blocks for the response (the same work
	  the static send_msg_to_se() does inside se_service.c), added by
	  zephyr/patches/hal_alif/0002-se-service-add-public-send-request.patch
	  and upstreamable to hal_alif.

	  Defaults ON: bench-validated on real E8 silicon (aen-se-crypto, Flow C
	  RAM-run) -- SHA-256("abc") matched the NIST known-answer and the
	  AES-128-GCM round-trip matched, both computed in the SE CryptoCell
	  (the SE backend binds at priority 110 ahead of PSA).  The remaining
	  family algs ride the identical proven transport + service IDs.  An alg
	  the SE declines (SHA-384/512, an over-ceiling single-shot input)
	  returns ALP_ERR_NOSUPPORT and the dispatcher falls through to the PSA
	  backend.  Turn OFF to force all crypto onto the M55 via PSA.  See #222.

config ALP_SDK_MPROC
	bool "Real multi-processor IPC for <alp/mproc.h>"
	default y if MBOX
	depends on MBOX
	help
	  Gates the real Zephyr-side body inside
	  src/backends/mproc/zephyr_drv.c.  When OFF, the registry
	  backend still links (so the dispatcher resolves) but every
	  primitive's I/O op returns ALP_ERR_NOSUPPORT.

	  After Slice 4c the dispatcher (src/mproc_dispatch.c) and its
	  Zephyr backend (src/backends/mproc/zephyr_drv.c) are compiled
	  unconditionally; this symbol now gates only the body of the
	  Zephyr backend, not what gets linked.  See
	  ALP_SDK_MPROC_SW_FALLBACK for the software-backend opt-in.

	  Per-surface state when ON:

	    - mbox: Zephyr MBOX driver class (v0.4).  Alif's MHU is
	      registered as a Zephyr mbox device on AEN; the backend
	      resolves alp_mbox_config.channel through the alp-mboxN
	      DT aliases.
	    - shmem: DT-anchored carve-outs (v0.7, commit 2e9deec).
	      alp_shmem_open(name) resolves "alp_shmem0".."alp_shmemN"
	      strictly against the alp-shmemN aliases; boards that
	      don't declare the aliases get NOT_READY at open.
	    - hwsem: intra-core k_sem fallback (v0.7, commit 877fa29)
	      indexed by integer hwsem_id, sized by
	      ALP_SDK_MPROC_HWSEM_COUNT.  Cross-core / per-SoC
	      HWSEM-block wiring (AEN HWSEM, ST HSEM, etc.) is
	      tracked separately.

	  Yocto + GD32 backends still return NULL / NOSUPPORT for
	  shmem + hwsem; Yocto carries the mbox shim only.

config ALP_SDK_MPROC_SW_FALLBACK
	bool "Software mproc fallback (no-op stubs)"
	depends on ALP_SDK
	default y if BOARD_NATIVE_SIM || ARCH_POSIX
	default n
	help
	  Compiles a no-op mproc backend that registers as a wildcard
	  at priority 0.  For native_sim build / test only -- no real
	  MHU / shared-memory carve-out / hwsem block exists, so
	  shmem_open / mbox_open / hwsem_open succeed silently,
	  hwsem_try_lock / lock / unlock are no-op ALP_OK, and
	  shmem_view / mbox_send / mbox_set_callback return
	  ALP_ERR_NOT_IMPLEMENTED.

config ALP_SDK_MPROC_NANOPB_FRAMING
	bool "Frame alp_mbox_send payloads through the IPC envelope"
	default n
	help
	  Wraps every alp_mbox_send payload in the IPC envelope
	  declared in src/common/proto/alp_mproc_frame.h before
	  handing it to the Zephyr mbox driver, and unwraps inbound
	  frames before dispatching alp_mbox_msg_cb_t.  The placeholder
	  binary format is intentionally NOT compatible with the v0.4-
	  final protobuf wire generated by nanopb against
	  metadata/protos/alp_mproc.proto -- this option exists so the
	  framing code path is exercised before the nanopb generator
	  pack lands.  Both ends of an IPC channel must agree on the
	  flag value; mixing framed + raw firmwares is a wire-protocol
	  break.

	  Has runtime effect only when ALP_SDK_MPROC is also on (the
	  framing code in mproc_zephyr.c is gated on both flags).
	  Compile-tested standalone so the encode/decode helpers can
	  be exercised under native_sim without a real mbox device.

config ALP_SDK_MPROC_FRAME_MAX_BYTES
	int "Maximum framed envelope size (bytes)"
	default 512
	depends on ALP_SDK_MPROC_NANOPB_FRAMING
	help
	  Static scratch buffer reserved per alp_mbox_t for the framed
	  payload.  Header overhead is ALP_MPROC_FRAME_HEADER_BYTES (12)
	  so the usable payload ceiling is this value minus 12 bytes.
	  Raise for larger RPC requests / responses.

config ALP_SDK_RPC
	bool "Framed RPC over OpenAMP / RPMsg for <alp/rpc.h>"
	default y if IPC_SERVICE_BACKEND_RPMSG
	depends on IPC_SERVICE_BACKEND_RPMSG && OPENAMP
	help
	  Gates the real Zephyr ipc_service / RPMsg body inside
	  src/backends/rpc/zephyr_drv.c.  When OFF, the registry
	  backend still links (so the dispatcher resolves) but every
	  channel-side op returns ALP_ERR_NOSUPPORT.

	  After Slice 4c the dispatcher (src/rpc_dispatch.c) and its
	  Zephyr backend (src/backends/rpc/zephyr_drv.c) are compiled
	  unconditionally; this symbol now gates only the body of the
	  Zephyr backend, not what gets linked.  See
	  ALP_SDK_RPC_SW_FALLBACK for the software-backend opt-in.

	  The orchestrator (scripts/alp_orchestrate.py) generates
	  <alp/system_ipc.h> + a per-board DT overlay under
	  zephyr/boards/<sku>_<core>.overlay that wires up the
	  carve-out, mailbox channel, and chosen { zephyr,ipc } node
	  so customer code calls alp_rpc_open(&(alp_rpc_config_t){...})
	  without knowing the address layout.  Heterogeneous projects
	  (board.yaml v2 with an ipc[] block) flip this on automatically
	  via the orchestrator-emitted per-core alp.conf.

config ALP_SDK_RPC_SW_FALLBACK
	bool "Software RPC fallback (no-op stub)"
	depends on ALP_SDK
	default y if BOARD_NATIVE_SIM || ARCH_POSIX
	default n
	help
	  Compiles a no-op RPC backend that registers as a wildcard at
	  priority 0.  For native_sim build / test only -- no real
	  OpenAMP / RPMsg transport exists, so open / subscribe /
	  unsubscribe / send all succeed silently and call returns
	  ALP_ERR_TIMEOUT immediately (mirrors the documented header
	  contract for a peer that fails to respond).

config ALP_SDK_MAX_RPC_HANDLES
	int "Maximum concurrent alp_rpc_channel_t handles (dispatcher pool)"
	default 2
	help
	  Sizes the dispatcher's per-handle pool in src/rpc_dispatch.c.
	  Default 2 covers the typical "control + telemetry" channel
	  pair an M-class slice opens; raise for apps that segment more
	  aggressively.  Separate from ALP_SDK_RPC_MAX_CHANNELS, which
	  sizes the Zephyr backend's internal struct rpc_be pool (must
	  be >= this value).

config ALP_SDK_RPC_MAX_CHANNELS
	int "Maximum struct rpc_be slots in the Zephyr backend pool"
	default 4
	depends on ALP_SDK_RPC
	help
	  Each backend slot reserves one ipc_service endpoint + a
	  method-subscribe table + the per-channel TX scratch and
	  sync-call slot.  4 covers the dispatcher's default pool of
	  2 with comfortable headroom for transient reopen flows;
	  raise alongside ALP_SDK_MAX_RPC_HANDLES if more handles are
	  held concurrently.

config ALP_SDK_RPC_SUBS_PER_CHANNEL
	int "Maximum alp_rpc_subscribe registrations per channel"
	default 8
	depends on ALP_SDK_RPC
	help
	  v0.6 dispatch table cap.  Subscribe attempts beyond this
	  return ALP_ERR_NOMEM with a clear log line so the customer
	  knows to raise the cap.  8 is sized for typical sensor /
	  command / event topic counts in a single channel; bigger
	  apps should split across more channels.

config ALP_SDK_RPC_TX_FRAME_MAX
	int "Max alp_rpc_send / alp_rpc_call frame size (bytes)"
	default 1024
	depends on ALP_SDK_RPC
	help
	  Per-channel TX scratch buffer.  Frame = method header (<=32 B
	  with NUL) + opaque payload.  1024 fits short sensor records,
	  small JSON snippets, and the v0.7 protobuf-framing upgrade
	  comfortably.  Sends that don't fit return ALP_ERR_NOMEM.

