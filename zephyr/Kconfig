	int "Maximum concurrent alp_aead_t handles"
	default 4

config ALP_SDK_BLE_MAX_CONNS
	int "Maximum concurrent alp_ble_conn_t handles"
	default 2
	help
	  Mirrors CONFIG_BT_MAX_CONN; raise both together if your app
	  holds more than two simultaneous connections.

config ALP_SDK_MAX_INFERENCE_HANDLES
	int "Maximum concurrent alp_inference_t handles"
	default 2
	help
	  Each handle reserves one tensor arena (default 128 KiB
	  static; caller-supplied via cfg.arena overrides) so the
	  default 2 is intentionally low.  Raise only if the app
	  genuinely runs multiple models at once.

config ALP_SDK_HAS_LVGL
	bool "Build <alp/gui.h> against LVGL"
	default y if LVGL
	default n
	help
	  Pulls upstream LVGL into the alp_gui_lvgl_attach() path.
	  Requires CONFIG_LVGL=y.

# Note: LwRB + nanopb were previously gated by CONFIG_ALP_SDK_USE_*
# flags here.  Removed in the v0.3 cleanup -- both are SDK-internal
# libraries (LwRB for audio DMA staging, nanopb for mproc IPC frame
# serialisation) and consumers don't need to enable them.  When the
# v0.4 audio + mproc paths land, the SDK code uses them
# unconditionally; the west.yml pins go in alongside.  See
# vendors/lwrb/ and vendors/nanopb/ for the runtime contract.

config ALP_SDK_HAS_CMSIS_DSP
	bool "Build <alp/math.h> against CMSIS-DSP"
	default y if CMSIS_DSP
	default n
	help
	  Re-export arm_math.h via <alp/math.h>.  Requires the
	  CMSIS-DSP module to be present in the Zephyr west manifest.

config ALP_SDK_HW_INFO
	bool "Runtime hardware-info reader (EEPROM + BOARD_ID ADC)"
	default y
	help
	  Compile src/zephyr/hw_info_zephyr.c.  Provides the
	  alp_hw_info_read() + alp_hw_info_assert_matches_build()
	  surface backed by the SoM on-module 24C128 EEPROM and the
	  per-board BOARD_ID ADC + resistor divider.  The EEPROM-side
	  half is wired when CONFIG_ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID
	  is set to a non-negative bus id; the BOARD_ID ADC cross-check
	  remains TODO pending the per-family generated header.

config ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID
	int "I2C bus id for the on-module EEPROM (< 0 = disabled)"
	default -1
	depends on ALP_SDK_HW_INFO && I2C && ALP_SDK_CHIP_EEPROM_24C128
	help
	  Per-board: the bus id (matches alp_i2c_open's bus_id field)
	  carrying the SoM's on-module 24C128 EEPROM.  On V2N this is
	  the E1M I2C0 bus (Renesas RIIC0 on P31/P30); on AEN it's the
	  Alif LPI2C bus.  Set to -1 to disable the EEPROM read path --
	  alp_hw_info_read() returns ALP_ERR_NOSUPPORT.

config ALP_SDK_HW_INFO_EEPROM_ADDR_7BIT
	hex "7-bit I2C address of the on-module EEPROM"
	default 0x50
	range 0x50 0x57
	depends on ALP_SDK_HW_INFO && ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID >= 0
	help
	  EEPROM I2C address strap (24C128 family supports 0x50..0x57).

config ALP_SDK_HW_INFO_EEPROM_OFFSET
	int "Manifest offset within the EEPROM (bytes)"
	default 0
	depends on ALP_SDK_HW_INFO && ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID >= 0
	help
	  Byte offset of the alp_hw_info_eeprom_t struct in EEPROM
	  storage.  Default 0 -- production-test flow places the
	  manifest at offset 0 per the design note in
	  metadata/e1m_modules/<family>/hw-revisions.yaml.

config ALP_SDK_HW_INFO_EEPROM_I2C_BITRATE_HZ
	int "I2C bitrate for the EEPROM read (Hz)"
	default 400000
	depends on ALP_SDK_HW_INFO && ALP_SDK_HW_INFO_EEPROM_I2C_BUS_ID >= 0
	help
	  Standard-mode 100 kHz, fast-mode 400 kHz, or fast-mode+ 1 MHz
	  -- choose the highest the on-bus devices all support.

# Chip drivers.  Each is opt-in so projects only pay for the
# silicon they actually use.  Symbols use the chip's natural prefix
# (lsm6dso_*, ssd1306_*, bme280_*, …) — no alp_ prefix on chip
# drivers.  The button_led / pdm_mic helpers are the exception
# (generic block utilities, alp_-prefixed).

menu "ALP SDK chip drivers"

config ALP_SDK_CHIP_LSM6DSO
	bool "STMicroelectronics LSM6DSO 6-axis IMU driver"
	depends on I2C
	help
	  Compile chips/lsm6dso/lsm6dso.c.  Provides lsm6dso_init,
	  lsm6dso_read_accel/gyro/temp.  Used by the alp-studio
	  block blk_imu_lsm6dso.

config ALP_SDK_CHIP_SSD1306
	bool "Solomon Systech SSD1306 monochrome OLED driver"
	depends on I2C
	help
	  Compile chips/ssd1306/ssd1306.c.  Provides ssd1306_init,
	  ssd1306_clear, ssd1306_draw_pixel, ssd1306_display.  Used
	  by the alp-studio block blk_oled_ssd1306.

config ALP_SDK_CHIP_BUTTON_LED
	bool "Generic button + LED block helper"
	depends on GPIO
	help
	  Compile chips/button_led/button_led.c.  Wraps alp_gpio_*
	  to provide alp_button_led_* lifecycle helpers used by the
	  alp-studio block blk_button_led.

config ALP_SDK_CHIP_BME280
	bool "Bosch BME280 environment sensor driver (T/H/P)"
