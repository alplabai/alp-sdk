# Alp SDK Kconfig fragment exposed to Zephyr applications.

config ALP_SDK
	bool "Alp SDK"
	help
	  Enable the Alp SDK on Zephyr.  When set, the SDK's Zephyr
	  backend is compiled and <alp/...> headers are added to the
	  application include path.

if ALP_SDK

# Subsystem fragments (issue #458): each covers one surface/vendor
# grouping and is sourced in the same order the monolith previously
# declared them in, so config ordering, choice/if/menu scoping, and every
# symbol's defaults/deps/help stay byte-for-byte equivalent.
rsource "kconfig/core.kconfig"
rsource "kconfig/i2c-spi-handles.kconfig"
rsource "kconfig/vendor-renesas-spi.kconfig"
rsource "kconfig/vendor-alif-peripherals.kconfig"
rsource "kconfig/peripherals-handles.kconfig"
rsource "kconfig/v2n-supervisor.kconfig"
rsource "kconfig/peripherals-wrappers.kconfig"
rsource "kconfig/power-camera-display.kconfig"
rsource "kconfig/gpu2d-update-log.kconfig"
rsource "kconfig/iot-audio-inference.kconfig"
rsource "kconfig/ble-security.kconfig"
rsource "kconfig/mproc-rpc-usb.kconfig"
rsource "kconfig/hw-info.kconfig"
rsource "kconfig/chips.kconfig"

# §D.lib.loader -- per-library HW-accelerator Kconfig knobs declared
# in a sibling file so the chip-driver menu above stays focused on
# chip surfaces.  Loader emits these from each enabled library's
# metadata/library-profiles/<name>/hw-backends.yaml.
rsource "Kconfig.alp-libraries"

# ---------------------------------------------------------------------------
# Alif Ensemble xHCI USB host (UHC) driver skeleton -- ADR 0017 Tier-1.5.
# Sourced inside if ALP_SDK because it is an alp-sdk module driver (wired
# from zephyr/CMakeLists.txt) and depends on UHC_DRIVER being enabled by
# the application.
# ---------------------------------------------------------------------------
rsource "drivers/usb/uhc/Kconfig"

endif # ALP_SDK

# ---------------------------------------------------------------------------
# Alif Ensemble MRAM flash driver -- DELIBERATELY OUTSIDE `if ALP_SDK`.
#
# Unlike the other vendored Alif drivers (ADC_ALIF / SPI_DW_ALIF / PWM_ALIF),
# the MRAM flash driver must be visible to images that do NOT set
# CONFIG_ALP_SDK -- specifically the MCUboot bootloader, which sysbuild builds
# as its own vanilla Zephyr image (it never enables ALP_SDK).  MCUboot's
# flash_map needs a flash driver on the MRAM to read/write slot0/slot1, so the
# symbol has to be reachable in the bootloader's Kconfig tree.  Gating only on
# CONFIG_FLASH + the DT node (not ALP_SDK) keeps it a plain Zephyr flash driver
# that any image consuming alp-sdk as a module can pull in.
# ---------------------------------------------------------------------------
config MRAM_FLASH_ALIF
	bool "Alif Ensemble MRAM flash (ADR 0017 Tier-2 INTERIM -> retire onto fork, BENCH-UNVERIFIED)"
	default y
	depends on FLASH
	depends on DT_HAS_ALIF_MRAM_FLASH_CONTROLLER_ENABLED
	select FLASH_HAS_DRIVER_ENABLED
	select FLASH_HAS_PAGE_LAYOUT
	select FLASH_HAS_NO_EXPLICIT_ERASE
	help
	  Alif Ensemble on-die MRAM flash class driver (compatible
	  "alif,mram-flash-controller", base 0x80000000), vendored VERBATIM from
	  the Apache-2.0 zephyr_alif fork (drivers/flash/flash_mram_alif.c).
	  Upstream Zephyr v4.4 + hal_alif ship NO flash-class driver for the MRAM
	  -- the upstream E8 SoC dtsi exposes it only as a "zephyr,memory-region"/
	  "soc-nv-flash" memory region (XIP-readable, no write/erase), which is not
	  a flash controller and so does not set FLASH_HAS_DRIVER_ENABLED.  MCUboot
	  and its flash_map need a real flash driver on the MRAM to read/write the
	  slot0/slot1 partitions, hence this fork-driver copy.  Pure CMSIS register/
	  memory access -- pulls in no hal_alif library (unlike ADC_ALIF).  16-byte
	  (128-bit) program/sector unit; software write-protection.  Not
	  silicon-validated.

	  ADR 0017 Tier-2 (a genuine fork-driver copy -- upstream + hal_alif ship no
	  MRAM flash driver): INTERIM.  Retires onto the opt-in sdk-alif fork once
	  the MRAM flash node is repointed to the fork compatible AND bench-verified.
	  Driver: zephyr/drivers/flash/flash_mram_alif.c.

# Alif peripheral-flow PL330 DMA + its Event-Router multiplexer, vendored from the
# Apache-2.0 sdk-alif fork with DISTINCT compatibles (alif,dma-pl330 /
# alif,dma-event-router) + config (DMA_PL330_ALIF) so they coexist with upstream
# Zephyr's MEMORY_TO_MEMORY-only arm,dma-pl330.  Provides host-side peripheral DMA
# for continuous SPI streams (the CC3501E bridge).  ADR 0017 Tier-2 (INTERIM;
# upstream ships no peripheral-flow PL330).  Drivers under zephyr/drivers/dma/.
rsource "drivers/dma/Kconfig.dma_pl330_alif"
rsource "drivers/dma/Kconfig.dma_alif_event_router"
