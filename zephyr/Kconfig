# Alp SDK Kconfig fragment exposed to Zephyr applications.

config ALP_SDK
	bool "Alp SDK"
	help
	  Enable the Alp SDK on Zephyr.  When set, the SDK's Zephyr
	  backend is compiled and <alp/...> headers are added to the
	  application include path.

if ALP_SDK

# Active SoC selection — drives <alp/soc_caps.h> capability checks.
# When no choice is selected the SDK's runtime validation is permissive
# (default macros = UINT16_MAX); selecting a SoC enables strict
# rejection of configs that exceed its documented hardware caps.
# See docs/adr/0002-error-mechanism.md.

choice
	prompt "Active SoC capability profile (for runtime config validation)"
	default ALP_SOC_NONE
	help
	  Select the SoM's SoC so the SDK can reject runtime configs
	  that exceed its documented caps (e.g. a 16-bit ADC config
	  on a 12-bit SoC).  alp-studio's generated build sets this
	  automatically; hand-written firmware can pick manually.

config ALP_SOC_NONE
	bool "None — capability checks pass through"

config ALP_SOC_ALIF_ENSEMBLE_E3
	bool "Alif Ensemble E3 (alif:ensemble:e3)"

config ALP_SOC_ALIF_ENSEMBLE_E4
	bool "Alif Ensemble E4 (alif:ensemble:e4 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E5
	bool "Alif Ensemble E5 (alif:ensemble:e5 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E6
	bool "Alif Ensemble E6 (alif:ensemble:e6 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E7
	bool "Alif Ensemble E7 (alif:ensemble:e7)"

config ALP_SOC_ALIF_ENSEMBLE_E8
	bool "Alif Ensemble E8 (alif:ensemble:e8 — preliminary)"

config ALP_SOC_RENESAS_RZV2N_N44
	bool "Renesas RZ/V2N R9A09G056N44 (renesas:rzv2n:n44)"

config ALP_SOC_DEEPX_DX_M1
	bool "DEEPX DX-M1 NPU (deepx:dx:m1)"

config ALP_SOC_NXP_IMX9_IMX93
	bool "NXP i.MX 93 (nxp:imx9:imx93 — preliminary)"

endchoice

config ALP_SDK_MAX_I2C_HANDLES
	int "Maximum concurrent alp_i2c_t handles"
	default 4

config ALP_SDK_I2C_SW_FALLBACK
	bool "Software I2C fallback (in-memory loopback)"
	depends on ALP_SDK
	default y if BOARD_NATIVE_SIM || ARCH_POSIX
	default n
	help
	  Compiles a deterministic in-memory I2C loopback backend that
	  registers as a wildcard at priority 0.  write() stashes the
	  last frame keyed by address; read() returns it zero-padded or
	  truncated.  For native_sim build / test only -- production
	  firmware MUST NOT rely on this since no real device is driven.

config ALP_SDK_MAX_SPI_HANDLES
	int "Maximum concurrent alp_spi_t handles"
	default 4

config ALP_SDK_SPI_SW_FALLBACK
	bool "Software SPI fallback (in-memory loopback)"
	depends on ALP_SDK
	default y if BOARD_NATIVE_SIM || ARCH_POSIX
	default n
	help
	  Compiles a deterministic in-memory SPI loopback backend that
	  registers as a wildcard at priority 0.  transceive() copies tx
	  into rx when both non-NULL; tx-only is a no-op; rx-only zero-fills.
	  For native_sim build / test only -- production firmware MUST NOT
	  rely on this since no real device is driven.

# Renesas RZ SPI_B (RSPI) controller driver -- carried in the alp-sdk
# module (NOT upstream Zephyr) so it survives a `west update` of the
# Zephyr tree.  Drives the new-generation RZ SPI_B IP (RZ/V2N, ...) via
# the FSP r_spi_b module; backs the on-module GD32 supervisor SPI fast
# path.  Driver source: zephyr/drivers/spi/spi_renesas_rz_spi_b.c;
# binding: zephyr/dts/bindings/spi/renesas,rz-spi-b.yaml.
config SPI_RENESAS_RZ_SPI_B
	bool "Renesas RZ SPI_B (RSPI)"
	default y
	depends on DT_HAS_RENESAS_RZ_SPI_B_ENABLED
	select USE_RZ_FSP_SPI_B
	select PINCTRL
	help
	  Enable the Renesas RZ SPI_B (RSPI) driver for the new-generation RZ
	  MPUs (RZ/V2N, RZ/V2H, ...), which replace the classic RSPI with the
	  SPI_B IP served by the FSP r_spi_b module.  The upstream
	  `renesas,rz-spi` driver targets the classic `r_spi` the rzv FSP does
	  not ship, so this dedicated `renesas,rz-spi-b` driver is required.

config SPI_RENESAS_RZ_SPI_B_INTERRUPT
	bool "RZ SPI_B interrupt-driven transfers"
	default y
	depends on SPI_RENESAS_RZ_SPI_B
	help
	  Use the FSP r_spi_b interrupt-driven transfer path (rxi/txi/tei/eri).
	  When disabled, the driver falls back to polled PIO transfers.

config SPI_RENESAS_RZ_SPI_B_USE_HW_SS
	bool "RZ SPI_B hardware slave select"
	default y
	depends on SPI_RENESAS_RZ_SPI_B
	help
	  Drive the chip select with the SPI_B SSL output instead of a GPIO.

config USE_RZ_FSP_SPI_B
	bool
	help
	  Compile the FSP r_spi_b module source (selected by
	  SPI_RENESAS_RZ_SPI_B).  The HAL build (modules/hal/renesas/drivers/
	  rz/CMakeLists.txt) gates rzv/r_spi_b/r_spi_b.c on this symbol, but
	  upstream Zephyr v4.4's zephyr/modules/Kconfig.renesas never defines
	  it (it defines the sibling USE_RZ_FSP_{SPI,RSPI_SPI,RIIC_MASTER});
	  define it here so the deliverable doesn't depend on patching Zephyr.

# Renesas RZ SCI-B Simple-SPI driver -- an SCI channel in clock-synchronous
# "Simple SPI" mode.  Drives the on-module GD32 supervisor SPI fast path, which
# the board wires to SCI7 (P76/P77/P96/P97 = MOSI7/MISO7/SCK7/SS7), NOT the
# dedicated SPI_B IP.  The rzv FSP ships no SCI-SPI module, so the FSP
# r_sci_b_spi module is vendored from RA into this SDK
# (zephyr/drivers/spi/r_sci_b_spi/) and gated by USE_RZ_FSP_SCI_B_SPI.
# Driver: zephyr/drivers/spi/spi_renesas_rz_sci_b.c;
# binding: zephyr/dts/bindings/spi/renesas,rz-sci-b-spi.yaml.
config SPI_RENESAS_RZ_SCI_B
	bool "Renesas RZ SCI-B Simple-SPI"
	default y
	depends on DT_HAS_RENESAS_RZ_SCI_B_SPI_ENABLED
	select USE_RZ_FSP_SCI_B_SPI
	select PINCTRL
	select GPIO
	help
	  Enable the Renesas RZ SCI-B Simple-SPI driver for the new-generation RZ
	  MPUs (RZ/V2N, ...).  An SCI channel runs in clock-synchronous Simple-SPI
	  mode via the FSP r_sci_b_spi module (vendored from RA -- see
	  USE_RZ_FSP_SCI_B_SPI).  The driver is interrupt-driven and master-only on
	  this port; master mode has no hardware slave-select, so the chip-select is
	  a GPIO (cs-gpios) -- GPIO is selected here because the driver cannot frame
	  a transfer without it.

config USE_RZ_FSP_SCI_B_SPI
	bool
	help
	  Compile the vendored FSP r_sci_b_spi module
	  (zephyr/drivers/spi/r_sci_b_spi/r_sci_b_spi.c), selected by
	  SPI_RENESAS_RZ_SCI_B.  The rzv FSP HAL ships only r_sci_b_uart / r_spi_b /
	  r_rspi, so -- unlike USE_RZ_FSP_SPI_B, which gates an existing HAL source
	  -- this symbol gates a BSD-3 FSP source carried inside this SDK (the RA
	  r_sci_b_spi.c, near-identical -- one documented one-line deviation -- with
	  an RZ cfg shim in r_sci_b_spi_cfg.h).

# Alif Ensemble ARM MHUv2 inter-core mailbox driver -- vendor-ext,
# BENCH-UNVERIFIED.  Carried here (not upstream Zephyr) so it survives a
# `west update`.  Mainline Zephyr v4.4 ships no `arm,mhuv2` binding; the
# opt-in alifsemi/zephyr_alif fork does, so a DISTINCT compatible
# `alif,mhuv2-mbox` is used to stay collision-free and let the stack build on
# the default upstream-Zephyr + hal_alif base.  Backs alp_rpc_open (OpenAMP
# static-vrings) on AEN801 (E8); rollout to AEN301..701 follows after AEN801
# bench-passes.  Driver: zephyr/drivers/mbox/mbox_alif_mhuv2.c;
# binding: zephyr/dts/bindings/mbox/alif,mhuv2-mbox.yaml.
config MBOX_ALIF_MHUV2
	bool "Alif Ensemble MHUv2 mailbox (vendor-ext, BENCH-UNVERIFIED)"
	default y
	depends on MBOX
	depends on DT_HAS_ALIF_MHUV2_MBOX_ENABLED
	help
	  Enable the ARM MHUv2 inter-core doorbell mailbox driver as integrated in
	  the Alif Ensemble family (E1/E3/E5/E7/E8).  Doorbell (signalling) mode
	  only: no payload travels through the MHU; data rides the OpenAMP
	  static-vrings in shared SRAM and the MHU only rings a per-bit doorbell.
	  vendor-ext, BENCH-UNVERIFIED -- authored from the ARM MHUv2 spec + the
	  zephyr_alif fork DTS; not yet validated on real silicon.

# Alif Ensemble hardware-semaphore (HWSEM) -- AMP mutual-exclusion latch shared
# between the two RTSS cores (M55-HE <-> M55-HP).  HWSEM has NO upstream Zephyr
# device class, so this is a "misc" (no-class) driver exposing a small take/give
# API (zephyr/drivers/misc/alif_hwsem/hwsem_alif.h).  Distinct compatible
# `alif,hwsem` keeps it collision-free on the default upstream-Zephyr + hal_alif
# base.  Driver: zephyr/drivers/misc/alif_hwsem/hwsem_alif.c;
# binding: zephyr/dts/bindings/misc/alif,hwsem.yaml.
config HWSEM_ALIF
	bool "Alif Ensemble hardware semaphore (vendor-ext, BENCH-UNVERIFIED)"
	default y
	depends on DT_HAS_ALIF_HWSEM_ENABLED
	help
	  Enable the Alif Ensemble HWSEM driver -- an AMP request/release latch
	  arbitrating a shared resource between the two RTSS cores (M55-HE and
	  M55-HP).  The take/give pair is keyed by the calling core's MASTER ID
	  (its CPUID), so a release only frees the latch for its owner.  Exposes a
	  tiny take/give API (hwsem_alif.h), NOT a standard Zephyr device-class API
	  (HWSEM has no upstream class).  vendor-ext, BENCH-UNVERIFIED -- authored
	  clean-room from the Alif DFP HWSEM register header; not yet validated on
	  real silicon.

#
# (Retired, task #21 / ADR 0017) There is intentionally NO Alif LPI2C driver.
# The on-module LPI2C0 housekeeping bus is SLAVE-ONLY (TRM §3.17.4), so a
# master-mode controller driver is a dead end; the RTC/TMP112/OPTIGA reads are
# Tier-3 (Alif SE services).  Edge I2C masters are Tier-1 upstream i2c_dw
# (snps,designware-i2c).  The former alif,lpi2c TX-only driver was removed.
#

config ETH_DWMAC_ALIF
	bool "Alif Ensemble DesignWare MAC glue (ADR 0017 Tier-1.5, BENCH-VERIFIED E8 2026-06-17)"
	default y
	depends on DT_HAS_ALIF_ETHERNET_ENABLED
	select ETH_DWMAC
	select PINCTRL
	select NOCACHE_MEMORY if ARCH_HAS_NOCACHE_MEMORY_SUPPORT
	help
	  Alif Ensemble platform glue (compatible "alif,ethernet") backing the
	  UPSTREAM eth_dwmac (Synopsys DesignWare GMAC) core.  Enables the
	  GMAC peripheral clock via the alif clock controller, wires the IRQ +
	  pinctrl, and hands the descriptor rings to the core.  First bring-up
	  is fixed-link (no upstream MDIO driver in Zephyr v4.4).
	  BENCH-VERIFIED E8 2026-06-17: the E1M-AEN801 (Cortex-M55-HE) pulled a
	  real DHCP lease and was server-side REACHABLE.  Driver:
	  zephyr/drivers/ethernet/eth_dwmac_alif_ensemble.c.

	  DMA-BUFFER PLACEMENT (required on the M55): the GMAC is a DMA bus master
	  and the upstream core hands it the raw CPU pointer (no local_to_global
	  translation), so the descriptor rings AND the net_buf packet pool MUST
	  live in the global on-chip SRAM0 (sram@2000000, @0x02000000, CPU addr ==
	  DMA addr), NEVER in the M55 DTCM (CPU-local, not on the GMAC AXI path --
	  buffers there are invisible to the DMA and no frame moves).  Pin this in
	  the board overlay via `chosen { zephyr,sram = &sram0; }` and keep
	  CONFIG_DCACHE=n (or a nocache region) so CPU and DMA share a coherent
	  view; the driver BUILD_ASSERTs the cache-coherency half of this.

	  ADR 0017 Tier-1.5 (in-tree thin glue over an UPSTREAM core): kept
	  in-tree, NOT retired onto the fork -- the sdk-alif fork forked the
	  DWMAC *core* (consuming it violates one-upstream-base), and upstream
	  Kconfig.dwmac offers no Ensemble path (STM32-only / MMU-gated; the M55
	  has an MPU).  Retiring would be an unconditional silent Ethernet loss.
	  See docs/adr/0017 + task #21.

choice ETH_DWMAC_ALIF_RMII_REFCLK
	prompt "Alif GMAC RMII 50 MHz reference-clock source"
	depends on ETH_DWMAC_ALIF
	default ETH_DWMAC_ALIF_RMII_REFCLK_AUTO
	help
	  Selects the source of the GMAC RMII 50 MHz reference clock via the Alif
	  ETH_CTRL register (CLKCTL_PER_MST 0x4903F000 + 0x80, bit 4).  The DWMAC
	  DMA software-reset cannot complete without a running RMII ref-clock, so
	  this MUST match the carrier wiring.  Bit-4 encodings transcribed from the
	  Apache-2.0 zephyr_alif fork (ALIF_ETH_RMII_{REFCLK_PIN,PLL_CLK_50M});
	  confirm against the Alif Ensemble TRM.

config ETH_DWMAC_ALIF_RMII_REFCLK_AUTO
	bool "Auto-detect (external pin, fall back to internal PLL)"
	help
	  Try the external REFCLK pin first (production wiring); if no clock is
	  present -- detected because the GMAC DMA soft-reset cannot complete --
	  fall back to the SoC internal 50 MHz PLL.  This is the robust default: it
	  brings Ethernet up on both fully-populated carriers (external oscillator
	  into P11_0) and boards without the RMII oscillator populated, with no
	  per-board configuration.  Bench-validated on the E1M-AEN801 (E8, 2026-06-17):
	  with the PHY power-enable (P15_4) asserted early, auto-detect found the
	  on-module external 50 MHz RMII oscillator (P11_0) and selected it
	  (ETH_CTRL bit 4 = 0); the MAC reset completed and the SOM pulled a real
	  DHCP lease.  (The internal-PLL fallback path remains, but was not the
	  bench-verified path.)

config ETH_DWMAC_ALIF_RMII_REFCLK_EXTERNAL
	bool "Force external REFCLK pin (P11_0 input)"
	help
	  ETH_CTRL bit 4 = 0, no fallback.  The carrier/SoM feeds a 50 MHz
	  oscillator into the RMII REFCLK pin (P11_0).  This is the E1M-AEN801
	  production wiring; use it to skip the auto-detect reset probe.

config ETH_DWMAC_ALIF_RMII_REFCLK_INTERNAL_PLL
	bool "Force internal 50 MHz PLL (SoC drives the PHY)"
	help
	  ETH_CTRL bit 4 = 1, no fallback.  The SoC generates the 50 MHz RMII
	  reference clock internally and drives it out to the PHY.  Use when no
	  external RMII oscillator is populated and you want to skip the probe.

endchoice

config SPI_DW_ALIF
	bool "Alif Ensemble DWC_ssi SPI (ADR 0017 Tier-2 INTERIM -> retire onto fork, BENCH-UNVERIFIED)"
	default y
	depends on DT_HAS_ALIF_DWC_SSI_SPI_ENABLED
	select PINCTRL
	help
	  Alif Ensemble DesignWare DWC_ssi SPI controller driver, vendored from
	  the Apache-2.0 zephyr_alif fork (drivers/spi/spi_dw_alif.c).  Binds the
	  distinct compatible "alif,dwc-ssi-spi" so it does NOT collide with
	  upstream Zephyr's DW-apb-SSI spi_dw (which owns "snps,designware-spi").
	  The DWC_ssi CTRLR0 register layout differs from DW-apb-SSI -- set the
	  node's `dwc-ssi` property.  Not silicon-validated.

	  ADR 0017 Tier-2 (a genuine fork-driver copy -- hal_alif ships no SSI
	  library): INTERIM.  Retires onto the opt-in sdk-alif fork once `spi0`
	  is repointed to the fork compatible AND bench-verified (hard-deleting
	  before the repoint lands would be a silent SPI-master regression).  A
	  pure-Tier-1 end-state is one small upstream patch away (set SSI_IS_MST,
	  CTRLR0[31], under CONFIG_SPI_DW_HSSI -- filed, non-blocking).  Task #21.

config SPI_DW_ALIF_USE_DMA
	bool "Alif DWC_ssi SPI DMA code path"
	default n
	depends on SPI_DW_ALIF
	help
	  Compile the DMA transfer path of the Alif DWC_ssi SPI driver.  DMA is
	  only actually engaged when the node wires `dmas`/`dma-names`; left off
	  by default (the DMAC channel/handshake encoding is a bench unknown).

# ----------------------------------------------------------------------------
# Secure-Enclave (SE) SERVICE transport -- Arm MHUv2 IPM driver + hal_alif client
# ----------------------------------------------------------------------------
# The SE service client lives in the Apache-2.0 hal_alif module
# (se_services/zephyr/src/se_service.c) and talks to the SE over two Arm MHUv2
# mailboxes via Zephyr's IPM API.  Two symbols gate it: ARM_MHUV2 (the in-tree
# IPM driver) and HAS_ALIF_SE_SERVICES (which compiles the hal_alif client).
# BOTH are `select`ed only by the Alif zephyr_alif FORK SoC Kconfig
# (SOC_SUPPORT_ARM_MHUV2 / soc/alif/ensemble/Kconfig) -- upstream Zephyr v4.4
# does NOT define or select either, so on the alp-sdk (upstream + hal_alif)
# stack the whole SE path is dark.  alp-sdk, as the integration layer, DEFINES
# both here (the USE_ALIF_HAL_UTIMER precedent below: define what hal_alif only
# selects) so the in-tree MHUv2 driver builds and se_service.c links.

config ARM_MHUV2
	bool "Arm MHUv2 mailbox (IPM) -- SE service transport (vendor-ext, BENCH-UNVERIFIED)"
	default y
	depends on DT_HAS_ARM_MHUV2_ENABLED
	select IPM
	help
	  Arm Message Handling Unit v2 (MHUv2) mailbox driver, exposed through
	  Zephyr's IPM API (compatible "arm,mhuv2"), vendored from the Apache-2.0
	  zephyr_alif fork (drivers/ipm/ipm_arm_mhuv2.c).  Upstream Zephyr v4.4
	  ships only the MHUv1 ipm_mhu.c; this is the v2 mailbox the Ensemble SE
	  service channel uses.  Drives the RTSS <-> SE seservice0r/seservice0s
	  mailboxes in the E8 SoC overlay.  ADR 0017 Tier-2 (INTERIM, task #21).

	  NOTE: hal_alif's se_service.c uses ipm_poll_out()/ipm_poll_in() on its
	  pre-scheduler path.  Those are a fork extension to Zephyr's IPM API absent
	  from upstream v4.4; the alp-sdk carries the small upstreamable Zephyr patch
	  that adds them (zephyr/patches.yml).  Without that patch this driver's
	  .poll_out/.poll_in tail (and se_service.c) will not compile.

config HAS_ALIF_SE_SERVICES
	bool "hal_alif Secure-Enclave service client (vendor-ext, BENCH-UNVERIFIED)"
	default y if DT_HAS_ALIF_SECURE_ENCLAVE_SERVICES_ENABLED
	depends on ARM_MHUV2
	help
	  Compile the Apache-2.0 hal_alif SE service client
	  (se_services/zephyr/src/se_service.c -- gated by hal_alif on
	  CONFIG_HAS_ALIF_SE_SERVICES, which only the fork SoC Kconfig otherwise
	  selects).  Provides se_service_system_get_device_data() (the SoC
	  lifecycle-state / LCS read), se_service_get_run_cfg(), the ES0 boot/run
	  power-manager calls, and se_service_update_stoc().  Needs the SE mailboxes
	  enabled (ARM_MHUV2 + the se_service DT node).  ADR 0017: alp-sdk CONSUMES
	  the hal_alif client (does not reimplement the SE protocol).

# hal_alif (drivers/CMakeLists.txt) gates its UTIMER HW library on
# CONFIG_USE_ALIF_HAL_UTIMER but never DEFINES that symbol -- it only `select`s
# it (under ALIF_BLE_HOST) and uses it in add_subdirectory_ifdef. On upstream
# Zephyr + hal_alif (no fork) nothing defines it, so a bare `select` is a no-op
# and drivers/utimer never builds.  alp-sdk, as the integration layer, defines
# it here so the PWM/counter drivers below can select it to pull in
# modules/hal/alif drivers/utimer (publishes <utimer.h> + compiles utimer.c).
config USE_ALIF_HAL_UTIMER
	bool
	help
	  Pull in the hal_alif UTIMER register library (drivers/utimer).  Selected
	  by PWM_ALIF_UTIMER / COUNTER_ALIF_UTIMER; not user-facing.

config PWM_ALIF_UTIMER
	bool "Alif Ensemble UTIMER PWM (vendor-ext, BENCH-UNVERIFIED)"
	default y
	depends on PWM
	depends on DT_HAS_ALIF_PWM_ENABLED
	select PINCTRL
	select USE_ALIF_HAL_UTIMER
	help
	  Alif Ensemble UTIMER PWM-class driver (compatible "alif,pwm"), written
	  over the hal_alif drivers/utimer register library (USE_ALIF_HAL_UTIMER
	  pulls in modules/hal/alif drivers/utimer).  Upstream Zephyr v4.4 + hal_alif
	  ship no PWM-class device for the Alif UTIMER.  Edge-aligned PWM only;
	  capture/dead-time route through the GD32-bridge backend on V2N.  Not
	  silicon-validated.  Driver: zephyr/drivers/pwm/pwm_alif_utimer.c.

config COUNTER_ALIF_UTIMER
	bool "Alif Ensemble UTIMER counter (vendor-ext, BENCH-UNVERIFIED)"
	default y
	depends on COUNTER
	depends on DT_HAS_ALIF_UTIMER_COUNTER_ENABLED
	select USE_ALIF_HAL_UTIMER
	help
	  Zephyr counter-class driver for the Alif Ensemble UTIMER, built on the
	  hal_alif utimer helpers.  Binds the "alif,utimer-counter" child node and
	  reaches the parent "alif,utimer" (reg / timer-id / clock-frequency / IRQ)
	  via DT_INST_PARENT, mirroring the sibling PWM driver.  Backs the portable
	  alp_counter surface via the alp-counter0 alias.  Not silicon-validated.
	  Driver: zephyr/drivers/counter/counter_alif_utimer.c.

config COUNTER_RTC_SNPS_DW
	bool "Synopsys DesignWare APB RTC counter (vendor-ext, BENCH-UNVERIFIED)"
	default y
	depends on COUNTER
	depends on DT_HAS_SNPS_DW_APB_RTC_ENABLED
	help
	  Zephyr counter-class driver for the Synopsys DesignWare APB RTC
	  (compatible "snps,dw-apb-rtc"), the E8 always-on LPRTC at
	  lprtc@42000000 (IRQ 58, 32768 Hz).  A free-running 32-bit up-counter
	  (CCVR) with ONE compare/alarm channel (CMR) -- NOT a calendar RTC, so it
	  does NOT satisfy the alp_rtc_* calendar surface as-is (that needs a
	  counter->calendar shim, still TBD; see the aen-rtc-regcheck README).
	  Vendored Tier-2 from the Apache-2.0 zephyr_alif fork
	  (drivers/counter/counter_dw_rtc.{c,h}); upstream Zephyr v4.4 ships no
	  snps,dw-apb-rtc driver (counter_dw_timer.c is the DIFFERENT snps,dw-timers
	  DW APB Timers IP).  Backs the portable alp_counter surface via the
	  alp-counter alias.  Not silicon-validated.  Driver:
	  zephyr/drivers/counter/counter_dw_rtc.c.

config COUNTER_ALIF_LPTIMER
	bool "Alif Ensemble LPTIMER counter (vendor-ext, BENCH-UNVERIFIED)"
	default y
	depends on COUNTER
	depends on DT_HAS_ALIF_LPTIMER_ENABLED
	help
	  Zephyr counter-class driver for the Alif Ensemble LPTIMER (low-power
	  timer), compatible "alif,lptimer".  On the E8 SoM this binds the
	  always-on lptimer@42001000 block: four independent 32-bit DOWN-counters
	  (channels 0..3, IRQs 60..63), each clocked from the VBAT-domain
	  low-frequency source (32 kHz / 128 kHz / external / cascade) and firing
	  an underflow interrupt on count-reaches-zero.  Free-running mode loads
	  0xFFFFFFFF and counts down; get_value() returns the decrementing
	  CURRENTVAL.  A DISTINCT always-on IP from the LPRTC (COUNTER_RTC_SNPS_DW,
	  lprtc@42000000) and the UTIMER counter (COUNTER_ALIF_UTIMER).  Backs the
	  portable alp_counter surface via the alp-counter alias.
	  ADR 0017 Tier-1.5 -- a thin in-tree Zephyr driver written directly over
	  the memory-mapped LPTIMER registers; the alifsemi/zephyr_alif fork ships
	  no Zephyr LPTIMER driver and no "alif,lptimer" binding, and hal_alif
	  exposes no Zephyr device for it, so there is no Tier-2 fork path to
	  consume.  Not silicon-validated.  Driver:
	  zephyr/drivers/counter/counter_alif_lptimer.c.

