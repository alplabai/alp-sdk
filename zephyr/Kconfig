config ALP_SDK_PERIPH_TMU
	bool "Enable <alp/tmu.h> wrapper (CORDIC math accelerator surface)"
	default y
	help
	  Compile the TMU registry sources -- src/tmu_dispatch.c plus
	  src/backends/tmu/zephyr_drv.c (and, when
	  ALP_SDK_TMU_SW_FALLBACK=y, src/backends/tmu/sw_fallback.c).
	  Provides alp_tmu_sin / cos / tan / atan / atan2 / sqrt / log /
	  exp / sinh / cosh / tanh / hypot on top of either the V2N
	  supervisor's GD32G5 TMU (CORDIC) accelerator (when
	  CONFIG_ALP_SDK_V2N_SUPERVISOR=y) or libm directly (every other
	  SoM).  The customer-facing header is SoM-agnostic; the V2N
	  dispatch is internal.

	  After Slice 4d the dispatcher caches the selected backend's
	  ops vtable on first call -- TMU is handle-less, so there is no
	  per-call selector cost on the hot path.  See
	  ALP_SDK_TMU_SW_FALLBACK for the software-backend opt-in.

config ALP_SDK_TMU_SW_FALLBACK
	bool "Software TMU fallback (libm)"
	depends on ALP_SDK && ALP_SDK_PERIPH_TMU
	default y if BOARD_NATIVE_SIM || ARCH_POSIX
	default n
	help
	  Compiles a libm-direct TMU backend that registers as a wildcard
	  at priority 0.  For native_sim build / test and for any SoM
	  whose dedicated TMU backend is not linked into the build --
	  every alp_tmu_* primitive then routes through sinf / cosf /
	  ... and returns ALP_OK.  Marginal cost is ~24 bytes for the ops
	  vtable when the rest of the firmware already pulls in libm.

config ALP_SDK_DSP
	bool "Enable <alp/dsp.h> standalone DSP-chain API"
	default n
	help
	  Compile the DSP registry sources -- src/dsp_dispatch.c plus
	  src/backends/dsp/sw_fallback.c.  Provides the standalone
	  alp_dsp_chain_* surface for in-RAM FIR / IIR / window /
	  FFT processing against int16 mV-scale buffers.  Uses
	  CMSIS-DSP when ALP_HAS_CMSIS_DSP=1; otherwise falls back
	  to a portable-C math kernel set (naive FIR convolution,
	  direct-form-1 biquad cascade, radix-2 Cooley-Tukey FFT).

	  Slice 4d migration: the legacy OS-agnostic body that lived at
	  src/common/dsp_chain.c is now the sw_fallback backend.  There
	  is no separate zephyr_drv backend today -- the V2N GD32G5
	  HW-FFT surfaces via wave-2's alp_adc_filter_t /
	  alp_adc_spectrum_t in <alp/adc.h>, not through this
	  standalone class.  Future HW backends (V2N standalone-FFT,
	  AEN once the wave-2 bridge stabilises) pre-empt the
	  sw_fallback transparently when registered at higher priority.

	  Static cost: ~30 KB for the chain pool (two concurrent
	  chains sized to ALP_DSP_MAX_FIR_TAPS / IIR_SECTIONS /
	  FFT_POINTS).  Pulls in math.h transcendentals (sinf, cosf,
	  sqrtf, lrintf).  Off by default to keep tight firmware
	  images lean.

config ALP_SDK_POWER
	bool "Enable <alp/power.h> system-power-mode surface"
	default y
	help
	  Compile src/power_dispatch.c + src/backends/power/zephyr_stub.c
	  (Slice 7 -- registry migration).  Provides the portable
	  alp_power_open / configure_wake_source / request_sleep /
	  close surface that backends route either through Zephyr's
	  pm_policy_* primitives (off-V2N) or through the GD32G553
	  supervisor's CMD_POWER_MODE_SET opcode (0x28) on V2N.

	  Slice 7 ships the surface on top of the backend registry with
	  a wildcard stub backend: open() returns a valid handle and
	  configure_wake_source() succeeds silently, but request_sleep()
	  returns ALP_ERR_NOT_IMPLEMENTED.  The dispatcher still enforces
	  the legacy INVAL pre-checks (RUN-mode, invalid enum,
	  no-wake-source-and-no-timer).  The per-backend HAL bodies
	  (Zephyr pm_state tables on AEN + the GD32 firmware-side
	  wake-handler + the supervisor re-init state machine) land in
	  follow-up commits per issue #22.

config ALP_SDK_CAMERA_ZEPHYR_VIDEO
	bool "Compile the real Zephyr drivers/video/ camera backend"
	depends on VIDEO
	default y
	help
	  Compile src/backends/camera/zephyr_video.c, the portable
	  camera backend that wraps Zephyr's drivers/video/ class
	  (video_get_caps + video_set_format + video_buffer_alloc +
	  video_enqueue / video_dequeue + video_stream_start / _stop)
	  into the alp_camera_* vtable.  Registered at silicon_ref="*"
	  priority 50 so it always wins over the zephyr_stub fallback
	  (priority 0) on builds that link Zephyr's video subsystem;
	  loses to vendor-specific real backends (V2N N44 ISP at
	  priority 100 on its silicon_ref) where present.

	  configure_isp returns ALP_ERR_NOSUPPORT -- the portable
	  Zephyr video class has no in-line ISP surface; vendor
	  backends ride on top to add the configure_isp op.

	  Depends on CONFIG_VIDEO so the video_* symbols are visible
	  at link time.

config ALP_SDK_CAMERA_V2N_N44_ISP
	bool "Compile the Renesas RZ/V2N N44 ISP-aware camera backend"
	depends on VIDEO
	default y if ALP_SOC_RENESAS_RZV2N_N44
	help
	  Compile src/backends/camera/v2n_n44_isp.c, the V2N N44
	  ISP-aware camera backend.  Registered at
	  silicon_ref="renesas:rzv2n:n44" priority 100 -- always
	  wins selection over the wildcard zephyr_video + zephyr_stub
	  on V2N silicon.

	  Sensor pipeline (open / start / stop / capture / release /
	  close) routes through the same Zephyr drivers/video/ API
	  the portable zephyr_video backend uses; configure_isp
	  validates + latches the requested config and returns
	  ALP_OK -- the matching MMIO writes against the V2N N44
	  ISP control registers land when the Renesas SoC port
	  grows the ISP driver per the V2N Hardware User's Manual
	  r01uh1003ej §18 "Image Signal Processor".

	  Off on non-V2N builds; the zephyr_video backend remains
	  the default on every other supported SoC.

config ALP_SDK_CAMERA_ALIF_ISP
	bool "Compile the Alif Ensemble ISP-Pico camera backend (OPT-IN)"
	depends on VIDEO
	depends on VIDEO_ISP_VSI
	default n
	help
	  Compile src/backends/camera/alif_isp_pico.c, the Alif Ensemble
	  ISP-Pico-aware camera backend.  Registered at
	  silicon_ref="alif:ensemble:e8" priority 100 -- wins selection
	  over the wildcard zephyr_video + zephyr_stub on E8 silicon when
	  enabled.  Mirrors the V2N N44 ISP backend (sensor pipeline routes
	  through the portable Zephyr v4.4 video API; configure_isp latches
	  the requested config).

	  OPT-IN, default n -- it depends on CONFIG_VIDEO_ISP_VSI, which
	  links the hal_alif libisp Vivante blob.  See the FLAGGED hal_alif
	  version mismatch under VIDEO_ISP_VSI: the vendored 2026 isp_pico.c
	  needs a newer hal_alif wrapper than the locally vendored 2025 one,
	  so the ISP driver compiles but does NOT link against the local
	  wrapper.  Bump the hal_alif wrapper before enabling.  Task #21.

config ALP_SDK_POWER_PM_POLICY
	bool "Compile the real Zephyr pm_policy_* power backend"
	depends on ALP_SDK_POWER
	depends on PM
	default y
	help
	  Compile src/backends/power/zephyr_pm_policy.c, which uses
	  Zephyr's pm_policy_state_lock_get / pm_policy_state_lock_put
	  to translate alp_power_request_sleep into a constraint over
	  the active per-SoC pm_state table.  Registered as
	  silicon_ref="*" at priority 100 so it always wins over the
	  zephyr_stub fallback (priority 0) on builds that link the PM
	  subsystem.

	  Off on builds without CONFIG_PM (where the pm_policy_* symbols
	  vanish); the zephyr_stub at priority 0 keeps alp_power_open
	  succeeding so application setup code keeps linking unchanged.

config ALP_SDK_POWER_EXT_RENESAS
	bool "Compile the Renesas V2N power vendor-extension body"
	depends on ALP_SDK_POWER
	depends on ALP_SDK_V2N_SUPERVISOR
	default y if ALP_SOC_RENESAS_RZV2N_N44
	help
	  Compile src/backends/ext/renesas/power.c, which implements
	  the alp_renesas_power_supervisor_mode_set vendor-extension
	  surface declared in <alp/ext/renesas/power.h>.  Routes through
	  the GD32G553 supervisor's CMD_POWER_MODE_SET opcode (0x28) via
	  the existing v2n_supervisor singleton mutex; no new bus plumbing
	  introduced.

	  Off on non-V2N builds; the header alone (always installed) is
	  enough for portable apps to compile-test against the symbol.

config ALP_SDK_GPU2D
	bool "Enable <alp/gpu2d.h> 2D graphics accelerator surface"
	default y
	help
	  Compile src/gpu2d_dispatch.c, the class dispatcher behind the
	  portable alp_gpu2d_open / fill_rect / blit / blend / close
	  surface.  The actual ops come from a backend: the portable
	  software fallback (ALP_SDK_GPU2D_SW_FALLBACK) or the Alif
	  D/AVE 2D real backend (ALP_SDK_GPU2D_ALIF_DAVE2D) on AEN
	  silicon.

	  Surfaces the headline gap the Alif Ensemble feature audit
	  (internal AEN feature audit) called out: customers
	  migrating from V2N to AEN otherwise silently lose 2D
	  acceleration because Zephyr has no portable `gpu` / `2d`
	  driver class.

config ALP_SDK_GPU2D_SW_FALLBACK
	bool "Portable software 2D fallback (real CPU fill/blit/blend)"
	depends on ALP_SDK_GPU2D
	default y
	help
	  Compile src/backends/gpu2d/sw_fallback.c, a REAL pure-C 2D
	  implementation registered as the wildcard "*" at priority 0.
	  It does actual pixel work -- solid fill, format-converting
	  blit, and the four blend modes (REPLACE / SRC_OVER /
	  ADDITIVE / MULTIPLY) over caller-owned framebuffer memory --
	  with no hardware or vendor dependency, so it builds and is
	  unit-tested on native_sim.

	  Always loses backend selection to a real silicon backend
	  (the Alif D/AVE 2D backend at priority 100 on AEN parts), but
	  is the backend that serves the API on every SoM without an
	  on-die 2D engine (V2N, i.MX 93) and on native_sim.  Default y
	  so alp_gpu2d_open() succeeds portably everywhere.

config ALP_SDK_GPU2D_ALIF_DAVE2D
	bool "Compile the Alif D/AVE 2D real backend (bench-unverified)"
	depends on ALP_SDK_GPU2D
	default n
	help
	  Compile src/backends/gpu2d/alif_dave2d.c, the AEN-family
	  D/AVE 2D backend.  Registers one entry per
	  alif:ensemble:e1..e8 at priority 100, driving the engine
	  through the documented d2_* API of the proprietary Alif
	  D/AVE 2D driver pack (AlifSemiconductor::Dave2DDriver).

	  Off by default: it can only build when the Dave2D pack is on
	  the include path (the SDK never vendors the pack), and it is
	  NOT silicon-validated -- the call sequencing and format /
	  blend-mode mappings are authored against the documented API
	  and await AEN bench bring-up (issue #24).  It cannot build on
	  native_sim; leave it off there and let the software fallback
	  serve the surface.  ADDITIVE / MULTIPLY blends have no
	  documented single-pass D/AVE 2D mapping and return NOSUPPORT
	  from this backend, so portable code that needs them falls
	  back to the software path.

config ALP_SDK_UPDATE_LOG
	bool "Enable <alp/update_log.h> firmware-update audit-log surface (experimental)"
	default n
	help
	  Compile the portable update-log surface: src/update_log_dispatch.c,
	  the pure engine (src/update_log/engine.c + sha256.c), and the
	  software tamper-evident tier (src/backends/update_log/sw_tier.c).

	  The software tier works on every target and reports assurance
	  SW_TAMPER_EVIDENT. A hardware-enforced backend (TF-M Protected
	  Storage + monotonic counter) is a later slice; until it lands the
	  surface stays experimental. See docs/abi-markers.md.

