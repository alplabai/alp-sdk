config ALP_SDK_CHIP_MURATA_LBEE5HY2FY
	bool "Murata LBEE5HY2FY-922 Wi-Fi 6 + BLE 5.4 module GPIO surface"
	depends on GPIO
	help
	  Compile chips/murata_lbee5hy2fy/murata_lbee5hy2fy.c.  Manages
	  the five side-channel GPIO lines (BT_REG_ON, WL_REG_ON,
	  BT_HOST_WAKE, WL_HOST_WAKE, BT_DEV_WAKE) of the Murata
	  LBEE5HY2FY-922 module on the V2N SoM.  Air-side traffic
	  (Wi-Fi SDIO, BT UART, BT I2S) lives in the host OS stack
	  (brcmfmac + BlueZ + ALSA on Linux); this driver is the thin
	  power-and-wake glue around it.  On V2N the REG_ON lines are
	  GD32-side; the driver takes callbacks for them so the caller
	  can route via gd32g553_gpio_write or a direct local-GPIO
	  shim on carriers that wire REG_ON to the host.

config ALP_SDK_CHIP_DEEPX_DXM1
	bool "DEEPX DX-M1 NPU host-side bring-up sequencer (V2N-M1)"
	depends on GPIO
	select ALP_SDK_CHIP_PI3DBS12212
	help
	  Compile chips/deepx_dxm1/deepx_dxm1.c.  Host-side glue that
	  sequences M1_RESET (Renesas PA6) + the passive PCIe muxes
	  (chips/pi3dbs12212/) before the Linux DEEPX kernel driver
	  (dx_rt_npu_linux_driver) takes over.  Only meaningful on
	  V2N-M1; the underlying DEEPX silicon is NOT populated on
	  V2N base.

config ALP_SDK_CHIP_GD32_SWD
	bool "GD32G553 host-driven SWD bit-bang controller (V2N flash + recovery)"
	depends on GPIO
	help
	  Compile chips/gd32_swd/gd32_swd.c.  Bit-banged SWD controller
	  that lets the Renesas RZ/V2N host reflash the on-module
	  GD32G553MEY7TR companion MCU using three GPIO lines
	  (SWDIO + SWCLK + optional NRST) routed back to the V2N pads
	  per the 2026-05-12 hardware decision.  Reference algorithm
	  follows Arm DDI 0316C (ADIv5) + GD32G553 User Manual Rev 1.2
	  §3 (FMC).  Pulls in no vendor SDK.  The driver exposes the
	  SWD packet layer + DPIDR read + Cortex-M33 halt + FMC erase/
	  write/verify + reset_and_run; pad assignments and silicon
	  exercise still TBD on V2N (see metadata/chips/gd32_swd.yaml).

