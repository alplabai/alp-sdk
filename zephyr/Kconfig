# ALP SDK Kconfig fragment exposed to Zephyr applications.

config ALP_SDK
	bool "ALP SDK"
	help
	  Enable the ALP SDK on Zephyr.  When set, the SDK's Zephyr
	  backend is compiled and <alp/...> headers are added to the
	  application include path.

if ALP_SDK

# Active SoC selection — drives <alp/soc_caps.h> capability checks.
# When no choice is selected the SDK's runtime validation is permissive
# (default macros = UINT16_MAX); selecting a SoC enables strict
# rejection of configs that exceed its documented hardware caps.
# See docs/adr/0002-error-mechanism.md.

choice
	prompt "Active SoC capability profile (for runtime config validation)"
	default ALP_SOC_NONE
	help
	  Select the SoM's SoC so the SDK can reject runtime configs
	  that exceed its documented caps (e.g. a 16-bit ADC config
	  on a 12-bit SoC).  alp-studio's generated build sets this
	  automatically; hand-written firmware can pick manually.

config ALP_SOC_NONE
	bool "None — capability checks pass through"

config ALP_SOC_ALIF_ENSEMBLE_E3
	bool "Alif Ensemble E3 (alif:ensemble:e3)"

config ALP_SOC_ALIF_ENSEMBLE_E4
	bool "Alif Ensemble E4 (alif:ensemble:e4 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E5
	bool "Alif Ensemble E5 (alif:ensemble:e5 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E6
	bool "Alif Ensemble E6 (alif:ensemble:e6 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E7
	bool "Alif Ensemble E7 (alif:ensemble:e7)"

config ALP_SOC_ALIF_ENSEMBLE_E8
	bool "Alif Ensemble E8 (alif:ensemble:e8 — preliminary)"

config ALP_SOC_RENESAS_RZV2N_N44
	bool "Renesas RZ/V2N R9A09G056N44 (renesas:rzv2n:n44)"

config ALP_SOC_DEEPX_DX_M1
	bool "DEEPX DX-M1 NPU (deepx:dx:m1)"

config ALP_SOC_NXP_IMX9_IMX93
	bool "NXP i.MX 93 (nxp:imx9:imx93 — preliminary)"

endchoice

config ALP_SDK_MAX_I2C_HANDLES
	int "Maximum concurrent alp_i2c_t handles"
	default 4

config ALP_SDK_MAX_SPI_HANDLES
	int "Maximum concurrent alp_spi_t handles"
	default 4

config ALP_SDK_MAX_UART_HANDLES
	int "Maximum concurrent alp_uart_t handles"
	default 4

config ALP_SDK_UART_RX_RINGBUF
	bool "Byte-granular RX ring buffer (LwRB) for <alp/peripheral.h> UART"
	default n
	depends on SERIAL && UART_INTERRUPT_DRIVEN
	help
	  Enable the alp_uart_rx_ringbuf_* helpers in src/zephyr/peripheral_uart.c.
	  When attached to an open alp_uart_t, the SDK registers an
	  interrupt-driven RX callback that drains the controller's FIFO
	  into a caller-supplied LwRB-backed ring; consumer code drains
	  bytes via alp_uart_rx_ringbuf_pop without polling.  Backed by
	  the SDK-internal LwRB stub (vendors/lwrb/) until the v0.4
	  extras-v04 west group flips upstream LwRB in.  When OFF the
	  helpers return NULL / ALP_ERR_NOSUPPORT so apps can link
	  cleanly.

config ALP_SDK_MAX_UART_RX_RINGBUF_HANDLES
	int "Maximum concurrent alp_uart_rx_ringbuf_t handles"
	default 4
	depends on ALP_SDK_UART_RX_RINGBUF
	help
	  Pool size for ring-buffer state structs.  One handle per
	  attached UART port; raise if more than four ports stream RX
	  through the helper concurrently.

config ALP_SDK_MAX_GPIO_HANDLES
	int "Maximum concurrent alp_gpio_t handles"
	default 16

config ALP_SDK_MAX_PWM_HANDLES
	int "Maximum concurrent alp_pwm_t handles"
	default 8

config ALP_SDK_MAX_ADC_HANDLES
	int "Maximum concurrent alp_adc_t handles"
	default 8

config ALP_SDK_MAX_COUNTER_HANDLES
	int "Maximum concurrent alp_counter_t handles"
	default 4

config ALP_SDK_MAX_QENC_HANDLES
	int "Maximum concurrent alp_qenc_t handles"
	default 4

config ALP_SDK_MAX_I2S_HANDLES
	int "Maximum concurrent alp_i2s_t handles"
	default 2

config ALP_SDK_MAX_CAN_HANDLES
	int "Maximum concurrent alp_can_t handles"
	default 4

config ALP_SDK_MAX_RTC_HANDLES
	int "Maximum concurrent alp_rtc_t handles"
	default 2

config ALP_SDK_MAX_WDT_HANDLES
	int "Maximum concurrent alp_wdt_t handles"
	default 2

# Per-class peripheral wrappers — opt-in so apps that don't use a
# given Zephyr subsystem don't link the wrapper.  Each defaults on
# when its underlying Zephyr driver class is enabled.

config ALP_SDK_PERIPH_PWM
	bool "Enable <alp/pwm.h> wrapper"
	default y if PWM
	depends on PWM
	help
	  Compile src/zephyr/peripheral_pwm.c.  Provides alp_pwm_*
	  on top of Zephyr's pwm_* API.  Resolves channel_id via the
	  alp-pwm0..alp-pwm7 DT aliases.

config ALP_SDK_PERIPH_ADC
	bool "Enable <alp/adc.h> wrapper"
	default y if ADC
	depends on ADC
	help
	  Compile src/zephyr/peripheral_adc.c.  Provides alp_adc_*
	  on top of Zephyr's adc_* API.  Resolves channel_id via the
	  alp-adc0..alp-adc7 DT aliases (each pointing at a node with
	  an io-channels phandle and the standard ADC channel-config
	  properties).

config ALP_SDK_PERIPH_COUNTER
	bool "Enable <alp/counter.h> free-running counter wrapper"
	default y if COUNTER
	depends on COUNTER
	help
	  Compile src/zephyr/peripheral_counter.c.  Provides
	  alp_counter_* on top of Zephyr's counter_* API.  Resolves
	  counter_id via the alp-counter0..alp-counter3 DT aliases.

config ALP_SDK_PERIPH_QENC
	bool "Enable <alp/counter.h> quadrature-decoder wrapper"
	default y if SENSOR
	depends on SENSOR
	help
	  Compile src/zephyr/peripheral_qenc.c.  Provides alp_qenc_*
	  on top of Zephyr's sensor_* API (SENSOR_CHAN_ROTATION).
	  Resolves encoder_id via alp-qenc0..alp-qenc3 DT aliases.

config ALP_SDK_PERIPH_I2S
	bool "Enable <alp/i2s.h> wrapper"
	default y if I2S
	depends on I2S
	help
	  Compile src/zephyr/peripheral_i2s.c.  Provides alp_i2s_*
	  on top of Zephyr's i2s_* API with a 2-block ping-pong
	  memory slab.

config ALP_SDK_PERIPH_CAN
	bool "Enable <alp/can.h> wrapper (classic CAN + CAN-FD)"
	default y if CAN
	depends on CAN
	help
	  Compile src/zephyr/peripheral_can.c.  Provides alp_can_*
	  on top of Zephyr's can_* API.  CAN-FD only when
	  CONFIG_CAN_FD_MODE=y.

config ALP_SDK_PERIPH_RTC
	bool "Enable <alp/rtc.h> wrapper"
	default y if RTC
	depends on RTC
	help
	  Compile src/zephyr/peripheral_rtc.c.  Provides alp_rtc_*
	  on top of Zephyr's rtc_* API.

config ALP_SDK_PERIPH_WDT
	bool "Enable <alp/wdt.h> wrapper"
	default y if WATCHDOG
	depends on WATCHDOG
	help
	  Compile src/zephyr/peripheral_wdt.c.  Provides alp_wdt_*
	  on top of Zephyr's wdt_* API.

# IoT (Wi-Fi station + MQTT) — v0.2 deliverable.  When OFF the
# wrapper still compiles and honours the v0.1 NULL-with-NOSUPPORT
# contract so apps can link cleanly against <alp/iot.h>.

config ALP_SDK_IOT_WIFI
	bool "Real Wi-Fi station via Zephyr wifi_mgmt"
	default y if WIFI && NET_MGMT
	depends on WIFI && NET_MGMT
	help
	  Enable the real wifi_mgmt-backed alp_wifi_* implementation.
	  Requires CONFIG_WIFI=y and a wifi-management subsystem (e.g.
	  CONFIG_WIFI_NM_WPA_SUPPLICANT=y on AEN-Zephyr).  When OFF
	  alp_wifi_open() returns NULL with alp_last_error() =
	  ALP_ERR_NOSUPPORT.

config ALP_SDK_IOT_MQTT
	bool "Real MQTT client via Zephyr mqtt_client"
	default y if MQTT_LIB
	depends on MQTT_LIB && NET_TCP
	help
	  Enable the real mqtt_client-backed alp_mqtt_* implementation.
	  Requires CONFIG_MQTT_LIB=y + CONFIG_NET_TCP=y.  When OFF
	  alp_mqtt_open() returns NULL with alp_last_error() =
	  ALP_ERR_NOSUPPORT.

config ALP_SDK_MAX_WIFI_HANDLES
	int "Maximum concurrent alp_wifi_t handles"
	default 1
	help
	  Wi-Fi station is single-instance on every E1M-conformant SoM
	  (one radio per module).  Override only if you intentionally
	  hold multiple handles in flight (e.g. open + cleanup overlap).

config ALP_SDK_MAX_MQTT_HANDLES
	int "Maximum concurrent alp_mqtt_t handles"
	default 2
	help
	  Number of concurrent MQTT clients the wrapper can keep open.
	  Each handle reserves CONFIG_ALP_SDK_MQTT_BUF_SIZE * 3 bytes
	  for its rx / tx / topic scratch.

config ALP_SDK_MQTT_BUF_SIZE
	int "Per-client MQTT rx / tx scratch buffer size"
	default 256
	help
	  Allocated three times per alp_mqtt_t (rx, tx, topic).  Sized
	  for v0.2's JSON-payload reference apps; raise for larger
	  publish bodies or longer topic strings.

# Audio (PDM input + I2S output) -- v0.2 deliverable.  When OFF the
# wrapper still compiles and honours the v0.1 NULL-with-NOSUPPORT
# contract.

config ALP_SDK_AUDIO_IN
	bool "Real PDM input via Zephyr audio_dmic"
	default y if AUDIO_DMIC
	depends on AUDIO_DMIC
	help
	  Enable the real audio_dmic-backed alp_audio_in_* implementation.
	  Resolves the studio-supplied peripheral_id via the alp-pdm0 /
	  alp-pdm1 DT aliases.  Includes the ALP DSP chain (DC-block in
	  v0.2; AGC + resample in v0.3).  When OFF alp_audio_in_open()
	  returns NULL with alp_last_error() = ALP_ERR_NOSUPPORT.

config ALP_SDK_AUDIO_OUT
	bool "Real I2S output via alp_i2s_*"
	default y if I2S
	depends on I2S
	help
	  Enable the real alp_i2s_*-backed alp_audio_out_* implementation.
	  Delegates straight to the v0.2 <alp/i2s.h> wrapper plus a
	  software volume scale.  Reuses the alp_i2s_t handle pool.
	  When OFF alp_audio_out_open() returns NULL with NOSUPPORT.

config ALP_SDK_MAX_AUDIO_IN_HANDLES
	int "Maximum concurrent alp_audio_in_t handles"
	default 1
	help
	  PDM input is single-stream on most E1M-conformant SoMs;
	  override only if the SoC genuinely exposes multiple PDM
	  controllers and the app holds them concurrently.

config ALP_SDK_MAX_AUDIO_OUT_HANDLES
	int "Maximum concurrent alp_audio_out_t handles"
	default 1

config ALP_SDK_AUDIO_BLOCK_BYTES
	int "Maximum block size for an alp_audio_in_t (bytes)"
	default 4096
	help
	  Per-handle slab buffer is sized at this * the slab block
	  count, statically, so the wrapper avoids k_malloc.  4096 B
	  fits 1024 mono S16 frames or 512 stereo S16 frames -- ~64
	  ms at 16 kHz mono, comfortably above the typical 5-10 ms
	  block latency.

config ALP_SDK_AUDIO_IN_SLAB_BLOCKS
	int "DMA blocks per audio_in slab (>= 2)"
	default 4
	help
	  Two is the minimum (one in-flight to the driver, one drained
	  by the caller).  Four is a comfortable default; raise for
	  apps that take longer than the block period to drain.

# Inference (<alp/inference.h>) -- v0.2 deliverable, the wrapper
# always compiles and falls back to ALP_ERR_NOSUPPORT when no
# backend is enabled.

config ALP_SDK_INFERENCE_TFLM
	bool "TensorFlow Lite Micro backend for <alp/inference.h>"
	default n
	depends on TENSORFLOW_LITE_MICRO && CPP
	help
	  Enable the TFLM-backed executor (src/zephyr/inference_tflm.cpp).
	  Wraps tflite::MicroInterpreter + tflite::MicroMutableOpResolver
	  for both CPU (reference kernels) and Ethos-U
	  (CONFIG_ALP_SDK_INFERENCE_ETHOS_U) backends.  Pulls in TFLM via
	  the upstream tflite-micro Zephyr module (see west.yml's
	  name-allowlist).  When OFF, alp_inference_open() returns NULL
	  with ALP_ERR_NOSUPPORT regardless of the backend selector.

config ALP_SDK_INFERENCE_DRPAI
	bool "Renesas DRP-AI3 backend for <alp/inference.h>"
	default n
	depends on SOC_SERIES_RZV2N || SOC_FAMILY_RENESAS_RZ
	help
	  Wires the alp_inference_drpai_* hooks (src/zephyr/inference_drpai.c)
	  into the dispatcher.  Real impl bridges Renesas's DRP-AI
	  translator runtime; v0.3 ships the dispatch routing only,
	  v0.4 fills the bodies once the vendor pack lands in CI.
	  When the v0.4 work completes this defaults y on V2N targets.

config ALP_SDK_INFERENCE_ETHOS_U
	bool "Wire Arm Ethos-U op resolver (Vela-compiled models)"
	default y if ALP_SDK_INFERENCE_TFLM && (SOC_SERIES_ENSEMBLE_E7 || ALP_SOC_NXP_IMX9_IMX93)
	depends on ALP_SDK_INFERENCE_TFLM
	help
	  Adds the AddEthosU() registration so Vela-compiled .tflite
	  files can dispatch their custom ETHOS-U operator to the NPU.
	  Covers Ethos-U55 on Alif Ensemble (AEN family) and Ethos-U65 on
	  NXP i.MX 93's Cortex-M33.  Variant selection happens via
	  ALP_SDK_INFERENCE_ETHOS_U_N93 (i.MX 93) -- the SDK source path
	  is identical between U55 and U65; only the Vela compilation
	  target + Arm driver build differ.  Off-target builds (CPU-only)
	  must turn this off.

config ALP_SDK_INFERENCE_ETHOS_U_N93
	bool "Target the i.MX 93 Ethos-U65 (vs the AEN family's Ethos-U55)"
	default y if ALP_SOC_NXP_IMX9_IMX93
	depends on ALP_SDK_INFERENCE_ETHOS_U
	help
	  Compile the i.MX 93 + Ethos-U65 per-variant config layer
	  (src/zephyr/inference_ethosu_n93.c).  Anchors the v0.4 NPU
	  attach hook + variant-name helper that downstream code uses
	  to keep Vela target consistency.  Models compiled for U55
	  do not run on U65 and vice versa; this flag plus the SoC
	  choice above tells the build which Vela target the app
	  expects.

# BLE (<alp/ble.h>) -- v0.3 deliverable.  Same NOSUPPORT contract
# when CONFIG_BT is off so apps can link cleanly under native_sim.

config ALP_SDK_BLE
	bool "Real Bluetooth host stack via Zephyr bt"
	default y if BT
	depends on BT
	help
	  Enables the wifi_mgmt + GATT-server peripheral path and the
	  scan + connect central path on top of Zephyr's `bt` host
	  stack.  Requires CONFIG_BT=y plus CONFIG_BT_PERIPHERAL=y
	  and/or CONFIG_BT_CENTRAL=y for the matching role.  When OFF
	  alp_ble_open() returns NULL with ALP_ERR_NOSUPPORT.

config ALP_SDK_SECURITY
	bool "Real MbedTLS PSA Crypto for <alp/security.h>"
	default y if MBEDTLS_PSA_CRYPTO_C
	depends on MBEDTLS && MBEDTLS_PSA_CRYPTO_C
	help
	  Wires the alp_hash_* / alp_aead_* / alp_random_bytes
	  surface onto MbedTLS's PSA Crypto API.  PSA picks the
	  active SoC's hardware accelerator transparently when the
	  vendor's driver layer registers it (Alif Ensemble crypto
	  subsystem, Renesas RZ/V2N RSIP).  When OFF the wrapper
	  falls back to NULL / NOSUPPORT.

config ALP_SDK_MPROC
	bool "Real multi-processor IPC for <alp/mproc.h>"
	default y if MBOX
	depends on MBOX
	help
	  Wires the alp_mbox_* / alp_shmem_* / alp_hwsem_*
	  primitives onto Zephyr's MBOX driver class (Alif's MHU is
	  registered as a Zephyr mbox device on AEN).  Per-SoC hwsem
	  + DT-anchored shared-memory bindings finalise in v0.3.x;
	  the wrapper falls back to NOSUPPORT for those paths until
	  the EVK overlay declares the regions.

config ALP_SDK_MPROC_NANOPB_FRAMING
	bool "Frame alp_mbox_send payloads through the IPC envelope"
	default n
	help
	  Wraps every alp_mbox_send payload in the IPC envelope
	  declared in src/common/proto/alp_mproc_frame.h before
	  handing it to the Zephyr mbox driver, and unwraps inbound
	  frames before dispatching alp_mbox_msg_cb_t.  The placeholder
	  binary format is intentionally NOT compatible with the v0.4-
	  final protobuf wire generated by nanopb against
	  metadata/protos/alp_mproc.proto -- this option exists so the
	  framing code path is exercised before the nanopb generator
	  pack lands.  Both ends of an IPC channel must agree on the
	  flag value; mixing framed + raw firmwares is a wire-protocol
	  break.

	  Has runtime effect only when ALP_SDK_MPROC is also on (the
	  framing code in mproc_zephyr.c is gated on both flags).
	  Compile-tested standalone so the encode/decode helpers can
	  be exercised under native_sim without a real mbox device.

config ALP_SDK_MPROC_FRAME_MAX_BYTES
	int "Maximum framed envelope size (bytes)"
	default 512
	depends on ALP_SDK_MPROC_NANOPB_FRAMING
	help
	  Static scratch buffer reserved per alp_mbox_t for the framed
	  payload.  Header overhead is ALP_MPROC_FRAME_HEADER_BYTES (12)
	  so the usable payload ceiling is this value minus 12 bytes.
	  Raise for larger RPC requests / responses.

config ALP_SDK_USB
	bool "Real USB device stack for <alp/usb.h>"
	default y if USB_DEVICE_STACK
	depends on USB_DEVICE_STACK
	help
	  Wires alp_usb_device_open / enable / disable on top of
	  Zephyr's USB device stack.  Per-class endpoint
	  read/write (CDC-ACM, MSC, HID) lands in v0.3.x once
	  the per-class wrappers are wired.  Host role lands
	  alongside the SoC's USB-host controller driver.

config ALP_SDK_MAX_USB_DEV_HANDLES
	int "Maximum concurrent alp_usb_dev_t handles"
	default 1
	help
	  USB device role is single-instance on every E1M-conformant
	  SoM (one USB controller per module).

