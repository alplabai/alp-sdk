# ALP SDK Kconfig fragment exposed to Zephyr applications.

config ALP_SDK
	bool "ALP SDK"
	help
	  Enable the ALP SDK on Zephyr.  When set, the SDK's Zephyr
	  backend is compiled and <alp/...> headers are added to the
	  application include path.

if ALP_SDK

# Active SoC selection — drives <alp/soc_caps.h> capability checks.
# When no choice is selected the SDK's runtime validation is permissive
# (default macros = UINT16_MAX); selecting a SoC enables strict
# rejection of configs that exceed its documented hardware caps.
# See docs/adr/0002-error-mechanism.md.

choice
	prompt "Active SoC capability profile (for runtime config validation)"
	default ALP_SOC_NONE
	help
	  Select the SoM's SoC so the SDK can reject runtime configs
	  that exceed its documented caps (e.g. a 16-bit ADC config
	  on a 12-bit SoC).  alp-studio's generated build sets this
	  automatically; hand-written firmware can pick manually.

config ALP_SOC_NONE
	bool "None — capability checks pass through"

config ALP_SOC_ALIF_ENSEMBLE_E3
	bool "Alif Ensemble E3 (alif:ensemble:e3)"

config ALP_SOC_ALIF_ENSEMBLE_E4
	bool "Alif Ensemble E4 (alif:ensemble:e4 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E5
	bool "Alif Ensemble E5 (alif:ensemble:e5 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E6
	bool "Alif Ensemble E6 (alif:ensemble:e6 — preliminary)"

config ALP_SOC_ALIF_ENSEMBLE_E7
	bool "Alif Ensemble E7 (alif:ensemble:e7)"

config ALP_SOC_ALIF_ENSEMBLE_E8
	bool "Alif Ensemble E8 (alif:ensemble:e8 — preliminary)"

config ALP_SOC_RENESAS_RZV2N_N44
	bool "Renesas RZ/V2N R9A09G056N44 (renesas:rzv2n:n44)"

config ALP_SOC_DEEPX_DX_M1
	bool "DEEPX DX-M1 NPU (deepx:dx:m1)"

config ALP_SOC_NXP_IMX9_IMX93
	bool "NXP i.MX 93 (nxp:imx9:imx93 — preliminary)"

endchoice

config ALP_SDK_MAX_I2C_HANDLES
	int "Maximum concurrent alp_i2c_t handles"
	default 4

config ALP_SDK_MAX_SPI_HANDLES
	int "Maximum concurrent alp_spi_t handles"
	default 4

config ALP_SDK_MAX_UART_HANDLES
	int "Maximum concurrent alp_uart_t handles"
	default 4

config ALP_SDK_MAX_GPIO_HANDLES
	int "Maximum concurrent alp_gpio_t handles"
	default 16

config ALP_SDK_MAX_PWM_HANDLES
	int "Maximum concurrent alp_pwm_t handles"
	default 8

config ALP_SDK_MAX_ADC_HANDLES
	int "Maximum concurrent alp_adc_t handles"
	default 8

config ALP_SDK_MAX_COUNTER_HANDLES
	int "Maximum concurrent alp_counter_t handles"
	default 4

config ALP_SDK_MAX_QENC_HANDLES
	int "Maximum concurrent alp_qenc_t handles"
	default 4

config ALP_SDK_MAX_I2S_HANDLES
	int "Maximum concurrent alp_i2s_t handles"
	default 2

config ALP_SDK_MAX_CAN_HANDLES
	int "Maximum concurrent alp_can_t handles"
	default 4

config ALP_SDK_MAX_RTC_HANDLES
	int "Maximum concurrent alp_rtc_t handles"
	default 2

config ALP_SDK_MAX_WDT_HANDLES
	int "Maximum concurrent alp_wdt_t handles"
	default 2

# Per-class peripheral wrappers — opt-in so apps that don't use a
# given Zephyr subsystem don't link the wrapper.  Each defaults on
# when its underlying Zephyr driver class is enabled.

config ALP_SDK_PERIPH_PWM
	bool "Enable <alp/pwm.h> wrapper"
	default y if PWM
	depends on PWM
	help
	  Compile src/zephyr/peripheral_pwm.c.  Provides alp_pwm_*
	  on top of Zephyr's pwm_* API.  Resolves channel_id via the
	  alp-pwm0..alp-pwm7 DT aliases.

config ALP_SDK_PERIPH_ADC
	bool "Enable <alp/adc.h> wrapper"
	default y if ADC
	depends on ADC
	help
	  Compile src/zephyr/peripheral_adc.c.  Provides alp_adc_*
	  on top of Zephyr's adc_* API.  Resolves channel_id via the
	  alp-adc0..alp-adc7 DT aliases (each pointing at a node with
	  an io-channels phandle and the standard ADC channel-config
	  properties).

config ALP_SDK_PERIPH_COUNTER
	bool "Enable <alp/counter.h> free-running counter wrapper"
	default y if COUNTER
	depends on COUNTER
	help
	  Compile src/zephyr/peripheral_counter.c.  Provides
	  alp_counter_* on top of Zephyr's counter_* API.  Resolves
	  counter_id via the alp-counter0..alp-counter3 DT aliases.

config ALP_SDK_PERIPH_QENC
	bool "Enable <alp/counter.h> quadrature-decoder wrapper"
	default y if SENSOR
	depends on SENSOR
	help
	  Compile src/zephyr/peripheral_qenc.c.  Provides alp_qenc_*
	  on top of Zephyr's sensor_* API (SENSOR_CHAN_ROTATION).
	  Resolves encoder_id via alp-qenc0..alp-qenc3 DT aliases.

config ALP_SDK_PERIPH_I2S
	bool "Enable <alp/i2s.h> wrapper"
	default y if I2S
	depends on I2S
	help
	  Compile src/zephyr/peripheral_i2s.c.  Provides alp_i2s_*
	  on top of Zephyr's i2s_* API with a 2-block ping-pong
	  memory slab.

config ALP_SDK_PERIPH_CAN
	bool "Enable <alp/can.h> wrapper (classic CAN + CAN-FD)"
	default y if CAN
	depends on CAN
	help
	  Compile src/zephyr/peripheral_can.c.  Provides alp_can_*
	  on top of Zephyr's can_* API.  CAN-FD only when
	  CONFIG_CAN_FD_MODE=y.

config ALP_SDK_PERIPH_RTC
	bool "Enable <alp/rtc.h> wrapper"
	default y if RTC
	depends on RTC
	help
	  Compile src/zephyr/peripheral_rtc.c.  Provides alp_rtc_*
	  on top of Zephyr's rtc_* API.

config ALP_SDK_PERIPH_WDT
	bool "Enable <alp/wdt.h> wrapper"
	default y if WATCHDOG
	depends on WATCHDOG
	help
	  Compile src/zephyr/peripheral_wdt.c.  Provides alp_wdt_*
	  on top of Zephyr's wdt_* API.

config ALP_SDK_HAS_LVGL
	bool "Build <alp/gui.h> against LVGL"
	default y if LVGL
	default n
	help
	  Pulls upstream LVGL into the alp_gui_lvgl_attach() path.
	  Requires CONFIG_LVGL=y.

config ALP_SDK_HAS_CMSIS_DSP
	bool "Build <alp/math.h> against CMSIS-DSP"
	default y if CMSIS_DSP
	default n
	help
	  Re-export arm_math.h via <alp/math.h>.  Requires the
	  CMSIS-DSP module to be present in the Zephyr west manifest.

# Chip drivers.  Each is opt-in so projects only pay for the
# silicon they actually use.  Symbols use the chip's natural prefix
# (lsm6dso_*, ssd1306_*, bme280_*, …) — no alp_ prefix on chip
# drivers.  The button_led / pdm_mic helpers are the exception
# (generic block utilities, alp_-prefixed).

menu "ALP SDK chip drivers"

config ALP_SDK_CHIP_LSM6DSO
	bool "STMicroelectronics LSM6DSO 6-axis IMU driver"
	depends on I2C
	help
	  Compile chips/lsm6dso/lsm6dso.c.  Provides lsm6dso_init,
	  lsm6dso_read_accel/gyro/temp.  Used by the alp-studio
	  block blk_imu_lsm6dso.

config ALP_SDK_CHIP_SSD1306
	bool "Solomon Systech SSD1306 monochrome OLED driver"
	depends on I2C
	help
	  Compile chips/ssd1306/ssd1306.c.  Provides ssd1306_init,
	  ssd1306_clear, ssd1306_draw_pixel, ssd1306_display.  Used
	  by the alp-studio block blk_oled_ssd1306.

config ALP_SDK_CHIP_BUTTON_LED
	bool "Generic button + LED block helper"
	depends on GPIO
	help
	  Compile chips/button_led/button_led.c.  Wraps alp_gpio_*
	  to provide alp_button_led_* lifecycle helpers used by the
	  alp-studio block blk_button_led.

config ALP_SDK_CHIP_BME280
	bool "Bosch BME280 environment sensor driver (T/H/P)"
	depends on I2C
	help
	  Compile chips/bme280/bme280.c.  Provides bme280_init,
	  bme280_set_sampling, bme280_read_raw + bme280_compensate
	  with the canonical Bosch integer-form compensation.  Used
	  by the alp-studio block blk_env_bme280.

config ALP_SDK_CHIP_LIS2DW12
	bool "STMicroelectronics LIS2DW12 3-axis accelerometer driver"
	depends on I2C
	help
	  Compile chips/lis2dw12/lis2dw12.c.  Provides lis2dw12_init,
	  lis2dw12_set_accel, lis2dw12_read_accel/temp.  Used by the
	  alp-studio block blk_accel_lis2dw12.

config ALP_SDK_CHIP_SSD1331
	bool "Solomon Systech SSD1331 96x64 colour OLED driver (SPI)"
	depends on SPI && GPIO
	help
	  Compile chips/ssd1331/ssd1331.c.  Provides ssd1331_init,
	  ssd1331_draw_pixel (RGB565), ssd1331_display.  Used by the
	  alp-studio block blk_oled_ssd1331.

config ALP_SDK_CHIP_OV5640
	bool "OmniVision OV5640 5MP image sensor SCCB driver"
	depends on I2C
	help
	  Compile chips/ov5640/ov5640.c.  Config-side only — chip-ID
	  verify, soft-reset, resolution / format presets, test
	  pattern.  The actual capture path lands in v0.2 alp_camera
	  on V2N.  Used by the alp-studio block blk_camera_ov5640.

config ALP_SDK_CHIP_PDM_MIC
	bool "Generic PDM microphone block helper"
	help
	  Compile chips/pdm_mic/pdm_mic.c.  Surface declared for
	  v0.2; underlying alp_i2s_* peripheral abstraction lands
	  alongside <alp/audio.h>.  Used by the alp-studio block
	  blk_pdm_mic.

config ALP_SDK_CHIP_ICM42670
	bool "TDK InvenSense ICM-42670-P 6-axis IMU driver"
	depends on I2C
	help
	  Compile chips/icm42670/icm42670.c.  Provides icm42670_init,
	  icm42670_set_accel/gyro, icm42670_read_accel/gyro/temp.
	  Used by the alp-studio block blk_imu_icm42670 and one of
	  the on-board IMUs on the E1M EVK.

config ALP_SDK_CHIP_BMI323
	bool "Bosch BMI323 6-axis IMU driver"
	depends on I2C
	help
	  Compile chips/bmi323/bmi323.c.  Provides bmi323_init,
	  bmi323_set_accel/gyro, bmi323_read_accel/gyro/temp.
	  Used by the alp-studio block blk_imu_bmi323 and the
	  second on-board IMU on the E1M EVK.

config ALP_SDK_CHIP_BMP581
	bool "Bosch BMP581 barometric pressure sensor"
	depends on I2C
	help
	  Compile chips/bmp581/bmp581.c.  Provides bmp581_init,
	  bmp581_set_sampling, bmp581_read_raw + bmp581_compensate
	  for the BMP581's already-compensated 24-bit P + T outputs.
	  Used by the alp-studio block blk_baro_bmp581 and the
	  on-board barometer on the E1M EVK.

endmenu # "ALP SDK chip drivers"

endif # ALP_SDK
