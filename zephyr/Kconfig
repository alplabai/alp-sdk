# ---------------------------------------------------------------------------
# Alif Ensemble ISP-Pico (Verisilicon ISP Nano "Pico", compatible
# "vsi,isp-pico") -- ADR 0017 Tier-2, OPT-IN (default n).  An m2m video device
# (input EP = camera/CPI, output EP = processed frame) vendored from the
# Apache-2.0 zephyr_alif fork (drivers/video/isp_pico.c) and PORTED to the v4.4
# video API by Alp Lab AB.  It links the hal_alif libisp wrapper
# (modules/hal/alif/drivers/isp/isp_wrapper -> Lib/libisp_gcc.a, the Vivante
# blob), so it selects USE_ALIF_ISP_LIB.
#
# HAL_ALIF VERSION MISMATCH (FLAGGED, task #21): the vendored isp_pico.c is the
# 2026 fork driver; the locally vendored hal_alif isp_wrapper is 2025 and does
# NOT export isp_vsi_set_param / isp_vsi_get_param, ships a 2-arg
# isp_vsi_bottom_half() vs this driver's 3-arg call, and ships no
# <zephyr/drivers/video/isp-vsi.h> (only isp_conf.h / isp_param_conf.h).  So
# this driver COMPILES against v4.4 but WILL NOT LINK against the local hal_alif
# until the wrapper is bumped.  Hence default n -- the default build stays green
# regardless; turning it on against the 2025 wrapper is a known link failure.
# Do NOT fabricate the missing hal_alif API.  vendor-ext, BENCH-UNVERIFIED.
# ---------------------------------------------------------------------------
config VIDEO_ISP_VSI
	bool "Alif Ensemble ISP-Pico (Verisilicon, ADR 0017 Tier-2 INTERIM, OPT-IN)"
	default n
	depends on VIDEO
	depends on DT_HAS_VSI_ISP_PICO_ENABLED
	select USE_ALIF_ISP_LIB
	help
	  Alif Ensemble ISP-Pico (Verisilicon ISP Nano) video m2m driver, vendored
	  from the Apache-2.0 zephyr_alif fork (drivers/video/isp_pico.c, compatible
	  "vsi,isp-pico") and PORTED to the v4.4 video API by Alp Lab AB.  Links the
	  hal_alif libisp wrapper (the Vivante ISP blob, USE_ALIF_ISP_LIB).

	  OPT-IN, default n.  FLAGGED hal_alif version mismatch: the vendored 2026
	  isp_pico.c needs a newer hal_alif libisp wrapper than the locally vendored
	  2025 one (missing isp_vsi_set_param / isp_vsi_get_param / isp-vsi.h; 2-arg
	  vs 3-arg isp_vsi_bottom_half), so it compiles but does NOT link against the
	  local wrapper.  Bump the hal_alif wrapper before enabling.  Task #21.
	  Driver: zephyr/drivers/video/isp_pico.c.

