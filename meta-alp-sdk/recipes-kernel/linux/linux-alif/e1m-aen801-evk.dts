/*
 * Copyright (c) 2026 Alp Lab AB -- E1M-AEN801 on the E1M-EVK carrier.
 * Copyright (C) 2025 Alif Semiconductor (SoC dtsi + DCT defines, consumed).
 *
 * Alif Ensemble E8 (AE822) A32-cluster Linux carrier DTS.  The peripheral
 * selection is transcribed from the AUTHORITATIVE routing -- the SoM E1M-pad ->
 * Alif-instance map (metadata/e1m_modules/aen/from-alif.tsv) + the carrier
 * E1M-pad -> board-feature map (metadata/boards/e1m-evk.yaml):
 *
 *   console (EVK_UART_PORT_DEBUG)  E1M_UART0 -> Alif UART5  P3_5/P3_4
 *   sensors (EVK_I2C_BUS_SENSORS)  E1M_I2C0  -> Alif I2C2   P5_6/P5_7
 *   disp/cam (EVK_I2C_BUS_DSI_CSI) E1M_I2C1  -> Alif I2C1   P3_7/P7_2
 *
 * Builds via the Alif dct-kernel flow (DTS_MACRO_FILE); validated by bake (dtb
 * compiles for MACHINE=e1m-aen801-a32, no board).  On-bus I2C device nodes are
 * TODO pending the EVK strap addresses (bmi323 + icm42670 both default 0x68).
 */
/dts-v1/;

#include "../common/ensemble-ex.dtsi"
#include "e1m_dct_defines.h"

/ {
	model = "ALP E1M-AEN801 on E1M-EVK (Alif Ensemble E8 / AE822)";
	compatible = "alp,e1m-aen801-evk", "alif,ensemble";

	aliases {
		serial0 = &uart5;
	};

	chosen {
		bootargs = "console=ttyS0,115200n8 \
		root=mtd:physmap-flash.0 \
		rootfstype=cramfs ro loglevel=7";
	};

	/* Carrier fixed rails (3.3 V / 1.8 V). */
	reg_3p3v: regulator-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "fixed-3.3V";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};
	reg_1p8v: regulator-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "fixed-1.8V";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
	};
};

/* SMP + on-die / OSPI memory, per the common DCT defines. */
&cpu1 {
	status = CPU1_STATUS;
};

&mem_stitch {
	status = MEM_STITCH_STATUS;
};

&mem_hyperam {
	status = MEM_HYPER_STATUS;
};

&mem_hyp_stitch {
	status = MEM_HYP_STITCH_STATUS;
};

/* Console -- E1M_UART0 = Alif UART5 (P3_5 TX / P3_4 RX). */
&uart5 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart5>;
	status = UART5_STATUS;
};

/* Sensors bus -- E1M_I2C0 = Alif I2C2 (P5_6 SCL / P5_7 SDA).
 * EVK_I2C_BUS_SENSORS: bmi323, icm42670, bmp581, ina236 x6, tcal9538. */
&i2c2 {
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_i2c2>;
	status = I2C2_STATUS;

	/*
	 * TODO(e1m-evk-hw): add the on-bus device nodes once the EVK strap
	 * addresses are confirmed (bmi323 + icm42670 both default to 0x68, so
	 * one straps to 0x69 -- schematic-determined):
	 *   bosch,bmi323            @ 0x68/0x69
	 *   invensense,icm42670     @ 0x68/0x69
	 *   bosch,bmp581            @ 0x46/0x47
	 *   ti,ina236        x6     @ 0x40..0x45
	 *   ti,tca9538 (TCAL9538)   @ 0x72
	 * See metadata/boards/e1m-evk.yaml (populated:) + the chip YAMLs.
	 */
};

/* Display / camera control bus -- E1M_I2C1 = Alif I2C1 (P3_7 SCL / P7_2 SDA). */
&i2c1 {
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_i2c1>;
	status = I2C1_STATUS;
};

/* Pinmux groups -- pins + functions transcribed from from-alif.tsv. */
&pinmux {
	pinctrl_uart5: uart5grp {
		pinmux = <
			PIN_P3_5__UART5_TX_A	0x23
			PIN_P3_4__UART5_RX_A	0x23
		>;
	};

	pinctrl_i2c2: i2c2grp {
		pinmux = <
			PIN_P5_6__I2C2_SCL_C	0x23
			PIN_P5_7__I2C2_SDA_C	0x23
		>;
	};

	pinctrl_i2c1: i2c1grp {
		pinmux = <
			PIN_P3_7__I2C1_SCL_B	0x23
			PIN_P7_2__I2C1_SDA_C	0x23
		>;
	};
};
