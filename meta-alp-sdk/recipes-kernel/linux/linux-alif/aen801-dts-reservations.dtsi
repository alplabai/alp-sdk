/*
 * Generated by `scripts/alp_orchestrate.py --emit dts-reservations`,
 * then HAND-ADJUSTED to 32-bit cells for this AArch32 target (see the
 * note below).  #include this file from your kernel / Zephyr DT.
 *
 * On regen (after a board.yaml `ipc:` or memory_map change) the
 * generator re-emits 64-bit `#address-cells = <2>` form -- RE-APPLY the
 * 32-bit adjustment below until emit_dts_reservations grows arch-aware
 * cell widths (see its TODO).
 *
 * Note: no #address-cells / #size-cells override here.  The Ensemble
 * E8 A32 cluster is AArch32 (32-bit physical addresses); the base DTS
 * (ensemble-ex.dtsi) already declares reserved-memory with
 * #address-cells = <1> #size-cells = <1>.  The reg here is 32-bit
 * format to match.
 */

/ {
    reserved-memory {

        alp_default_rpmsg: alp_default_rpmsg@23c0000 {
            compatible = "shared-dma-pool";
            reg = <0x023c0000 0x00040000>;
            no-map;
            label = "alp_default_rpmsg";
        };

    };
};
