From a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0 Mon Sep 17 00:00:00 2001
From: Caner <alpcaner92@gmail.com>
Date: Fri, 22 May 2026 00:00:00 +0200
Subject: [PATCH] arm64: dts: renesas: rzv2n-evk: customize for e1m-x_v2n-m1

Identify the custom board (e1m-x carrier + v2n-m1 SoM) in model and
compatible. Functional node disables (HDMI / audio / PMIC / cameras /
PCIe) will land in follow-up patches once we verify this pipeline
plumbing works.

Signed-off-by: Caner <alpcaner92@gmail.com>
---
 arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
index 1234567..abcdef0 100644
--- a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
+++ b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
@@ -112,8 +112,8 @@
  */

 / {
-	model = "Renesas RZ/V2N EVK Board based on r9a09g056n48";
-	compatible = "renesas,rzv2n-evk", "renesas,r9a09g056n48", "renesas,r9a09g056";
+	model = "ALP e1m-x carrier + v2n-m1 SoM (RZ/V2N r9a09g056n48)";
+	compatible = "alp,e1m-x-v2n-m1", "renesas,r9a09g056n48", "renesas,r9a09g056";

 	aliases {
 		ethernet0 = &eth0;
--
2.34.1

