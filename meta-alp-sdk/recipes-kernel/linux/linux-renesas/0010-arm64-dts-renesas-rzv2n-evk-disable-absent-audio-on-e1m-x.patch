From 46798d5908545deb32cc3cb913215c9615a5ad44 Mon Sep 17 00:00:00 2001
From: Caner <alpcaner92@gmail.com>
Date: Mon, 25 May 2026 14:28:06 +0200
Subject: [PATCH 1/3] arm64: dts: renesas: rzv2n-evk: disable absent audio on
 e1m-x

The e1m-x carrier has no DA7212 codec (the EVK part); its audio is a
TAS2563 smart-amp on SSI/I2S per alp-sdk metadata. With the EVK audio
graph enabled, the audio-graph-card fails to parse (no codec endpoint),
the SSI/ADG clocks fail to enable (rzv2h-cpg CLK_ON), and ALSA reports
no soundcards. Disable da7212, rcar_sound and the sound_card graph until
the TAS2563 path is wired up in a follow-up patch.

Signed-off-by: Caner <alpcaner92@gmail.com>
---
 .../dts/renesas/r9a09g056n48-rzv2n-evk.dts    | 20 +++++++++++++++++++
 1 file changed, 20 insertions(+)

diff --git a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
index a79c85828fa4..0a6c9b84a945 100644
--- a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
+++ b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
@@ -1559,3 +1559,23 @@ &cru1 {
 &pcie0 {
 	status = "disabled";
 };
+
+/*
+ * ALP e1m-x carrier: no DA7212 codec is populated. Carrier audio is a
+ * TAS2563 smart-amp on SSI/I2S (alp-sdk metadata/boards/e1m-x-evk.yaml),
+ * to be enabled in a later patch once the SDK I2S-mux/SSI/shutdown-GPIO
+ * routing is final. Until then disable the EVK audio graph so it stops
+ * failing to probe (audio-graph-card parse error, SSI/ADG CLK_ON enable
+ * failures, "No soundcards found").
+ */
+&da7212 {
+	status = "disabled";
+};
+
+&rcar_sound {
+	status = "disabled";
+};
+
+&sound_card {
+	status = "disabled";
+};
-- 
