From: Alp Lab AB
Date: Thu, 4 Jun 2026 15:47:10 +0200
Subject: [PATCH] input: goodix - fall back to polling when no IRQ is wired
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Copyright (c) 2026 Alp Lab AB
SPDX-License-Identifier: GPL-2.0

On the E1M-X V2N SoM the GT911 INT line terminates at the GD32G553
IO-MCU, not at a Linux-visible GPIO.  No IRQ will ever exist for this
controller under Linux on this SoM; the MCU will proxy touch events
over the GD32 bridge I2C channel once that adapter lands.

This patch is shipped DORMANT on purpose: the GT911 I2C bus also
terminates at the GD32 (no Linux I2C master), so no DT node and no
Kconfig enable will reference the goodix driver yet.  It is landed now
because (a) the forthcoming bridge I2C-proxy adapter requires exactly
this polled mode, and (b) the change compile-gates cleanly today with
no effect on any existing board.

Implementation notes:

  Ordering constraint: input_setup_polling() must be called before
  input_register_device().  The polling branch is therefore placed
  before the registration call; input_set_drvdata() is added in the
  same location so that goodix_ts_poll() can recover the driver
  private data via input_get_drvdata().  The IRQ branch is placed
  after registration, exactly where it was before — preserving the
  original control flow for the interrupt-driven case byte-for-byte.

  Interval choice: 17 ms (~60 Hz) matches the GT911's maximum report
  rate and the target display refresh rate; it is generous enough that
  the I2C transaction fits within one poll slot even at the 100 kHz
  bus speed used on the bridge path.

  Suspend/resume: the IRQ_PIN_ACCESS_NONE paths in goodix_suspend() and
  goodix_resume() called disable_irq()/enable_irq() unconditionally.
  With client->irq == 0 those calls would oops; guard them with
  "if (client->irq > 0)".  The pin-access paths (non-NONE) are
  unreachable when no IRQ is wired and are left unchanged.

Upstream-Status: Pending [generic improvement; no SoM-specific code]

Signed-off-by: Alp Lab AB
---
 drivers/input/touchscreen/goodix.c | 39 ++++++++++++++++++++++++------
 1 file changed, 32 insertions(+), 7 deletions(-)

diff --git a/drivers/input/touchscreen/goodix.c b/drivers/input/touchscreen/goodix.c
index 6de64b3f900f..3db0f0eaac81 100644
--- a/drivers/input/touchscreen/goodix.c
+++ b/drivers/input/touchscreen/goodix.c
@@ -43,6 +43,7 @@
 #define GOODIX_BUFFER_STATUS_READY	BIT(7)
 #define GOODIX_HAVE_KEY			BIT(4)
 #define GOODIX_BUFFER_STATUS_TIMEOUT	20
+#define GOODIX_POLL_INTERVAL_MS		17	/* ~59 Hz, matches GT911 report rate */
 
 #define RESOLUTION_LOC		1
 #define MAX_CONTACTS_LOC	5
@@ -513,6 +514,14 @@ static irqreturn_t goodix_ts_irq_handler(int irq, void *dev_id)
 	return IRQ_HANDLED;
 }
 
+static void goodix_ts_poll(struct input_dev *input)
+{
+	struct goodix_ts_data *ts = input_get_drvdata(input);
+
+	goodix_process_events(ts);
+	goodix_i2c_write_u8(ts->client, GOODIX_READ_COOR_ADDR, 0);
+}
+
 static void goodix_free_irq(struct goodix_ts_data *ts)
 {
 	devm_free_irq(&ts->client->dev, ts->client->irq, ts);
@@ -1237,6 +1246,18 @@ static int goodix_configure_dev(struct goodix_ts_data *ts)
 		return error;
 	}
 
+	input_set_drvdata(ts->input_dev, ts);
+
+	if (ts->client->irq <= 0) {
+		error = input_setup_polling(ts->input_dev, goodix_ts_poll);
+		if (error) {
+			dev_err(&ts->client->dev,
+				"could not set up polling: %d\n", error);
+			return error;
+		}
+		input_set_poll_interval(ts->input_dev, GOODIX_POLL_INTERVAL_MS);
+	}
+
 	error = input_register_device(ts->input_dev);
 	if (error) {
 		dev_err(&ts->client->dev,
@@ -1255,11 +1276,13 @@ static int goodix_configure_dev(struct goodix_ts_data *ts)
 	if (error)
 		return error;
 
-	ts->irq_flags = goodix_irq_flags[ts->int_trigger_type] | IRQF_ONESHOT;
-	error = goodix_request_irq(ts);
-	if (error) {
-		dev_err(&ts->client->dev, "request IRQ failed: %d\n", error);
-		return error;
+	if (ts->client->irq > 0) {
+		ts->irq_flags = goodix_irq_flags[ts->int_trigger_type] | IRQF_ONESHOT;
+		error = goodix_request_irq(ts);
+		if (error) {
+			dev_err(&ts->client->dev, "request IRQ failed: %d\n", error);
+			return error;
+		}
 	}
 
 	return 0;
@@ -1441,7 +1464,8 @@ static int __maybe_unused goodix_suspend(struct device *dev)
 
 	/* We need gpio pins to suspend/resume */
 	if (ts->irq_pin_access_method == IRQ_PIN_ACCESS_NONE) {
-		disable_irq(client->irq);
+		if (client->irq > 0)
+			disable_irq(client->irq);
 		return 0;
 	}
 
@@ -1485,7 +1509,8 @@ static int __maybe_unused goodix_resume(struct device *dev)
 	int error;
 
 	if (ts->irq_pin_access_method == IRQ_PIN_ACCESS_NONE) {
-		enable_irq(client->irq);
+		if (client->irq > 0)
+			enable_irq(client->irq);
 		return 0;
 	}
 
