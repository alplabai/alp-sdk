// SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
/*
 * ALP E1M-X-EVK carrier (45x65) — peripherals on the baseboard.
 *
 * Composes with a SoM dtsi: a board dts includes the SoC dtsi, then the
 * SoM dtsi (e1m-v2n-som.dtsi), then this carrier dtsi. Because we build
 * up from the SoC dtsi and only ENABLE what the carrier populates, there
 * is no "disable the EVK's nodes" pile — the Renesas EVK's HDMI bridge,
 * OV5645 cameras, DA7212 codec and RAA215300 PMIC simply aren't enabled.
 *
 * Ported from the Renesas RZ/V2N EVK reference dts (kernel SHA 6717c06).
 * STATUS: UNVALIDATED through dtc/bitbake.
 *
 * TODO (carrier features to port once exercised on the bench):
 *   - Audio: TAS2563 smart-amp pair on I2C0 @0x4D/0x4E, I2S0 -> SSI1
 *     (rcar_sound audio-graph). See chips/tas2563 + issue #25.
 *   - Display 1 (J6): ported -- rk055hdmipi4ma0 panel on dsi0 (see below).
 *     Display 2 (J28) is permanently unavailable: it requires DSI1 lane
 *     set, which the V2N/V2M family does not populate.
 *     Touch (GT911 on the panel FFC): DEFERRED -- its I2C bus
 *     (DSI1_CSI_I2C) terminates on the GD32 IO-MCU bridge; Linux has no
 *     direct path until the bridge gains an I2C-master proxy.
 *   - 2x MIPI-CSI cameras.
 *   - CAN-FD (TCAN1044 x2).
 */

#include <dt-bindings/interrupt-controller/irq.h>

/ {
	aliases {
		ethernet0 = &eth0;
		ethernet1 = &eth1;
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c6 = &i2c6;
		i2c7 = &i2c7;
		i2c8 = &i2c8;
		mmc0 = &sdhi0;
		mmc1 = &sdhi1;
		serial0 = &scif;
	};

	chosen {
		bootargs = "ignore_loglevel";
		stdout-path = "serial0:115200n8";
	};

	gpio-keys {
		compatible = "gpio-keys";

		nmi {
			interrupt-parent = <&icu>;
			interrupts = <0 IRQ_TYPE_EDGE_FALLING>;
			linux,code = <0>;
			label = "NMI";
			wakeup-source;
		};
	};

	/* Carrier microSD (SDHI1) VccQ level-shifter. */
	vqmmc_sdhi1: regulator-vqmmc-sdhi1 {
		compatible = "regulator-gpio";
		regulator-name = "SDHI1 VqmmC";
		gpios = <&pinctrl RZV2N_GPIO(A, 2) GPIO_ACTIVE_HIGH>;
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <3300000>;
		gpios-states = <0>;
		states = <3300000 0>, <1800000 1>;
	};
};

&qextal_clk {
	clock-frequency = <24000000>;
};

&rtxin_clk {
	clock-frequency = <32768>;
};

&rtc_clk {
	clock-frequency = <32768>;
};

&rtc {
	status = "okay";
};

/* Carrier microSD slot (SDHI1). The bench dev image roots from this card
 * (root=/dev/mmcblk1p2); on-module eMMC (SDHI0) is the production boot. */
&sdhi1 {
	pinctrl-0 = <&sdhi1_pins>;
	pinctrl-1 = <&sdhi1_pins>;
	pinctrl-names = "default", "state_uhs";
	vmmc-supply = <&reg_3p3v>;
	vqmmc-supply = <&vqmmc_sdhi1>;
	bus-width = <4>;
	sd-uhs-sdr50;
	sd-uhs-sdr104;
	status = "okay";
};

&gpu {
	status = "okay";
	mali-supply = <&reg_0p8v>;
};

/* Display 1 (J6): RK055HDMIPI4MA0 720x1280 MIPI-DSI panel.
 * The V2N's single DSI feeds the connector DSI0 lane set -> J6 directly
 * (no bridge/mux on this carrier). Display 2 (J28) sits on the DSI1
 * lane set, which the V2N family does not populate -- permanently
 * unavailable on V2N/V2M.
 * Panel rails are always-on; VIO is modeled here as the carrier's
 * default 3V3 setting. LCD1_PWR_EN (IO15) is pulled high on the carrier
 * and IO15 is unrouted on V2N -- no power GPIO needed. Panel reset =
 * E1M-X IO13 via bridge GPIO line 5.
 * Touch (GT911 on the panel FFC) is NOT wired here: its bus
 * (DSI1_CSI_I2C = E1M-X I2C3) has no Linux master today, so Linux has
 * no path to it until
 * the bridge gains an I2C-master proxy. Tracked as a follow-up; the
 * goodix polled-mode patch already ships dormant for that stack.
 */
&du {
	status = "okay";
};

&dsi0 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";

	panel@0 {
		compatible = "rocktech,rk055hdmipi4ma0";
		reg = <0>;
		reset-gpios = <&gd32_gpio 5 GPIO_ACTIVE_LOW>;
		vcc-supply = <&reg_3p3v>;
		iovcc-supply = <&reg_3p3v>;
		backlight = <&backlight>;

		port {
			panel_in: endpoint {
				remote-endpoint = <&dsi0_out>;
			};
		};
	};

	/* port@1 merges with the SoC dtsi's existing dsi0/ports/port@1
	 * node (which carries the dsi0_out label).  The label is NOT
	 * re-declared here to avoid a duplicate-label dtc error; the
	 * panel_in remote-endpoint above resolves via the SoC label. */
	ports {
		port@1 {
			endpoint {
				remote-endpoint = <&panel_in>;
				data-lanes = <1 2>;
			};
		};
	};
};

/* Dual GbE — MACs on the carrier RJ45s; PHYs are on-module (SoM dtsi). */
&eth0 {
	pinctrl-0 = <&eth0_pins>;
	pinctrl-names = "default";
	phy-handle = <&phy0>;
	phy-mode = "rgmii-id";
	status = "okay";
};

&eth1 {
	pinctrl-0 = <&eth1_pins>;
	pinctrl-names = "default";
	phy-handle = <&phy1>;
	phy-mode = "rgmii-id";
	status = "okay";
};

&i2c0 {
	pinctrl-0 = <&i2c0_pins>;
	pinctrl-names = "default";
	/* 100 kHz: on-module EEPROM bus on internal pull-ups (weak ~50k). */
	clock-frequency = <100000>;
	status = "okay";
};

&i2c1 {
	pinctrl-0 = <&i2c1_pins>;
	pinctrl-names = "default";
	clock-frequency = <400000>;
	status = "okay";
};

&i2c6 {
	pinctrl-0 = <&i2c6_pins>;
	pinctrl-names = "default";
	clock-frequency = <400000>;
	status = "okay";
};

&i2c7 {
	pinctrl-0 = <&i2c7_pins>;
	pinctrl-names = "default";
	clock-frequency = <400000>;
	status = "okay";
};

&i2c8 {
	pinctrl-0 = <&i2c8_pins>;
	pinctrl-names = "default";
	clock-frequency = <400000>;
	status = "okay";
};

&scif {
	pinctrl-0 = <&scif_pins>;
	pinctrl-names = "default";
	status = "okay";
};

/* USB 2.0 host (OTG) + USB 3.0.  The carrier's OVC sense wiring is not
 * usable (errata E3).  PB.1 (usb30) is parked as a GPIO input by the hog
 * below, which keeps the xHCI OVC input inactive.  P9.6 (usb20) can no
 * longer be parked the same way: it is SCK7 of the CM33-owned GD32
 * supervisor SPI, and the CM33 is started by BL2 PRE-Linux -- so the old
 * hog actually clobbered the live SCK7 mux at every Linux boot (~1.9 s,
 * PMC9 byte-RMW; same clobber class as SD1_CD below) until the CM33's
 * own pin re-init took the pad back, which is also why usb20 OVC
 * suppression was lost.  The usb20 channel is instead suppressed at the
 * controller: spurious-oc on the EHCI (generic binding, in-tree) and on
 * the OHCI (kernel patch 0003 adds the same property).  OC processing
 * is fully off for usb20 -- correct here because VBUS is hardwired
 * always-on with no per-port switching to protect. */
&ehci0 {
	memory-region = <&global_cma>;
	dr_mode = "otg";
	spurious-oc;
	status = "okay";
};

&ohci0 {
	memory-region = <&global_cma>;
	dr_mode = "otg";
	spurious-oc;
	status = "okay";
};

&hsusb {
	dr_mode = "otg";
	status = "okay";
};

&usb20phyrst {
	status = "okay";
};

&usb2_phy0_vbus_otg {
	status = "okay";
};

&usb2_phy0 {
	/* USB2.0 VBUS is always-on (hardwired) on the E1M-X carrier, so no
	 * VBUS GPIO/pinmux is needed. The old usb20_pins hogged P95 (func 14),
	 * which is the DEEPX PCIe mux-sel on V2M and MUST stay a GPIO — the
	 * pinctrl claim collided with the deepx-pcie-mux-sel hog. Dropped. */
	vbus-supply = <&usb2_phy0_vbus_otg>;
	status = "okay";
};

&usb3_phy0 {
	status = "okay";
};

&xhci0 {
	pinctrl-0 = <&usb30_pins>;
	pinctrl-names = "default";
	memory-region = <&global_cma>;
	status = "okay";
};

&pinctrl {
	eth0_pins: eth0 {
		pins = "ET0_TXC_TXCLK";
		output-enable;
	};

	eth1_pins: eth1 {
		pins = "ET1_TXC_TXCLK";
		output-enable;
	};

	/* Unlike the Renesas EVK (external pull-ups on RIIC0/1), the ALP
	 * board has none on RIIC0 (on-module EEPROM bus), RIIC1, or RIIC8
	 * (BRD_I2C); enable the SoC internal pull-ups so SCL/SDA idle high. */
	i2c0_pins: i2c0 {
		pinmux = <RZV2N_PORT_PINMUX(3, 0, 1)>, /* I2C0_SDA */
			 <RZV2N_PORT_PINMUX(3, 1, 1)>; /* I2C0_SCL */
		bias-pull-up;
	};

	i2c1_pins: i2c1 {
		pinmux = <RZV2N_PORT_PINMUX(3, 2, 1)>, /* I2C1_SDA */
			 <RZV2N_PORT_PINMUX(3, 3, 1)>; /* I2C1_SCL */
		bias-pull-up;
	};

	i2c6_pins: i2c6 {
		pinmux = <RZV2N_PORT_PINMUX(4, 4, 1)>, /* I2C6_SDA */
			 <RZV2N_PORT_PINMUX(4, 5, 1)>; /* I2C6_SCL */
		bias-pull-up;
	};

	i2c7_pins: i2c7 {
		pinmux = <RZV2N_PORT_PINMUX(4, 6, 1)>, /* I2C7_SDA */
			 <RZV2N_PORT_PINMUX(4, 7, 1)>; /* I2C7_SCL */
		bias-pull-up;
	};

	i2c8_pins: i2c8 {
		pinmux = <RZV2N_PORT_PINMUX(0, 6, 1)>, /* I2C8_SDA */
			 <RZV2N_PORT_PINMUX(0, 7, 1)>; /* I2C8_SCL */
		bias-pull-up;
	};

	scif_pins: scif {
		pins = "SCIF_TXD", "SCIF_RXD";
		renesas,output-impedance = <1>;
	};

	/* SD1 CLK/CMD/DAT are dedicated (hardwired) balls on the carrier and
	 * don't need pin config.
	 *
	 * SD1_CD (card-detect) on P94 is DELIBERATELY NOT muxed here: P94 shares
	 * the port-9 PMC9/PM9 control registers with P96 (SCK7) and P97 (CS) of the
	 * on-module GD32 supervisor SPI, which the CM33 owns across the AMP split.
	 * Linux's boot-time byte/half-word write to mux SD1_CD wiped the CM33's
	 * P96/P97 bits (no SCK / no CS framing) -- the on-silicon root cause that
	 * the bench /dev/mem poke worked around.  Dropping the SD1_CD claim removes
	 * the clobber at the source so the CM33's own pin setup sticks.  (If carrier
	 * microSD hot-plug detect is needed later, route it to a non-port-9 pin or
	 * mark &sdhi1 broken-cd/non-removable.) */
	sdhi1_pins: sd1 {
	};

	/* microSD slot power enable. */
	sd1-pwr-en-hog {
		gpio-hog;
		gpios = <RZV2N_GPIO(A, 3) GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "sd1_pwr_en";
	};

	/* No usb20 (USB2.0 VBUS) pinmux: VBUS is always-on (hardwired) on this
	 * carrier, and P95 is the DEEPX PCIe mux-sel on V2M (kept as GPIO). */

	usb30_pins: usb30 {
		vbus {
			pinmux = <RZV2N_PORT_PINMUX(B, 0, 14)>; /* VBUS */
		};
	};

	/* usb30 OVC (PB.1) parked as a plain GPIO input so the xHCI OVC
	 * input reads inactive.  P9.6 (usb20 OVC) is DELIBERATELY absent:
	 * it is the CM33's SCK7.  Linux must never claim or re-mux the
	 * CM33's P9.6/P9.7, and every Linux port-9 access is a non-atomic
	 * PMC9/PM9 byte-RMW that can race the CM33 (the SD1_CD/P94 lesson
	 * above).  The one deliberate exception is the V2M deepx mux-sel
	 * hog on P9.5 (e1m-v2m-deepx.dtsi) -- see the race note there. */
	usb-ovc-disable-hog {
		gpio-hog;
		gpios = <RZV2N_GPIO(B, 1) GPIO_ACTIVE_HIGH>;
		input;
		line-name = "usb_ovc_disable";
	};
};
