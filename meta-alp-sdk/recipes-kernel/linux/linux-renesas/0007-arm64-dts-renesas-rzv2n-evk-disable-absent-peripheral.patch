From b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0 Mon Sep 17 00:00:00 2001
From: Caner <alpcaner92@gmail.com>
Date: Fri, 22 May 2026 11:00:00 +0200
Subject: [PATCH] arm64: dts: renesas: rzv2n-evk: disable EVK-only peripherals
 on e1m-x_v2n-m1

Disable nodes for hardware that exists on the Renesas RZ/V2N EVK but is
not populated on the e1m-x carrier + v2n-m1 SoM. Confirmed absent by
boot-log probe failures and/or i2c "SCL stuck low" (no pull-ups on the
custom carrier for the unused buses).

  - raa215300 PMIC (i2c8/0x12) - no PMIC on this carrier
  - adv7535 HDMI bridge (i2c3/0x3d) - no HDMI bridge
  - dsi0, du, hdmi-out - display path is moot without the bridge
  - ov5645_csi20, ov5645_csi21 (i2c0+i2c1 /0x3c) - no cameras
  - csi20, csi21, cru0, cru1 - camera input pipeline, moot
  - pcie0 - no PCIe device populated, leaves -ETIMEDOUT in boot

Audio (da7212 + rcar_sound) is intentionally left enabled pending
confirmation of the carrier's codec/headphone path.

Signed-off-by: Caner <alpcaner92@gmail.com>
---
 .../boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts    | 54 ++++++++++++++++++++++
 1 file changed, 54 insertions(+)

diff --git a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
index fedcba0..0123456 100644
--- a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
+++ b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
@@ -1505,3 +1505,57 @@
 	status = "okay";
 };
 #endif
+
+/*
+ * ALP e1m-x carrier + v2n-m1 SoM customizations.
+ * Disable EVK-only peripherals that are not populated on this board.
+ * Audio (&da7212, &rcar_sound) left as-is pending carrier codec check.
+ */
+
+&{/hdmi-out} {
+	status = "disabled";
+};
+
+&adv7535 {
+	status = "disabled";
+};
+
+&dsi0 {
+	status = "disabled";
+};
+
+&du {
+	status = "disabled";
+};
+
+&raa215300 {
+	status = "disabled";
+};
+
+&ov5645_csi20 {
+	status = "disabled";
+};
+
+&ov5645_csi21 {
+	status = "disabled";
+};
+
+&csi20 {
+	status = "disabled";
+};
+
+&csi21 {
+	status = "disabled";
+};
+
+&cru0 {
+	status = "disabled";
+};
+
+&cru1 {
+	status = "disabled";
+};
+
+&pcie0 {
+	status = "disabled";
+};
--
2.34.1

