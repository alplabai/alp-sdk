From 7fe37cebf9dd86200542b36fe4d450d6e3b716bb Mon Sep 17 00:00:00 2001
From: Caner <alpcaner92@gmail.com>
Date: Mon, 25 May 2026 14:28:06 +0200
Subject: [PATCH 3/3] arm64: dts: renesas: rzv2n-evk: disable USB OVC pins on
 e1m-x

Both USB2.0 root ports (EHCI bus2 / OHCI bus3) log a spurious
'over-current condition' at boot because the SoC OVC pins (P9.6, PB.1)
read asserted on this carrier. Removing them from the USB pinctrl groups
is not enough (U-Boot leaves them in OVC function); also claim them as
GPIO inputs via a hog so the OVC peripheral function is de-selected and
the internal OVRCUR reads inactive. This silences both EHCI and OHCI
(OHCI has no software over-current-ignore option) while keeping USB2.0
host up.

Signed-off-by: Caner <alpcaner92@gmail.com>
---
 .../dts/renesas/r9a09g056n48-rzv2n-evk.dts    | 29 +++++++++++++++++++
 1 file changed, 29 insertions(+)

diff --git a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
index d45776c5ccdc..88c2383b9071 100644
--- a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
+++ b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
@@ -1597,3 +1597,32 @@ &i2c6 {
 &i2c7 {
 	status = "disabled";
 };
+
+/*
+ * ALP e1m-x: kill the false USB2.0 over-current. The SoC OVC pins
+ * (P9.6 for the EHCI/OHCI channel, PB.1 for the xHCI channel) read
+ * permanently asserted on this carrier, so every boot logs
+ * "usb usbN-port1: over-current condition". Removing OVC from the pinctrl
+ * groups alone is not enough (U-Boot leaves the pins in OVC function), so
+ * also claim them as GPIO inputs via a hog: that de-selects the OVC
+ * peripheral function and the SoC's internal OVRCUR then reads inactive.
+ * EHCI/OHCI stay enabled so USB2.0 host remains fully functional. (OHCI
+ * has no software over-current-ignore knob, hence the pin-level fix.)
+ */
+&usb20_pins {
+	/delete-node/ ovc;
+};
+
+&usb30_pins {
+	/delete-node/ ovc;
+};
+
+&pinctrl {
+	usb-ovc-disable-hog {
+		gpio-hog;
+		gpios = <RZV2N_GPIO(9, 6) GPIO_ACTIVE_HIGH>,
+			<RZV2N_GPIO(B, 1) GPIO_ACTIVE_HIGH>;
+		input;
+		line-name = "usb_ovc_disable";
+	};
+};
