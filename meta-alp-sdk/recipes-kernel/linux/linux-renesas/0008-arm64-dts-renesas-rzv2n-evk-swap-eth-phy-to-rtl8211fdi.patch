From c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0 Mon Sep 17 00:00:00 2001
From: Caner <alpcaner92@gmail.com>
Date: Fri, 22 May 2026 11:30:00 +0200
Subject: [PATCH] arm64: dts: renesas: rzv2n-evk: swap eth PHYs to RTL8211FDI
 for e1m-x carrier

The ALP e1m-x carrier uses Realtek RTL8211FDI on both ET0 and ET1 (per
alp-sdk metadata/e1m_modules/v2n/renesas-peripheral-map.tsv), not the
Microchip KSZ9131 wired to the Renesas EVK.

With the EVK compatible string in place, Linux binds the Microchip
driver to the Realtek silicon -- end0 fails phy_poll_reset with
-ETIMEDOUT and end1 attaches but on the wrong driver, so the link
never actually negotiates correctly.

Change phy0 + phy1 compatible to RTL8211F's id (Realtek OUI 0x001c,
model 0xc916). The existing skew-psec properties are all zero and are
silently ignored by the Realtek driver, so leave them in place to keep
the diff minimal; PHY-internal RGMII delay is already correct via
phy-mode = "rgmii-id". CONFIG_REALTEK_PHY=y is already set in the
arm64 defconfig at SHA 6717c06c.

Signed-off-by: Caner <alpcaner92@gmail.com>
---
 .../boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts    | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
index 0123456..1234567 100644
--- a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
+++ b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
@@ -617,7 +617,7 @@

 &mdio0 {
 	phy0: ethernet-phy@0 {
-		compatible = "ethernet-phy-id0022.1640", "ethernet-phy-ieee802.3-c22";
+		compatible = "ethernet-phy-id001c.c916", "ethernet-phy-ieee802.3-c22";
 		reg = <0>;
 		rxc-skew-psec = <0>;
 		txc-skew-psec = <0>;
@@ -636,7 +636,7 @@

 &mdio1 {
 	phy1: ethernet-phy@1 {
-		compatible = "ethernet-phy-id0022.1640", "ethernet-phy-ieee802.3-c22";
+		compatible = "ethernet-phy-id001c.c916", "ethernet-phy-ieee802.3-c22";
 		reg = <0>;
 		rxc-skew-psec = <0>;
 		txc-skew-psec = <0>;
--
2.34.1

