From 023b67a44b2d0fed75c912c6685853a2f3b3a2e6 Mon Sep 17 00:00:00 2001
From: Alp Lab AB <gate@alp-lab.se>
Date: Fri, 12 Jun 2026 13:47:22 +0200
Subject: [PATCH] rzv2n-dev: ALP E1M production boot: eMMC 1.8 V rail + pinned
 console

Two build-gated ALP E1M additions:

CONFIG_ALP_E1M_EMMC_1V8 (default y for rzv2n-dev): drive eMMC_V_SEL
(PA0) high in board_init, which runs before initr_mmc/initr_env in
init_sequence_r -- the E1M SoM's eMMC/SD0 IO rail powers up at 3.3 V
from an on-module pull-down, and eMMC defines VccQ as fixed from card
init with no live voltage-switch handshake.  With the rail parked at
1.8 V before the first MMC access, U-Boot's own environment load and
kernel load run the card at its proper signaling voltage and the card
never sees a VccQ transition; Linux re-asserts the same level via a
gpio-hog.  Not enabled for stock Renesas boards whose SD0 channel may
carry a 3.3 V SD card.

CONFIG_ALP_PROD_BOOT (default n, DEV-target only -- the rzv2n-evk.h
config has no override): rebuild the kernel cmdline with the
production settings (console=ttySC0,115200 + quiet loglevel=4,
earlycon dropped); the dev cmdline keeps earlycon but gains the pinned
console=, which stops the kernel replaying the early log across the
console handover.  The cmdline is rebuilt at CONFIG_BOOTCOMMAND rather
than by editing the env block: that block is patched by optional
vendor feature layers (meta-rz-drpai add-ether) and varies per build,
so the stable CONFIG_BOOTCOMMAND line is the only patch-safe hook.

Signed-off-by: Alp Lab AB <gate@alp-lab.se>
---
 board/renesas/rzv2n-dev/Kconfig     | 24 ++++++++++++++++++++++++
 board/renesas/rzv2n-dev/rzv2n-dev.c | 11 +++++++++++
 configs/rzv2n-dev_defconfig         |  1 +
 include/configs/rzv2n-dev.h         | 26 +++++++++++++++++++++++++-
 4 files changed, 61 insertions(+), 1 deletion(-)

diff --git a/board/renesas/rzv2n-dev/Kconfig b/board/renesas/rzv2n-dev/Kconfig
index 4ef61be..bfabe66 100644
--- a/board/renesas/rzv2n-dev/Kconfig
+++ b/board/renesas/rzv2n-dev/Kconfig
@@ -30,3 +30,27 @@ config SYS_CONFIG_NAME
 
 endif
 
+
+config ALP_E1M_EMMC_1V8
+	bool "ALP E1M: drive eMMC_V_SEL (PA0) high before MMC init"
+	depends on TARGET_RZV2N_DEV || TARGET_RZV2N_EVK
+	help
+	  On the ALP E1M V2N SoM family the eMMC/SD0 IO rail is
+	  GPIO-selected (PA0, on-module pull-down -> 3.3 V at power-on).
+	  Drive it high in board_init, which runs before initr_mmc and
+	  initr_env in init_sequence_r -- so VccQ is a stable 1.8 V
+	  before the first MMC access (env load, kernel load).  eMMC
+	  defines VccQ as fixed from card init and has no live
+	  voltage-switch handshake.  Do NOT enable on boards whose SD0
+	  channel carries a 3.3 V SD card.
+
+config ALP_PROD_BOOT
+	bool "ALP E1M: production kernel cmdline (quiet, no earlycon)"
+	depends on TARGET_RZV2N_DEV
+	help
+	  Rebuild the kernel cmdline with the production settings:
+	  console=ttySC0,115200 + quiet loglevel=4, earlycon dropped.
+	  Pair with CONFIG_BOOTDELAY=0 and CONFIG_AUTOBOOT_KEYED (the
+	  ALP prod-boot.cfg fragment).  DEV-target only: the cmdline
+	  rebuild lives in include/configs/rzv2n-dev.h; rzv2n-evk.h has
+	  no override, so the symbol would half-apply there.
diff --git a/board/renesas/rzv2n-dev/rzv2n-dev.c b/board/renesas/rzv2n-dev/rzv2n-dev.c
index b5f159a..a20ccae 100644
--- a/board/renesas/rzv2n-dev/rzv2n-dev.c
+++ b/board/renesas/rzv2n-dev/rzv2n-dev.c
@@ -378,6 +378,17 @@ int board_init(void)
 	/* address of boot parameters */
 	gd->bd->bi_boot_params = CONFIG_TEXT_BASE + 0x50000;
 
+#ifdef CONFIG_ALP_E1M_EMMC_1V8
+	/* eMMC_V_SEL (PA0): the E1M SoM's eMMC/SD0 IO rail powers up
+	 * at 3.3 V (on-module pull-down).  Park it at 1.8 V here --
+	 * board_init runs before initr_mmc/initr_env in
+	 * init_sequence_r, so the rail is stable before the first MMC
+	 * access: eMMC defines VccQ as fixed from card init and must
+	 * never see a mid-session change.  Linux re-asserts the same
+	 * level via a gpio-hog. */
+	alp_gpio_output(10, 0, 1);
+#endif
+
 	board_usb_init();
 
 	return 0;
diff --git a/configs/rzv2n-dev_defconfig b/configs/rzv2n-dev_defconfig
index 7ced1c5..e04099d 100644
--- a/configs/rzv2n-dev_defconfig
+++ b/configs/rzv2n-dev_defconfig
@@ -97,3 +97,4 @@ CONFIG_USB_GADGET_DOWNLOAD=y
 CONFIG_USB_FUNCTION_MASS_STORAGE=y
 CONFIG_CMD_USB_MASS_STORAGE=y
 
+CONFIG_ALP_E1M_EMMC_1V8=y
diff --git a/include/configs/rzv2n-dev.h b/include/configs/rzv2n-dev.h
index ad8f46a..ac562a9 100644
--- a/include/configs/rzv2n-dev.h
+++ b/include/configs/rzv2n-dev.h
@@ -70,7 +70,31 @@
 	"sd2load=ext4load mmc 1:2 0x48080000 boot/Image;ext4load mmc 1:2 0x48000000 boot/r9a09g056n44-dev.dtb;run prodsdbootargs \0" \
 	"bootcmd_check=if mmc dev 1; then run sd2load; else run emmcload; fi \0"
 
-#define CONFIG_BOOTCOMMAND	"env default -a;run bootcmd_check;run bootimage"
+/* ALP: kernel cmdline base.  console= pinned so the early kernel log
+ * is not replayed across the console handover; the production build
+ * drops earlycon and quiets the console. */
+#ifdef CONFIG_ALP_PROD_BOOT
+#define ALP_BOOTARGS_BASE	"console=ttySC0,115200 rootwait rw quiet loglevel=4"
+#else
+#define ALP_BOOTARGS_BASE	"console=ttySC0,115200 rootwait rw earlycon"
+#endif
+
+/* ALP: bootargs are REBUILT here rather than by editing the env block
+ * above -- that block is patched by optional vendor feature layers
+ * (e.g. meta-rz-drpai add-ether) and its contents vary per build, so
+ * an override at this stable line is the only patch-safe hook.  The
+ * vendor prodsd/prodemmcbootargs still run inside *load but are
+ * deliberately overridden (left untouched for patch safety).  The
+ * sd-vs-emmc root choice mirrors bootcmd_check.
+ * FUTURE (per-SKU dtb): any EEPROM-manifest-derived fdtfile must be
+ * set AFTER the leading "env default -a" wipe (i.e. from within this
+ * override), and the dtb load will move out of bootcmd_check into
+ * here, with the name injected per-MACHINE via a Kconfig string +
+ * .cfg fragment (same channel as prod-boot.cfg). */
+#define CONFIG_BOOTCOMMAND	"env default -a;run bootcmd_check;" \
+	"if mmc dev 1; then setenv alp_root /dev/mmcblk2p2; else setenv alp_root /dev/mmcblk0p2; fi;" \
+	"setenv bootargs " ALP_BOOTARGS_BASE " root=${alp_root};" \
+	"run bootimage"
 
 /* For board */
 /* Ethernet RAVB */
-- 
2.34.1

